---
import BaseLayout from '../layouts/BaseLayout.astro'; import Hero from '../components/Hero.astro'; import ServiceCard from '../components/ServiceCard.astro'; import ArticleCard from '../components/ArticleCard.astro'; import SectionHeader from '../components/SectionHeader.astro'; import StatCard from '../components/StatCard.astro'; import TeamCard from '../components/TeamCard.astro'; import Timeline from '../components/Timeline.astro'; import CallToAction from '../components/CallToAction.astro'; import {library} from '../data/library';
const articles=library.filter(i=>i.type==='article').slice(0,3);
---
<BaseLayout title="Sachverständige und Großschadenregulierung" description="SV-Netzwerk: technische Schadenbewertung, Großschadenregulierung, Fachwissen und SVOS."><Hero eyebrow="SV-Netzwerk · Bau & Schaden" title="Technische Klarheit für komplexe Schadenentscheidungen." text="Sachverständigenleistungen, Großschadenregulierung und ein dokumentationsstarkes SV Operating System für belastbare Entscheidungen." primaryLabel="Schaden melden" primaryHref="/schaden-melden/" secondaryLabel="Fachwissen öffnen" secondaryHref="/fachwissen/"/><section class="sv-section"><div class="sv-container"><SectionHeader eyebrow="Leistungen" title="Fachlich prüfen. Klar dokumentieren. Sicher entscheiden." text="Leistungen werden nicht isoliert, sondern als durchgängiger Prüf- und Entscheidungsprozess organisiert."/><div class="sv-grid sv-grid-3"><ServiceCard number="01" title="Komplex- und Großschäden" text="Technische Einordnung, Reservebewertung und dokumentierte Steuerung mehrstufiger Schadenverläufe." href="/komplexschaeden/"/><ServiceCard number="02" title="Sachverständigenleistungen" text="Nachvollziehbare Feststellungen, fachliche Bewertungen und belastbare Empfehlungen." href="/leistungen/"/><ServiceCard number="03" title="Gutachter-Plattform" text="Digitale Zusammenarbeit und vernetzte Fachkompetenz für moderne Schadenprozesse." href="/gutachter-plattform/"/></div></div></section><section class="sv-section sv-section-alt"><div class="sv-container"><SectionHeader eyebrow="SV Operating System" title="Ein gemeinsamer Standard für jeden Bearbeitungsschritt." text="SVOS verbindet technische Prüfung, Organisation und Dokumentation."/><div class="stats sv-card"><StatCard value="01" label="Erfassen" text="Schadenbild, Beteiligte und Unterlagen zusammenführen."/><StatCard value="02" label="Prüfen" text="Kausalität, Umfang, Plausibilität und Kosten bewerten."/><StatCard value="03" label="Entscheiden" text="Empfehlungen, Freigaben und Reserven dokumentieren."/></div><Timeline items={[{title:'Auftragsklarheit',text:'Prüfgegenstand, Rollen und Zielsetzung werden eindeutig festgelegt.'},{title:'Technische Abgrenzung',text:'Schadenbedingte Maßnahmen werden von Mängeln, Vorschäden und Instandhaltung getrennt.'},{title:'Regulierungssichere Dokumentation',text:'Feststellungen und Entscheidungen bleiben jederzeit nachvollziehbar.'}]}/></div></section><section class="sv-section"><div class="sv-container"><SectionHeader eyebrow="Fachwissen" title="Aktuelle Beiträge aus Regulierung und Sachverständigenpraxis." text="Die neue Bibliothek bietet Kategorien, Tags, Filter und Suche." href="/fachwissen/" label="Bibliothek öffnen"/><div class="sv-grid sv-grid-3">{articles.map(a=><ArticleCard {...a} />)}</div></div></section><section class="sv-section sv-section-dark sv-surface-dark"><div class="sv-container split"><div><SectionHeader eyebrow="Team & Netzwerk" title="Persönliche Verantwortung mit vernetzter Fachkompetenz." text="Der jeweilige Bearbeitungsstand bleibt klar zugeordnet; Spezialwissen wird gezielt ergänzt."/><a class="sv-button sv-button-light" href="/netzwerk/">Netzwerk ansehen</a></div><TeamCard name="Christian Wächter" role="Sachverständiger & Großschadenregulierer" qualification="DIN EN ISO/IEC 17024 zertifiziert" href="/experten/christian-waechter/"/></div></section><section class="sv-section"><div class="sv-container partner"><SectionHeader eyebrow="Partner" title="Kooperation mit klaren Qualitätsanforderungen." text="Fachpartner werden strukturiert eingebunden und arbeiten auf einer gemeinsamen dokumentarischen Grundlage."/><a class="sv-button sv-button-secondary" href="/partner/">Partnerbereich</a></div></section><CallToAction title="Ein Schadenfall braucht eine klare fachliche Linie." text="Übermitteln Sie die Eckdaten. Wir ordnen den Vorgang ein und benennen die nächsten sinnvollen Schritte." href="/schaden-melden/" label="Schadenfall einreichen"/></BaseLayout>
<style>.stats{display:grid;grid-template-columns:repeat(3,1fr);margin-bottom:3rem;padding:1.5rem}.split{display:grid;grid-template-columns:1.2fr .8fr;align-items:center;gap:4rem}.partner{display:flex;align-items:end;justify-content:space-between;gap:2rem}@media(max-width:52rem){.stats,.split{grid-template-columns:1fr}.partner{align-items:start;flex-direction:column}}</style>
