---
interface Props {
  title?: string;
  variant?: 'info' | 'success' | 'warning' | 'danger';
}

const { title, variant = 'info' } = Astro.props;
---

<aside class:list={['notice', `notice--${variant}`]} role={variant === 'danger' ? 'alert' : 'note'}>
  {title && <strong>{title}</strong>}
  <div class="notice-content"><slot /></div>
</aside>

<style>
  .notice {
    margin-block: var(--sv-space-5);
    padding: var(--sv-space-4) var(--sv-space-5);
    border: 1px solid var(--notice-color);
    border-left-width: 0.3rem;
    border-radius: var(--sv-radius-sm);
    background: color-mix(in srgb, var(--notice-color) 8%, white);
  }

  .notice--info {
    --notice-color: var(--sv-color-primary);
  }

  .notice--success {
    --notice-color: var(--sv-color-success);
  }

  .notice--warning {
    --notice-color: var(--sv-color-warning);
  }

  .notice--danger {
    --notice-color: var(--sv-color-danger);
  }

  .notice-content {
    margin-top: var(--sv-space-2);
  }

  .notice-content :global(:first-child) {
    margin-top: 0;
  }

  .notice-content :global(:last-child) {
    margin-bottom: 0;
  }
</style>
