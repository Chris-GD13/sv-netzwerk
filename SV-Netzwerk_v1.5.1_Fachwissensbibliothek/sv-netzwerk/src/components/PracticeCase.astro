---
interface Props {
  title: string;
  finding?: string;
  assessment?: string;
  recommendation?: string;
}

const { title, finding, assessment, recommendation } = Astro.props;
---

<section class="practice sv-card">
  <p class="eyebrow">Praxisfall</p>
  <h2>{title}</h2>

  {finding && (
    <div>
      <h3>Feststellung</h3>
      <p>{finding}</p>
    </div>
  )}

  {assessment && (
    <div>
      <h3>Bewertung</h3>
      <p>{assessment}</p>
    </div>
  )}

  {recommendation && (
    <div>
      <h3>Empfehlung</h3>
      <p>{recommendation}</p>
    </div>
  )}

  <slot />
</section>

<style>
  .practice {
    margin-block: var(--sv-space-7);
    padding: var(--sv-space-6);
  }

  .eyebrow {
    margin: 0 0 var(--sv-space-2);
    color: var(--sv-color-accent);
    font-size: 0.8rem;
    font-weight: 750;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h2 {
    margin-top: 0;
  }

  h3 {
    margin-bottom: var(--sv-space-1);
    font-size: 1rem;
  }

  p {
    color: var(--sv-color-muted);
  }
</style>
