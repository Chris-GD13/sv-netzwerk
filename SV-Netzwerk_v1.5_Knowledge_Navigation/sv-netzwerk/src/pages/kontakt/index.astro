---
import BaseLayout from '../../layouts/BaseLayout.astro'; import Hero from '../../components/Hero.astro'; import { site } from '../../data/site';
---
<BaseLayout title="Kontakt" description="Kontakt zum SV-Netzwerk für Schadenfälle, Sachverständigenleistungen und Großschadenregulierung."><Hero compact eyebrow="Kontakt" title="Schadenfall oder Projekt fachlich einordnen." text="Senden Sie die wichtigsten Eckdaten und vorhandenen Unterlagen. Wir melden uns mit einer klaren Einschätzung zum weiteren Vorgehen."/><section class="sv-section"><div class="sv-container contact-grid"><article class="sv-card contact"><p class="sv-eyebrow">Niederlassung Süd</p><h2>{site.author.name}</h2><p>{site.author.role}<br/>{site.author.qualification}</p><p>{site.address[0]}<br/>{site.address[1]}</p><p><a href={`mailto:${site.email}`}>{site.email}</a><br/><a href={`tel:${site.phone.replace(/\D/g,'')}`}>{site.phone}</a></p></article><article class="sv-card contact"><p class="sv-eyebrow">Für die Erstzuordnung</p><h2>Diese Angaben helfen.</h2><ul><li>Schadenart und Schadendatum</li><li>Objektanschrift</li><li>Auftraggeber und Versicherung</li><li>Schadennummer, soweit vorhanden</li><li>Fotos, Berichte, Angebote oder Rechnungen</li></ul><a class="sv-button sv-button-primary" href={`mailto:${site.email}?subject=Anfrage%20SV-Netzwerk`}>E-Mail vorbereiten</a></article></div></section></BaseLayout><style>.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:2rem}.contact{padding:clamp(1.5rem,4vw,3rem)}.contact ul{margin:0 0 2rem;padding-left:1.2rem}.contact li{margin:.45rem 0}@media(max-width:46rem){.contact-grid{grid-template-columns:1fr}}</style>
