---
import BaseLayout from '../../layouts/BaseLayout.astro'; import Hero from '../../components/Hero.astro'; import ArticleCard from '../../components/ArticleCard.astro'; import SectionHeader from '../../components/SectionHeader.astro'; import {library,categories,tags} from '../../data/library';
const articles=library.filter(i=>i.type==='article');
---
<BaseLayout title="Fachwissensbibliothek" description="Fachbeiträge, Kategorien, Tags und Suchzugriff zu Schadenregulierung, Bautechnik und Sachverständigenpraxis."><Hero compact eyebrow="Fachwissen" title="Wissen strukturiert finden und sicher anwenden." text="Thematische Navigation, Kategorien, Tags und Volltextsuche führen schnell zu den relevanten fachlichen Grundlagen."/><section class="sv-section"><div class="sv-container"><SectionHeader eyebrow="Bibliothek" title="Fachbeiträge nach Thema und Schlagwort" text="Die Struktur ist für einen kontinuierlich wachsenden Wissensbestand vorbereitet."/><div class="library-tools sv-card"><label>Bibliothek filtern<input type="search" placeholder="Titel, Kategorie oder Schlagwort" data-filter-input/></label><div class="category-nav">{categories.map(c=><button type="button" data-category={c}>{c}</button>)}<button type="button" data-category="all">Alle</button></div><div class="alpha" aria-label="Alphabetische Navigation">{'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('').map(l=><a href={`#${l}`}>{l}</a>)}</div></div><div class="tag-cloud">{tags.map(t=><span class="sv-pill">{t}</span>)}</div><div class="sv-grid sv-grid-3" data-library-grid>{articles.map(a=><div data-library-item data-search={`${a.title} ${a.description} ${a.category} ${a.tags.join(' ')}`.toLowerCase()} data-category={a.category}><ArticleCard category={a.category} title={a.title} text={a.description} href={a.href} date={new Date(a.date).toLocaleDateString('de-DE')}/></div>)}</div><nav class="pagination" aria-label="Seitennavigation"><span aria-current="page">1</span><a href="/fachwissen/?seite=2">2</a><a href="/fachwissen/?seite=2">Weiter →</a></nav></div></section></BaseLayout>
<script is:inline>const input=document.querySelector('[data-filter-input]');const items=[...document.querySelectorAll('[data-library-item]')];function apply(q='',cat='all'){items.forEach(i=>{i.hidden=!(i.dataset.search.includes(q.toLowerCase())&&(cat==='all'||i.dataset.category===cat));});}input?.addEventListener('input',e=>apply(e.target.value));document.querySelectorAll('[data-category]').forEach(b=>b.addEventListener('click',()=>apply(input?.value||'',b.dataset.category)));</script>
<style>.library-tools{display:grid;gap:1rem;margin-bottom:1.5rem;padding:1.25rem}.library-tools label{font-weight:850}.library-tools input{width:100%;margin-top:.45rem;padding:.8rem;border:1px solid var(--sv-color-line);border-radius:.65rem}.category-nav,.alpha,.tag-cloud{display:flex;flex-wrap:wrap;gap:.5rem}.category-nav button,.alpha a{padding:.45rem .7rem;border:1px solid var(--sv-color-line);border-radius:999px;background:white;color:var(--sv-color-primary);font-size:.82rem;font-weight:800;text-decoration:none;cursor:pointer}.tag-cloud{margin-bottom:2rem}.pagination{display:flex;justify-content:center;gap:.5rem;margin-top:2rem}.pagination a,.pagination span{padding:.55rem .8rem;border:1px solid var(--sv-color-line);border-radius:.5rem;text-decoration:none}.pagination span{background:var(--sv-color-primary);color:white}</style>
