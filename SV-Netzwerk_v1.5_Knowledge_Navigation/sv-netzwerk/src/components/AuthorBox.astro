---
import { site } from '../data/site';

interface Props {
  name?: string;
  role?: string;
  qualification?: string;
}

const {
  name = site.author.name,
  role = site.author.role,
  qualification = site.author.qualification,
} = Astro.props;
---

<aside class="author sv-card">
  <div class="initials" aria-hidden="true">
    {name.split(' ').map((part) => part[0]).join('').slice(0, 2)}
  </div>
  <div>
    <strong>{name}</strong>
    <p>{role}<br />{qualification}</p>
  </div>
</aside>

<style>
  .author {
    display: flex;
    align-items: center;
    gap: var(--sv-space-4);
    padding: var(--sv-space-5);
  }

  .initials {
    display: grid;
    width: 3.25rem;
    aspect-ratio: 1;
    place-items: center;
    border-radius: 50%;
    background: var(--sv-color-primary);
    color: white;
    font-weight: 750;
  }

  p {
    margin: var(--sv-space-1) 0 0;
    color: var(--sv-color-muted);
  }
</style>
