---
interface Props { eyebrow?: string; title: string; text: string; primaryLabel?: string; primaryHref?: string; secondaryLabel?: string; secondaryHref?: string; compact?: boolean; }
const { eyebrow, title, text, primaryLabel, primaryHref, secondaryLabel, secondaryHref, compact=false } = Astro.props;
---
<section class:list={['hero',{compact}]}><div class="sv-container hero-grid"><div>{eyebrow&&<p class="sv-eyebrow">{eyebrow}</p>}<h1>{title}</h1><p class="hero-lead">{text}</p><div class="sv-stack">{primaryLabel&&primaryHref&&<a class="sv-button sv-button-light" href={primaryHref}>{primaryLabel}</a>}{secondaryLabel&&secondaryHref&&<a class="sv-button hero-outline" href={secondaryHref}>{secondaryLabel}</a>}</div></div><div class="hero-panel" aria-hidden="true"><span class="line l1"></span><span class="line l2"></span><span class="line l3"></span><strong>SVOS</strong><small>Struktur · Prüfung · Entscheidung</small></div></div></section>
<style>
.hero{position:relative;overflow:hidden;padding-block:clamp(5rem,11vw,9rem);background:linear-gradient(135deg,var(--sv-color-ink) 0%,var(--sv-color-primary) 72%,#285e7e 100%);color:white}.hero::after{position:absolute;inset:auto -12rem -18rem auto;width:35rem;aspect-ratio:1;border:1px solid rgba(255,255,255,.14);border-radius:50%;content:""}.hero.compact{padding-block:4rem}.hero-grid{display:grid;grid-template-columns:minmax(0,1.35fr) minmax(18rem,.65fr);align-items:center;gap:clamp(3rem,7vw,7rem)}.hero h1{max-width:54rem}.hero .sv-eyebrow{color:#f0c56f}.hero-lead{max-width:45rem;margin-bottom:2rem;color:#dce7ee;font-size:clamp(1.12rem,2vw,1.35rem)}.hero-outline{border-color:rgba(255,255,255,.6);color:white}.hero-outline:hover{background:white;color:var(--sv-color-primary)}.hero-panel{position:relative;display:grid;min-height:22rem;place-content:center;padding:2rem;border:1px solid rgba(255,255,255,.22);border-radius:2rem;background:rgba(255,255,255,.08);box-shadow:0 30px 80px rgba(0,0,0,.22);backdrop-filter:blur(8px)}.hero-panel strong{font-family:var(--sv-font-display);font-size:5rem;letter-spacing:-.06em}.hero-panel small{color:#dce7ee;letter-spacing:.08em;text-transform:uppercase}.line{position:absolute;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,.48),transparent);transform:rotate(-25deg)}.l1{top:20%;right:-10%;left:-10%}.l2{top:50%;right:-20%;left:-20%}.l3{top:80%;right:-10%;left:-10%}@media(max-width:52rem){.hero-grid{grid-template-columns:1fr}.hero-panel{min-height:15rem}.hero-panel strong{font-size:4rem}}
</style>
