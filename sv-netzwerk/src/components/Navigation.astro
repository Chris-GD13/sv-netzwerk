---
import MegaMenu from './MegaMenu.astro';
import type { NavItem } from './Header.astro';

interface Props { items: NavItem[]; currentPath: string }
const { items, currentPath } = Astro.props;
const pathIsActive = (href: string) => href === '/' ? currentPath === '/' : currentPath.startsWith(href);
const itemIsActive = (item: NavItem) => pathIsActive(item.href) || Boolean(item.children?.some((child) => pathIsActive(child.href)));
---

<nav class="desktop-nav" aria-label="Hauptnavigation" data-desktop-nav>
  <ul>
    {items.map((item, index) => (
      <li class="desktop-nav__item" data-nav-item>
        {item.children ? (
          <button
            class:list={["desktop-nav__trigger", { "is-active": itemIsActive(item) }]}
            type="button"
            aria-expanded="false"
            aria-controls={`mega-menu-${index}`}
            data-mega-trigger
          >
            <span>{item.label}</span>
            <svg viewBox="0 0 16 16" aria-hidden="true"><path d="m4 6 4 4 4-4" /></svg>
          </button>
        ) : (
          <a class:list={["desktop-nav__link", { "is-active": itemIsActive(item) }]} href={item.href} aria-current={itemIsActive(item) ? 'page' : undefined}>{item.label}</a>
        )}
        {item.children && <MegaMenu item={item} id={`mega-menu-${index}`} currentPath={currentPath} />}
      </li>
    ))}
  </ul>
</nav>

<script is:inline>
  (() => {
    const nav = document.querySelector('[data-desktop-nav]');
    const items = [...(nav?.querySelectorAll('[data-nav-item]') ?? [])];

    const close = (except = null) => items.forEach((item) => {
      if (item === except) return;
      item.querySelector('[data-mega-trigger]')?.setAttribute('aria-expanded', 'false');
      const panel = item.querySelector('[data-mega-menu]');
      if (panel) panel.hidden = true;
    });

    items.forEach((item) => {
      const trigger = item.querySelector('[data-mega-trigger]');
      const panel = item.querySelector('[data-mega-menu]');
      trigger?.addEventListener('click', () => {
        const open = trigger.getAttribute('aria-expanded') !== 'true';
        close(item);
        trigger.setAttribute('aria-expanded', String(open));
        if (panel) panel.hidden = !open;
      });
    });

    document.addEventListener('pointerdown', (event) => {
      if (!(event.target instanceof Element) || !event.target.closest('[data-desktop-nav]')) close();
    });
    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      const active = nav?.querySelector('[data-mega-trigger][aria-expanded="true"]');
      close();
      if (active instanceof HTMLElement) active.focus();
    });
  })();
</script>
