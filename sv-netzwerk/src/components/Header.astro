---
import Navigation from './Navigation.astro';
import MobileMenu from './MobileMenu.astro';
import HamburgerButton from './HamburgerButton.astro';
import SearchButton from './SearchButton.astro';
import LogoMark from './LogoMark.astro';
import { navigation } from '../data/navigation';

const currentPath = Astro.url.pathname;
---

<header class="site-header" data-site-header>
  <div class="sv-container site-header__bar">
    <a class="site-brand" href="/" aria-label="SV-Netzwerk – Startseite">
      <span class="site-brand__symbol" aria-hidden="true"><LogoMark /></span>
      <span class="site-brand__copy">
        <strong>SV-Netzwerk</strong>
        <small>Bau · Schaden · Regulierung</small>
      </span>
    </a>

    <Navigation items={navigation} currentPath={currentPath} />

    <div class="site-header__actions">
      <SearchButton />
      <a class="header-cta" href="/schaden-melden/">
        Schaden melden
        <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 10h12m-5-5 5 5-5 5" /></svg>
      </a>
      <HamburgerButton />
    </div>
  </div>
</header>

<MobileMenu items={navigation} currentPath={currentPath} />

<script is:inline>
  (() => {
    const header = document.querySelector('[data-site-header]');
    const update = () => header?.classList.toggle('is-scrolled', window.scrollY > 16);
    update();
    window.addEventListener('scroll', update, { passive: true });
  })();
</script>
