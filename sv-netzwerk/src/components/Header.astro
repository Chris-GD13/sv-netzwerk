---
const path=Astro.url.pathname;
const groups=[
 {label:'Leistungen',href:'/leistungen/',items:[['Sachverständigenleistungen','/leistungen/'],['Komplexschäden','/komplexschaeden/'],['Großschadenregulierung','/grossschadenregulierung/'],['Schaden melden','/schaden-melden/']]},
 {label:'Fachwissen',href:'/fachwissen/',items:[['Bibliothek','/fachwissen/'],['Praxisfälle','/praxisfaelle/'],['Downloads','/downloads/'],['Wissen in 180 Sekunden','/wissen-in-180-sekunden/']]},
 {label:'SVOS',href:'/svos/',items:[['SV Operating System','/svos/'],['Knowledge Engine','/svos/fachwissen/'],['Komponenten','/komponenten/'],['Suche','/suche/']]}
];
const active=(href:string)=>href==='/'?path===href:path.startsWith(href);
---
<header class="site-header" data-header>
  <div class="header-accent"></div>
  <div class="sv-container header-inner">
    <a class="brand" href="/" aria-label="SV-Netzwerk Startseite">
      <span class="brand-mark"><b>SV</b><i></i></span>
      <span class="brand-copy"><strong>SV-Netzwerk</strong><small>Bau · Schaden · Regulierung</small></span>
    </a>
    <nav class="desktop-nav" aria-label="Hauptnavigation">
      {groups.map(g=><div class="nav-group"><a href={g.href} aria-current={active(g.href)?'page':undefined}>{g.label}</a><div class="mega"><div class="mega-intro"><span>Bereich</span><strong>{g.label}</strong><p>Fachlich strukturiert, direkt erreichbar und konsequent dokumentiert.</p></div><div class="mega-links">{g.items.map(i=><a href={i[1]}><span>{i[0]}</span><b aria-hidden="true">↗</b></a>)}</div></div></div>)}
      <a class:list={['plain-link',{active:active('/netzwerk/')}]} href="/netzwerk/">Netzwerk</a>
      <a class:list={['plain-link',{active:active('/kontakt/')}]} href="/kontakt/">Kontakt</a>
    </nav>
    <div class="header-actions">
      <button class="icon-button" type="button" data-search-open aria-label="Suche öffnen"><span aria-hidden="true">⌕</span></button>
      <a class="header-cta" href="/schaden-melden/">Schaden melden <span aria-hidden="true">→</span></a>
      <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav" data-menu-toggle><span></span><span></span><span></span><b class="sr-only">Navigation öffnen</b></button>
    </div>
  </div>
  <div id="mobile-nav" class="mobile-nav" data-nav><div class="mobile-inner">{groups.map(g=><details><summary>{g.label}</summary><a href={g.href}>Übersicht</a>{g.items.map(i=><a href={i[1]}>{i[0]}</a>)}</details>)}<a href="/netzwerk/">Netzwerk</a><a href="/kontakt/">Kontakt</a><a class="mobile-cta" href="/schaden-melden/">Schaden melden</a></div></div>
</header>
<script is:inline>const header=document.querySelector('[data-header]');const toggle=document.querySelector('[data-menu-toggle]');const nav=document.querySelector('[data-nav]');let ticking=false;const updateHeader=()=>{header?.classList.toggle('is-compact',scrollY>36);ticking=false};window.addEventListener('scroll',()=>{if(!ticking){requestAnimationFrame(updateHeader);ticking=true}},{passive:true});const setMenu=(open)=>{toggle?.setAttribute('aria-expanded',String(open));nav?.classList.toggle('is-open',open);document.body.classList.toggle('menu-open',open)};toggle?.addEventListener('click',()=>setMenu(toggle.getAttribute('aria-expanded')!=='true'));document.addEventListener('keydown',(event)=>{if(event.key==='Escape'&&toggle?.getAttribute('aria-expanded')==='true'){setMenu(false);toggle.focus()}});nav?.querySelectorAll('a').forEach(link=>link.addEventListener('click',()=>setMenu(false)));</script>
<style>
.site-header{position:sticky;top:0;z-index:80;border-bottom:1px solid rgba(214,224,229,.9);background:rgba(255,255,255,.94);backdrop-filter:blur(18px);transition:box-shadow var(--sv-transition)}.header-accent{height:3px;background:linear-gradient(90deg,var(--sv-color-accent) 0 16%,var(--sv-color-primary) 16% 100%)}.site-header.is-compact{box-shadow:0 10px 30px rgba(16,33,48,.08)}.header-inner{display:flex;min-height:5.6rem;align-items:center;justify-content:space-between;gap:1.6rem;transition:min-height var(--sv-transition)}.is-compact .header-inner{min-height:4.6rem}.brand{display:flex;align-items:center;gap:.85rem;color:var(--sv-color-ink);text-decoration:none}.brand-mark{position:relative;display:grid;width:3rem;aspect-ratio:1;place-items:center;border-radius:.72rem;background:var(--sv-color-primary);color:white;box-shadow:0 8px 20px rgba(11,74,111,.2)}.brand-mark i{position:absolute;right:-.12rem;bottom:.4rem;width:.36rem;height:1.3rem;border-radius:1rem;background:var(--sv-color-accent)}.brand-copy strong,.brand-copy small{display:block}.brand-copy strong{font-size:1.04rem;letter-spacing:.01em}.brand-copy small{margin-top:.18rem;color:var(--sv-color-muted);font-size:.64rem;font-weight:800;letter-spacing:.13em;text-transform:uppercase}.desktop-nav{display:flex;align-items:center;gap:1.35rem}.desktop-nav> a,.nav-group>a{position:relative;color:var(--sv-color-ink-soft);font-size:.9rem;font-weight:820;text-decoration:none}.nav-group{position:relative;padding-block:1.9rem}.nav-group>a::after,.plain-link::after{position:absolute;right:0;bottom:-.55rem;left:0;height:2px;transform:scaleX(0);background:var(--sv-color-accent);content:"";transition:transform var(--sv-transition)}.nav-group:hover>a::after,.nav-group>a[aria-current="page"]::after,.plain-link:hover::after,.plain-link.active::after{transform:scaleX(1)}.mega{position:absolute;top:calc(100% - .8rem);left:50%;display:none;width:37rem;grid-template-columns:.9fr 1.1fr;transform:translateX(-50%);overflow:hidden;border:1px solid var(--sv-color-line);border-radius:1.15rem;background:white;box-shadow:var(--sv-shadow-lg)}.nav-group:hover .mega,.nav-group:focus-within .mega{display:grid}.mega-intro{padding:1.6rem;background:var(--sv-color-primary);color:white}.mega-intro span{color:#c6dbe6;font-size:.7rem;font-weight:900;letter-spacing:.14em;text-transform:uppercase}.mega-intro strong{display:block;margin:.4rem 0 .75rem;font-size:1.45rem}.mega-intro p{margin:0;color:#dce8ee;font-size:.88rem}.mega-links{display:grid;padding:.75rem}.mega-links a{display:flex;align-items:center;justify-content:space-between;padding:.82rem .9rem;border-radius:.7rem;color:var(--sv-color-ink);font-weight:780;text-decoration:none}.mega-links a:hover{background:var(--sv-color-surface-alt)}.mega-links b{color:var(--sv-color-accent-strong)}.header-actions{display:flex;align-items:center;gap:.65rem}.icon-button,.menu-toggle{display:grid;width:2.85rem;height:2.85rem;place-items:center;border:1px solid var(--sv-color-line);border-radius:.7rem;background:white;color:var(--sv-color-ink);cursor:pointer}.icon-button{font-size:1.35rem}.header-cta{display:inline-flex;align-items:center;gap:.5rem;min-height:2.85rem;padding:.65rem .95rem;border-radius:.7rem;background:var(--sv-color-accent);color:var(--sv-color-ink);font-size:.88rem;font-weight:850;text-decoration:none}.header-cta:hover{background:#f0b94c;color:var(--sv-color-ink)}.menu-toggle{display:none;padding:.65rem}.menu-toggle span{display:block;width:1.35rem;height:2px;margin:.16rem;background:var(--sv-color-ink)}.mobile-nav{display:none}.mobile-cta{margin-top:1rem;border-radius:.7rem;background:var(--sv-color-accent);color:var(--sv-color-ink)!important;text-align:center;font-weight:850}@media(max-width:74rem){.desktop-nav{display:none}.menu-toggle{display:block}.mobile-nav{position:fixed;inset:4.7rem 0 0 auto;display:block;width:min(30rem,94vw);transform:translateX(105%);background:white;box-shadow:var(--sv-shadow-lg);transition:transform var(--sv-transition);overflow:auto}.mobile-nav.is-open{transform:none}.mobile-inner{display:grid;padding:1rem}.mobile-inner details,.mobile-inner>a{padding:1rem;border-bottom:1px solid var(--sv-color-line)}.mobile-inner summary{cursor:pointer;font-weight:850}.mobile-inner details a{display:block;padding:.65rem 0;text-decoration:none}}@media(max-width:38rem){.header-cta{display:none}.brand-copy small{display:none}}
</style>
