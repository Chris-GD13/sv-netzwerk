---
const current=Astro.url.pathname;
const groups=[
 {label:'Leistungen',href:'/leistungen/',items:[['Komplex- und Großschäden','/komplexschaeden/'],['Großschadenregulierung','/grossschadenregulierung/'],['Sachverständigenleistungen','/leistungen/'],['Schaden melden','/schaden-melden/']]},
 {label:'Fachwissen',href:'/fachwissen/',items:[['Bibliothek','/fachwissen/'],['Leitungswasser','/fachwissen/kategorie/leitungswasser/'],['Brandschäden','/fachwissen/kategorie/brandschaden/'],['Schadenregulierung','/fachwissen/kategorie/schadenregulierung/']]},
 {label:'Downloads',href:'/downloads/',items:[['Prüflisten','/downloads/'],['Wissen in 180 Sekunden','/wissen-in-180-sekunden/'],['SVOS','/svos/'],['Gutachter-Plattform','/gutachter-plattform/']]}
];
---
<header class="site-header" data-header><div class="sv-container header-inner"><a class="brand" href="/" aria-label="SV-Netzwerk Startseite"><span class="brand-mark">SV</span><span><strong>SV-Netzwerk</strong><small>Bau & Schaden</small></span></a><nav class="desktop-nav" aria-label="Hauptnavigation">{groups.map(g=><div class="nav-group"><a href={g.href} aria-current={current.startsWith(g.href)?'page':undefined}>{g.label}</a><div class="mega"><strong>{g.label}</strong>{g.items.map(i=><a href={i[1]}>{i[0]}<span>→</span></a>)}</div></div>)}<a href="/netzwerk/">Netzwerk</a></nav><div class="header-actions"><button class="icon-button" type="button" data-search-open aria-label="Suche öffnen" title="Suche öffnen (Strg/Cmd + K)">⌕</button><a class="sv-button sv-button-primary nav-cta" href="/schaden-melden/">Schaden melden</a><button class="menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav" data-menu-toggle><span></span><span></span><span></span><b class="sr-only">Navigation öffnen</b></button></div></div><div id="mobile-nav" class="mobile-nav" data-nav><div class="mobile-inner">{groups.map(g=><details><summary>{g.label}</summary><a href={g.href}>Übersicht</a>{g.items.map(i=><a href={i[1]}>{i[0]}</a>)}</details>)}<a href="/netzwerk/">Netzwerk</a><a href="/kontakt/">Kontakt</a></div></div></header>
<script is:inline>const header=document.querySelector('[data-header]');const toggle=document.querySelector('[data-menu-toggle]');const nav=document.querySelector('[data-nav]');window.addEventListener('scroll',()=>header?.classList.toggle('is-compact',scrollY>40),{passive:true});toggle?.addEventListener('click',()=>{const open=toggle.getAttribute('aria-expanded')==='true';toggle.setAttribute('aria-expanded',String(!open));nav?.classList.toggle('is-open',!open);document.body.classList.toggle('menu-open',!open);});</script>
<style>.site-header{position:sticky;top:0;z-index:60;border-bottom:1px solid color-mix(in srgb,var(--sv-color-line) 82%,transparent);background:color-mix(in srgb,var(--sv-color-surface) 93%,transparent);backdrop-filter:blur(18px);transition:box-shadow var(--sv-transition)}.site-header.is-compact{box-shadow:var(--sv-shadow-sm)}.header-inner{display:flex;min-height:5.25rem;align-items:center;justify-content:space-between;gap:1.5rem;transition:min-height var(--sv-transition)}.is-compact .header-inner{min-height:4.3rem}.brand{display:flex;align-items:center;gap:.75rem;color:var(--sv-color-ink);text-decoration:none}.brand-mark{display:grid;width:2.65rem;aspect-ratio:1;place-items:center;border-radius:.7rem;background:var(--sv-color-primary);color:white;font-weight:900}.brand strong,.brand small{display:block;line-height:1.1}.brand small{margin-top:.2rem;color:var(--sv-color-muted);font-size:.7rem;letter-spacing:.09em;text-transform:uppercase}.desktop-nav{display:flex;align-items:center;gap:1.45rem}.desktop-nav> a,.nav-group>a{color:var(--sv-color-ink-soft);font-size:.92rem;font-weight:800;text-decoration:none}.nav-group{position:relative;padding-block:1.5rem}.nav-group>a[aria-current="page"]{color:var(--sv-color-primary)}.mega{position:absolute;top:calc(100% - .5rem);left:50%;display:none;width:22rem;transform:translateX(-50%);padding:1rem;border:1px solid var(--sv-color-line);border-radius:1rem;background:white;box-shadow:var(--sv-shadow-lg)}.nav-group:hover .mega,.nav-group:focus-within .mega{display:grid}.mega strong{padding:.5rem .65rem;color:var(--sv-color-muted);font-size:.75rem;letter-spacing:.12em;text-transform:uppercase}.mega a{display:flex;justify-content:space-between;padding:.75rem;border-radius:.65rem;color:var(--sv-color-ink);font-weight:750;text-decoration:none}.mega a:hover{background:var(--sv-color-surface-alt)}.header-actions{display:flex;align-items:center;gap:.65rem}.icon-button,.menu-toggle{display:grid;width:2.85rem;height:2.85rem;place-items:center;border:1px solid var(--sv-color-line);border-radius:.7rem;background:white;color:var(--sv-color-ink);cursor:pointer}.icon-button{font-size:1.4rem}.menu-toggle{display:none;padding:.65rem}.menu-toggle span{display:block;width:1.35rem;height:2px;margin:.16rem;background:var(--sv-color-ink)}.mobile-nav{display:none}.sr-only{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)}@media(max-width:72rem){.desktop-nav{display:none}.menu-toggle{display:block}.mobile-nav{position:fixed;inset:4.3rem 0 0 auto;display:block;width:min(28rem,92vw);transform:translateX(105%);background:white;box-shadow:var(--sv-shadow-lg);transition:transform var(--sv-transition);overflow:auto}.mobile-nav.is-open{transform:none}.mobile-inner{display:grid;padding:1rem}.mobile-inner details,.mobile-inner>a{padding:1rem;border-bottom:1px solid var(--sv-color-line)}.mobile-inner summary{cursor:pointer;font-weight:850}.mobile-inner details a{display:block;padding:.65rem 0;text-decoration:none}.nav-cta{display:none}}@media(max-width:30rem){.brand small{display:none}}</style>
