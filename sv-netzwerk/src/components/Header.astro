---
import Navigation from './Navigation.astro';
import MobileMenu from './MobileMenu.astro';
import HamburgerButton from './HamburgerButton.astro';
import SearchButton from './SearchButton.astro';

export type NavChild = { label: string; href: string; description: string };
export type NavItem = { label: string; href: string; description?: string; children?: NavChild[] };

const currentPath = Astro.url.pathname;
const navigation: NavItem[] = [
  {
    label: 'Leistungen',
    href: '/leistungen/',
    description: 'Vom Schadenbild zur belastbaren Entscheidung.',
    children: [
      { label: 'Alle Leistungen', href: '/leistungen/', description: 'Unser Leistungsspektrum im Überblick.' },
      { label: 'Komplexschäden', href: '/komplexschaeden/', description: 'Interdisziplinäre Bewertung komplexer Schadenbilder.' },
      { label: 'Großschadenregulierung', href: '/grossschadenregulierung/', description: 'Struktur und Steuerung für hohe Schadenvolumina.' },
      { label: 'Schaden melden', href: '/schaden-melden/', description: 'Einen neuen Schaden direkt an uns übermitteln.' },
    ],
  },
  {
    label: 'Wissen',
    href: '/fachwissen/',
    description: 'Fachwissen, das in der Praxis weiterhilft.',
    children: [
      { label: 'Fachwissen', href: '/fachwissen/', description: 'Fundierte Beiträge aus Technik und Regulierung.' },
      { label: 'Praxisfälle', href: '/praxisfaelle/', description: 'Reale Fälle nachvollziehbar aufbereitet.' },
      { label: 'Downloads', href: '/downloads/', description: 'Checklisten und Arbeitshilfen zum Mitnehmen.' },
      { label: 'Wissen in 180 Sekunden', href: '/wissen-in-180-sekunden/', description: 'Komplexe Themen schnell auf den Punkt gebracht.' },
    ],
  },
  {
    label: 'SVOS',
    href: '/svos/',
    description: 'Ein System für konsistente Schadenbearbeitung.',
    children: [
      { label: 'SV Operating System', href: '/svos/', description: 'Standards, Prozesse und Wissen in einem System.' },
      { label: 'Gutachter-Plattform', href: '/gutachter-plattform/', description: 'Digitale Zusammenarbeit für Sachverständige.' },
      { label: 'Für Versicherer', href: '/versicherer/', description: 'Prüffähige Abläufe und transparente Ergebnisse.' },
      { label: 'Expertennetzwerk', href: '/netzwerk/', description: 'Spezialisierte Kompetenz gezielt vernetzt.' },
    ],
  },
  { label: 'Netzwerk', href: '/netzwerk/' },
];
---

<header class="site-header" data-site-header>
  <div class="sv-container site-header__bar">
    <a class="site-brand" href="/" aria-label="SV-Netzwerk – Startseite">
      <span class="site-brand__symbol" aria-hidden="true">
        <svg viewBox="0 0 42 42"><path d="M8 9h26v24H8z"/><path d="M14 15h14M14 21h9M14 27h14"/></svg>
      </span>
      <span class="site-brand__copy">
        <strong>SV-Netzwerk</strong>
        <small>Bau · Schaden · Regulierung</small>
      </span>
    </a>

    <Navigation items={navigation} currentPath={currentPath} />

    <div class="site-header__actions">
      <span class="header-availability"><i aria-hidden="true"></i> Bundesweit verfügbar</span>
      <SearchButton />
      <a class="header-cta" href="/schaden-melden/">
        Schaden melden
        <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 10h12m-5-5 5 5-5 5" /></svg>
      </a>
      <HamburgerButton />
    </div>
  </div>
</header>

<MobileMenu items={navigation} currentPath={currentPath} />

<script is:inline>
  (() => {
    const header = document.querySelector('[data-site-header]');
    const update = () => header?.classList.toggle('is-scrolled', window.scrollY > 16);
    update();
    window.addEventListener('scroll', update, { passive: true });
  })();
</script>
