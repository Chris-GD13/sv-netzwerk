---
const current = Astro.url.pathname;
const groups = [
  { label: 'Leistungen', href: '/leistungen/', description: 'Technische Bewertung und Regulierung', items: [
    ['Komplex- und Großschäden','/komplexschaeden/','Strukturierte Bearbeitung komplexer Schadenlagen'],
    ['Großschadenregulierung','/grossschadenregulierung/','Koordination, Prüfung und belastbare Entscheidungen'],
    ['Sachverständigenleistungen','/leistungen/','Technische Expertise für Bau- und Versicherungsschäden']
  ]},
  { label: 'Fachwissen', href: '/fachwissen/', description: 'Praxiswissen für bessere Entscheidungen', items: [
    ['Fachwissensbibliothek','/fachwissen/','Beiträge, Normen und technische Einordnungen'],
    ['Praxisfälle','/praxisfaelle/','Reale Fälle strukturiert dokumentiert'],
    ['Downloads','/downloads/','Prüflisten, Merkblätter und Arbeitshilfen']
  ]},
  { label: 'SVOS', href: '/svos/', description: 'Das Operating System für Schadenprozesse', items: [
    ['SVOS Foundation','/svos/','Einheitliche Standards und digitale Prozesse'],
    ['Gutachter-Plattform','/gutachter-plattform/','Experten, Aufträge und prüffähige Unterlagen'],
    ['Netzwerk','/netzwerk/','Vernetzte Kompetenz mit klarer Verantwortung']
  ]}
];
---
<header class="site-header" data-header>
  <div class="header-shell sv-container">
    <a class="brand" href="/" aria-label="SV-Netzwerk Startseite">
      <span class="brand-symbol" aria-hidden="true"><span>SV</span></span>
      <span class="brand-copy"><strong>SV-Netzwerk</strong><small>Bau · Schaden · Regulierung</small></span>
    </a>

    <nav class="desktop-nav" aria-label="Hauptnavigation">
      {groups.map((group) => (
        <div class="nav-group">
          <a class="nav-link" href={group.href} aria-current={current.startsWith(group.href) ? 'page' : undefined}>{group.label}<span aria-hidden="true">⌄</span></a>
          <div class="mega-menu">
            <div class="mega-intro"><span>{group.label}</span><strong>{group.description}</strong><a href={group.href}>Übersicht öffnen →</a></div>
            <div class="mega-links">{group.items.map((item) => <a href={item[1]}><strong>{item[0]}</strong><small>{item[2]}</small></a>)}</div>
          </div>
        </div>
      ))}
      <a class="nav-link" href="/partner/" aria-current={current.startsWith('/partner/') ? 'page' : undefined}>Partner</a>
    </nav>

    <div class="header-actions">
      <button class="search-trigger" type="button" data-search-open aria-label="Suche öffnen"><span aria-hidden="true">⌕</span><b>Suche</b></button>
      <a class="sv-button sv-button-primary desktop-cta" href="/schaden-melden/">Schaden melden</a>
      <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav" data-menu-toggle>
        <span></span><span></span><span></span><b class="sr-only">Navigation öffnen</b>
      </button>
    </div>
  </div>

  <div class="mobile-backdrop" data-mobile-backdrop></div>
  <aside id="mobile-nav" class="mobile-nav" data-nav aria-label="Mobile Navigation" aria-hidden="true">
    <div class="mobile-head"><strong>Navigation</strong><button type="button" data-menu-close aria-label="Navigation schließen">×</button></div>
    <div class="mobile-content">
      {groups.map((group) => (
        <details>
          <summary>{group.label}<span>+</span></summary>
          <a class="mobile-overview" href={group.href}>{group.description}</a>
          {group.items.map((item) => <a href={item[1]}><strong>{item[0]}</strong><small>{item[2]}</small></a>)}
        </details>
      ))}
      <a class="mobile-single" href="/partner/">Partner</a>
      <a class="mobile-single" href="/kontakt/">Kontakt</a>
      <a class="sv-button sv-button-primary mobile-cta" href="/schaden-melden/">Schaden melden</a>
    </div>
  </aside>
</header>
<script is:inline>
  const header=document.querySelector('[data-header]');
  const toggle=document.querySelector('[data-menu-toggle]');
  const close=document.querySelector('[data-menu-close]');
  const nav=document.querySelector('[data-nav]');
  const backdrop=document.querySelector('[data-mobile-backdrop]');
  let ticking=false;
  const updateHeader=()=>{header?.classList.toggle('is-compact',window.scrollY>28);ticking=false};
  window.addEventListener('scroll',()=>{if(!ticking){requestAnimationFrame(updateHeader);ticking=true}},{passive:true});
  const setMenu=(open)=>{
    toggle?.setAttribute('aria-expanded',String(open));
    nav?.setAttribute('aria-hidden',String(!open));
    nav?.classList.toggle('is-open',open);
    backdrop?.classList.toggle('is-open',open);
    document.body.classList.toggle('menu-open',open);
  };
  toggle?.addEventListener('click',()=>setMenu(toggle.getAttribute('aria-expanded')!=='true'));
  close?.addEventListener('click',()=>setMenu(false));
  backdrop?.addEventListener('click',()=>setMenu(false));
  document.addEventListener('keydown',(event)=>{if(event.key==='Escape'){setMenu(false);toggle?.focus()}});
  nav?.querySelectorAll('a').forEach(link=>link.addEventListener('click',()=>setMenu(false)));
</script>
<style>
.site-header{position:sticky;top:0;z-index:100;border-bottom:1px solid color-mix(in srgb,var(--sv-color-line) 80%,transparent);background:rgba(255,255,255,.92);backdrop-filter:blur(18px);transition:box-shadow var(--sv-transition),background var(--sv-transition)}.site-header.is-compact{box-shadow:0 10px 36px rgba(7,26,45,.1);background:rgba(255,255,255,.97)}.header-shell{display:flex;min-height:5.4rem;align-items:center;justify-content:space-between;gap:1.5rem;transition:min-height var(--sv-transition)}.is-compact .header-shell{min-height:4.5rem}.brand{display:flex;align-items:center;gap:.8rem;color:var(--sv-color-ink);text-decoration:none}.brand-symbol{display:grid;width:3rem;aspect-ratio:1;place-items:center;clip-path:polygon(50% 0,94% 25%,94% 75%,50% 100%,6% 75%,6% 25%);background:linear-gradient(135deg,var(--sv-color-primary),var(--sv-color-primary-bright));color:white;font-size:.8rem;font-weight:950}.brand-copy strong,.brand-copy small{display:block;line-height:1.05}.brand-copy strong{font-size:1.05rem;letter-spacing:-.025em}.brand-copy small{margin-top:.25rem;color:var(--sv-color-muted);font-size:.63rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase}.desktop-nav{display:flex;align-items:center;gap:.3rem}.nav-group{position:relative}.nav-link{display:flex;align-items:center;gap:.35rem;padding:1rem .72rem;border-radius:.65rem;color:var(--sv-color-ink-soft);font-size:.9rem;font-weight:850;text-decoration:none}.nav-link:hover,.nav-link[aria-current="page"]{background:var(--sv-color-surface-alt);color:var(--sv-color-primary)}.nav-group:hover .mega-menu,.nav-group:focus-within .mega-menu{visibility:visible;transform:translate(-50%,0);opacity:1;pointer-events:auto}.mega-menu{position:absolute;top:calc(100% + .7rem);left:50%;display:grid;visibility:hidden;width:min(44rem,80vw);grid-template-columns:.8fr 1.6fr;transform:translate(-50%,-.5rem);overflow:hidden;border:1px solid var(--sv-color-line);border-radius:1.2rem;background:white;box-shadow:var(--sv-shadow-lg);opacity:0;pointer-events:none;transition:opacity var(--sv-transition),transform var(--sv-transition),visibility var(--sv-transition)}.mega-intro{padding:1.5rem;background:linear-gradient(145deg,var(--sv-color-primary),#08243c);color:white}.mega-intro>span{color:#ffc95f;font-size:.72rem;font-weight:900;letter-spacing:.14em;text-transform:uppercase}.mega-intro strong{display:block;margin:.75rem 0 1.3rem;font-size:1.35rem;line-height:1.2}.mega-intro a{color:white;font-size:.86rem;font-weight:800;text-decoration:none}.mega-links{display:grid;padding:.7rem}.mega-links a{display:block;padding:1rem;border-radius:.8rem;color:var(--sv-color-ink);text-decoration:none}.mega-links a:hover{background:var(--sv-color-surface-alt)}.mega-links strong,.mega-links small{display:block}.mega-links small{margin-top:.18rem;color:var(--sv-color-muted);font-size:.78rem;line-height:1.4}.header-actions{display:flex;align-items:center;gap:.6rem}.search-trigger{display:flex;min-height:2.9rem;align-items:center;gap:.4rem;padding:.65rem .8rem;border:1px solid var(--sv-color-line);border-radius:.7rem;background:white;color:var(--sv-color-ink);cursor:pointer}.search-trigger span{font-size:1.25rem}.search-trigger b{font-size:.78rem}.menu-toggle{display:none;width:3rem;height:3rem;padding:.7rem;border:1px solid var(--sv-color-line);border-radius:.7rem;background:white;cursor:pointer}.menu-toggle span{display:block;width:1.55rem;height:2px;margin:.25rem auto;background:var(--sv-color-ink)}.mobile-nav,.mobile-backdrop{display:none}
@media(max-width:72rem){.desktop-nav,.desktop-cta,.search-trigger b{display:none}.menu-toggle{display:block}.mobile-backdrop{position:fixed;inset:0;display:block;visibility:hidden;background:rgba(4,18,31,.55);opacity:0;transition:opacity var(--sv-transition),visibility var(--sv-transition)}.mobile-backdrop.is-open{visibility:visible;opacity:1}.mobile-nav{position:fixed;inset:0 0 0 auto;display:flex;width:min(31rem,94vw);flex-direction:column;transform:translateX(105%);background:white;box-shadow:-30px 0 80px rgba(7,26,45,.24);transition:transform var(--sv-transition-slow)}.mobile-nav.is-open{transform:none}.mobile-head{display:flex;align-items:center;justify-content:space-between;padding:1.25rem;border-bottom:1px solid var(--sv-color-line)}.mobile-head strong{font-size:1.1rem}.mobile-head button{width:2.7rem;height:2.7rem;border:0;border-radius:.7rem;background:var(--sv-color-surface-alt);font-size:1.8rem;cursor:pointer}.mobile-content{overflow:auto;padding:1rem 1rem 2rem}.mobile-content details{border-bottom:1px solid var(--sv-color-line)}.mobile-content summary{display:flex;align-items:center;justify-content:space-between;padding:1rem .25rem;cursor:pointer;font-weight:900;list-style:none}.mobile-content summary::-webkit-details-marker{display:none}.mobile-content details>a{display:block;padding:.75rem;border-radius:.7rem;color:var(--sv-color-ink);text-decoration:none}.mobile-content details>a:hover{background:var(--sv-color-surface-alt)}.mobile-content details strong,.mobile-content details small{display:block}.mobile-content details small{margin-top:.15rem;color:var(--sv-color-muted);font-size:.76rem}.mobile-overview{background:var(--sv-color-surface-blue);font-weight:800}.mobile-single{display:block;padding:1rem .25rem;border-bottom:1px solid var(--sv-color-line);color:var(--sv-color-ink);font-weight:900;text-decoration:none}.mobile-cta{width:100%;margin-top:1.2rem}}
@media(max-width:34rem){.header-shell{min-height:4.7rem}.brand-copy small{display:none}.brand-symbol{width:2.7rem}}
</style>
