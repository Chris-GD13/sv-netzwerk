---
import Navigation from './Navigation.astro';
import MobileMenu from './MobileMenu.astro';
import HamburgerButton from './HamburgerButton.astro';
import SearchButton from './SearchButton.astro';

export type NavChild = { label: string; href: string; description: string };
export type NavItem = { label: string; href: string; description?: string; children?: NavChild[] };

const currentPath = Astro.url.pathname;
const navigation: NavItem[] = [
  {
    label: 'Leistungen',
    href: '/leistungen/',
    description: 'Schäden strukturiert prüfen, bewerten und regulieren.',
    children: [
      { label: 'Leistungsübersicht', href: '/leistungen/', description: 'Technische Prüfung und Schadenregulierung aus einer Hand.' },
      { label: 'Komplexschäden', href: '/komplexschaeden/', description: 'Interdisziplinäre Bearbeitung anspruchsvoller Schadenbilder.' },
      { label: 'Großschadenregulierung', href: '/grossschadenregulierung/', description: 'Klare Steuerung bei hohen Schadenvolumina.' },
      { label: 'Schaden melden', href: '/schaden-melden/', description: 'Eckdaten sicher und direkt an uns übermitteln.' },
    ],
  },
  {
    label: 'Fachwissen',
    href: '/fachwissen/',
    description: 'Praxiserprobtes Wissen für fundierte Entscheidungen.',
    children: [
      { label: 'Wissensbibliothek', href: '/fachwissen/', description: 'Fachbeiträge aus Technik und Regulierung.' },
      { label: 'Praxisfälle', href: '/praxisfaelle/', description: 'Nachvollziehbare Fälle aus der Schadenpraxis.' },
      { label: 'Downloads', href: '/downloads/', description: 'Prüfschemata, Checklisten und Arbeitshilfen.' },
      { label: 'Wissen in 180 Sekunden', href: '/wissen-in-180-sekunden/', description: 'Komplexe Fachthemen kompakt erklärt.' },
    ],
  },
  {
    label: 'SVOS',
    href: '/svos/',
    description: 'Digitale Standards für vernetzte Sachverständigenarbeit.',
    children: [
      { label: 'SV Operating System', href: '/svos/', description: 'Standardisierte Fach- und Prozessarchitektur.' },
      { label: 'Gutachter-Plattform', href: '/gutachter-plattform/', description: 'Qualifizierte Sachverständige intelligent vernetzen.' },
      { label: 'Für Sachverständige', href: '/experten/', description: 'Werkzeuge, Standards und starke Zusammenarbeit.' },
      { label: 'Für Versicherer', href: '/versicherer/', description: 'Prüffähige und dokumentationsstarke Abläufe.' },
    ],
  },
  { label: 'Netzwerk', href: '/netzwerk/' },
];
---

<header class="site-header" data-site-header>
  <div class="site-header__utility">
    <div class="sv-container site-header__utility-inner">
      <p><span class="status-dot" aria-hidden="true"></span> Bundesweit für Sie im Einsatz</p>
      <div>
        <span>DIN EN ISO/IEC 17024 zertifiziert</span>
        <a href="tel:+4973673939783" aria-label="Anrufen unter 07367 393 97 83">07367 / 393 97 83</a>
      </div>
    </div>
  </div>

  <div class="sv-container site-header__bar">
    <a class="site-brand" href="/" aria-label="SV-Netzwerk – Startseite">
      <span class="site-brand__mark" aria-hidden="true"><span>SV</span></span>
      <span class="site-brand__copy">
        <strong>SV-Netzwerk</strong>
        <small>Bau · Schaden · Regulierung</small>
      </span>
    </a>

    <Navigation items={navigation} currentPath={currentPath} />

    <div class="site-header__actions">
      <SearchButton />
      <a class="header-link" href="/kontakt/">Kontakt</a>
      <a class="header-cta" href="/schaden-melden/">
        Schaden melden
        <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 10h12m-5-5 5 5-5 5" /></svg>
      </a>
      <HamburgerButton />
    </div>
  </div>
</header>

<MobileMenu items={navigation} currentPath={currentPath} />

<script is:inline>
  (() => {
    const header = document.querySelector('[data-site-header]');
    const updateHeader = () => header?.classList.toggle('is-scrolled', window.scrollY > 12);
    updateHeader();
    window.addEventListener('scroll', updateHeader, { passive: true });
  })();
</script>
