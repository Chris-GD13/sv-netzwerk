---
import type { TimelineItem } from '../types/components';
interface Props { items: TimelineItem[]; numbered?: boolean; }
const {items,numbered=true}=Astro.props as Props;
---
<ol class="timeline">{items.map((item,index)=><li><div class="marker" aria-hidden="true">{numbered?String(index+1).padStart(2,'0'):'•'}</div><div><div class="meta">{item.date}</div><h3>{item.title}</h3><p>{item.text}</p></div></li>)}</ol>
<style>.timeline{margin:0;padding:0;list-style:none}.timeline li{position:relative;display:grid;grid-template-columns:4rem 1fr;gap:1.25rem;padding:1.5rem 0;border-bottom:1px solid var(--sv-color-line)}.marker{display:grid;width:3rem;height:3rem;place-items:center;border-radius:50%;background:var(--sv-color-accent-soft);color:var(--sv-color-primary);font-weight:900}.timeline p{margin:0;color:var(--sv-color-muted)}.meta{margin-bottom:.25rem;color:var(--sv-color-muted);font-size:.82rem;font-weight:800;text-transform:uppercase}@media(max-width:34rem){.timeline li{grid-template-columns:3rem 1fr}.marker{width:2.5rem;height:2.5rem}}</style>
