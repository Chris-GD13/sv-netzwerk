---
import type { FAQItem } from '../types/components';
interface Props { items: FAQItem[]; openFirst?: boolean; }
const {items,openFirst=true}=Astro.props as Props;
---
<div class="faq">{items.map((item,index)=><details class="sv-card" open={openFirst&&index===0}><summary><span>{item.question}</span><span class="plus" aria-hidden="true">+</span></summary><p>{item.answer}</p></details>)}</div>
<style>.faq{display:grid;gap:.75rem}details{padding:1.1rem 1.25rem}summary{display:flex;cursor:pointer;align-items:center;justify-content:space-between;gap:1rem;font-weight:850;list-style:none}summary::-webkit-details-marker{display:none}.plus{font-size:1.45rem;transition:transform var(--sv-transition)}details[open] .plus{transform:rotate(45deg)}details p{margin:1rem 0 0;color:var(--sv-color-muted)}</style>
