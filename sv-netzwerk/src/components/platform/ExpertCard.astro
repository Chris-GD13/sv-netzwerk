---
import type { ExpertProfile } from '../../types/platform';
interface Props { expert: ExpertProfile; }
const { expert } = Astro.props;
---
<article class="expert-card sv-card sv-card-lift">
  <a class="expert-card__portrait" href={`/experten/${expert.slug}/`} aria-label={`Profil von ${expert.name} öffnen`}>
    {expert.image ? <img src={expert.image} alt={`Portrait von ${expert.name}`} width="720" height="720" loading="lazy" /> : <span aria-hidden="true">{expert.name.split(' ').map((part)=>part[0]).join('').slice(0,2)}</span>}
  </a>
  <div class="expert-card__body">
    <p class="sv-eyebrow">{expert.group === 'backoffice' ? 'Backoffice' : expert.role}</p>
    <h2><a href={`/experten/${expert.slug}/`}>{expert.name}</a></h2>
    <strong>{expert.function}</strong>
    <p>{expert.shortProfile}</p>
    <ul aria-label={`Fachgebiete von ${expert.name}`}>{expert.expertise.slice(0,4).map((item)=><li>{item}</li>)}</ul>
    <div class="expert-card__links">
      <a class="expert-card__link" href={`/experten/${expert.slug}/`}>Profil und Beschreibung <span aria-hidden="true">→</span></a>
      {expert.linkedin && <a class="expert-card__linkedin" href={expert.linkedin} target="_blank" rel="noopener noreferrer" aria-label={`${expert.name} auf LinkedIn`}>LinkedIn <span aria-hidden="true">↗</span></a>}
    </div>
  </div>
</article>
<style>
.expert-card{display:flex;min-height:100%;flex-direction:column;overflow:hidden}.expert-card__portrait{display:block;aspect-ratio:4/3;overflow:hidden;background:linear-gradient(145deg,var(--sv-color-primary),var(--sv-color-ink));text-decoration:none}.expert-card__portrait img{width:100%;height:100%;object-fit:cover;object-position:center 24%;transition:transform var(--sv-transition)}.expert-card:hover .expert-card__portrait img{transform:scale(1.025)}.expert-card__portrait span{display:grid;width:100%;height:100%;place-items:center;color:white;font-size:3rem;font-weight:900}.expert-card__body{display:flex;flex:1;flex-direction:column;padding:1.35rem}.expert-card h2{margin:.15rem 0 .35rem;font-size:1.55rem}.expert-card h2 a{color:inherit;text-decoration:none}.expert-card strong{display:block;min-height:2.8em;margin-bottom:.75rem;line-height:1.4}.expert-card p:not(.sv-eyebrow){color:var(--sv-color-muted);font-size:.9rem}.expert-card ul{display:flex;flex-wrap:wrap;gap:.4rem;margin:1rem 0;padding:0;list-style:none}.expert-card li{padding:.3rem .55rem;border-radius:999px;background:var(--sv-color-surface-alt);color:var(--sv-color-muted);font-size:.72rem}.expert-card__links{display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:.8rem;margin-top:auto}.expert-card__link,.expert-card__linkedin{font-weight:850;text-decoration:none}.expert-card__linkedin{color:var(--sv-color-primary)}
</style>
