---
import type { ExpertProfile } from '../../types/platform';
interface Props { expert: ExpertProfile }
const { expert } = Astro.props;
const initials = expert.name.split(' ').map((part)=>part[0]).join('').slice(0,2);
---
<article class="expert-card sv-card">
  {expert.image ? <img src={expert.image} alt={`Porträt von ${expert.name}`} width="320" height="320" loading="lazy" decoding="async" /> : <div class="expert-card__avatar" aria-hidden="true">{initials}</div>}
  <div><p class="sv-eyebrow">{expert.role}</p><h2>{expert.name}</h2><strong>{expert.function}</strong><p>{expert.shortProfile}</p><ul>{expert.expertise.slice(0,4).map((item)=><li>{item}</li>)}</ul><a href={`/experten/${expert.slug}/`}>Expertenprofil <span aria-hidden="true">→</span></a></div>
</article>
<style>.expert-card{display:grid;grid-template-columns:minmax(8rem,.55fr) minmax(0,1.45fr);gap:1.5rem;padding:1.5rem}.expert-card img,.expert-card__avatar{width:100%;aspect-ratio:1;border-radius:1rem}.expert-card img{object-fit:cover}.expert-card__avatar{display:grid;place-items:center;background:linear-gradient(145deg,var(--sv-color-primary),var(--sv-color-ink));color:white;font-size:2rem;font-weight:900}.expert-card h2{font-size:1.8rem}.expert-card strong{display:block;margin-bottom:.7rem}.expert-card p:not(.sv-eyebrow),.expert-card li{color:var(--sv-color-muted)}.expert-card ul{display:flex;flex-wrap:wrap;gap:.4rem;margin:1rem 0;padding:0;list-style:none}.expert-card li{padding:.3rem .55rem;border-radius:999px;background:var(--sv-color-surface-alt);font-size:.76rem}.expert-card a{font-weight:850;text-decoration:none}@media(max-width:38rem){.expert-card{grid-template-columns:1fr}.expert-card img,.expert-card__avatar{width:7rem}}</style>
