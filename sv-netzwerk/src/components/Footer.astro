---
import { site } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="sv-container footer-grid">
    <div>
      <strong>{site.name}</strong>
      <p>{site.author.name}<br />{site.author.role}<br />{site.author.qualification}</p>
    </div>

    <nav aria-label="Fußnavigation">
      <a href="/impressum/">Impressum</a>
      <a href="/datenschutzerklaerung/">Datenschutz</a>
      <a href="/kontakt/">Kontakt</a>
    </nav>
  </div>

  <div class="sv-container copyright">
    © {year} {site.author.name}. Alle Rechte vorbehalten.
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--sv-space-8);
    padding-block: var(--sv-space-7) var(--sv-space-5);
    border-top: 1px solid var(--sv-color-border);
    background: var(--sv-color-surface);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(12rem, 1fr);
    gap: var(--sv-space-6);
  }

  p {
    margin-bottom: 0;
    color: var(--sv-color-muted);
  }

  nav {
    display: grid;
    align-content: start;
    gap: var(--sv-space-2);
  }

  .copyright {
    margin-top: var(--sv-space-6);
    padding-top: var(--sv-space-4);
    border-top: 1px solid var(--sv-color-border);
    color: var(--sv-color-muted);
    font-size: 0.85rem;
  }

  @media (max-width: 42rem) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
