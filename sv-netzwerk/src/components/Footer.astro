---
import { site } from '../data/site';
const year=new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-cta sv-container"><div><p class="sv-eyebrow">Direkter Einstieg</p><h2>Komplexer Schadenfall?<br/>Wir schaffen eine klare fachliche Linie.</h2></div><a class="sv-button sv-button-primary" href="/schaden-melden/">Schaden melden →</a></div>
  <div class="sv-container footer-grid">
    <div class="footer-brand"><span class="footer-symbol">SV</span><strong>SV-Netzwerk</strong><p>Technische Bewertung, strukturierte Regulierung und digitale Prozesse für komplexe Bau- und Versicherungsschäden.</p></div>
    <div><h3>Leistungen</h3><a href="/leistungen/">Übersicht</a><a href="/komplexschaeden/">Komplexschäden</a><a href="/grossschadenregulierung/">Großschadenregulierung</a><a href="/schaden-melden/">Schaden melden</a></div>
    <div><h3>Fachportal</h3><a href="/fachwissen/">Fachwissen</a><a href="/praxisfaelle/">Praxisfälle</a><a href="/downloads/">Downloads</a><a href="/svos/">SVOS</a></div>
    <div><h3>Kontakt</h3><p>{site.author.name}<br/>{site.address[0]}<br/>{site.address[1]}</p><a href={`mailto:${site.email}`}>{site.email}</a><a href={`tel:${site.phone.replace(/\D/g,'')}`}>{site.phone}</a></div>
  </div>
  <div class="sv-container footer-bottom"><span>© {year} {site.legalName}</span><nav aria-label="Rechtliches"><a href="/impressum/">Impressum</a><a href="/datenschutz/">Datenschutz</a><a href="/barrierefreiheit/">Barrierefreiheit</a></nav></div>
</footer>
<style>
.site-footer{background:#03111f;color:#c7d5df}.footer-cta{display:flex;align-items:center;justify-content:space-between;gap:2rem;padding-block:clamp(3rem,6vw,5rem);border-bottom:1px solid rgba(255,255,255,.12)}.footer-cta h2{max-width:50rem;color:white;font-size:clamp(2rem,4vw,3.6rem)}.footer-cta .sv-eyebrow{color:#ffc95f}.footer-grid{display:grid;grid-template-columns:1.7fr repeat(3,1fr);gap:clamp(2rem,5vw,5rem);padding-block:clamp(3rem,7vw,6rem)}.footer-symbol{display:grid;width:3.3rem;aspect-ratio:1;place-items:center;margin-bottom:1rem;clip-path:polygon(50% 0,94% 25%,94% 75%,50% 100%,6% 75%,6% 25%);background:var(--sv-color-accent);color:#111820;font-weight:950}.footer-brand>strong{display:block;color:white;font-size:1.25rem}.footer-brand p{max-width:28rem;margin-top:.8rem}.site-footer h3{color:white;font-family:var(--sv-font-sans);font-size:.88rem;letter-spacing:.1em;text-transform:uppercase}.site-footer a{display:block;margin:.55rem 0;color:#c7d5df;text-decoration:none}.site-footer a:hover{color:white}.site-footer p{color:#9fb2c0}.footer-bottom{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding-block:1.35rem;border-top:1px solid rgba(255,255,255,.12);font-size:.82rem}.footer-bottom nav{display:flex;flex-wrap:wrap;gap:1.2rem}
@media(max-width:58rem){.footer-cta{align-items:flex-start;flex-direction:column}.footer-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:36rem){.footer-grid{grid-template-columns:1fr}.footer-bottom{align-items:flex-start;flex-direction:column}}
</style>
