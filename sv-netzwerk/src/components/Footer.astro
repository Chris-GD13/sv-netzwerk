---
import { site } from '../data/site';
import LogoMark from './LogoMark.astro';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-accent" aria-hidden="true"></div>
  <div class="sv-container footer-lead">
    <div class="footer-brand">
      <span class="footer-brand__mark" aria-hidden="true"><LogoMark /></span>
      <div><strong>SV-Netzwerk</strong><small>Bau · Schaden · Regulierung</small></div>
    </div>
    <div class="footer-lead__copy">
      <p class="sv-eyebrow">Standort Aalen · bundesweit im Einsatz</p>
      <h2>Technische Klarheit für belastbare Schadenentscheidungen.</h2>
    </div>
    <a class="footer-contact" href="/kontakt/">Kontakt aufnehmen <span aria-hidden="true">→</span></a>
  </div>

  <div class="sv-container footer-directory">
    <div class="footer-column">
      <h3>Unternehmen</h3>
      <a href="/ueber-uns/">Über uns</a>
      <a href="/experten/">Experten</a>
      <a href="/netzwerk/">Netzwerk</a>
    </div>
    <div class="footer-column">
      <h3>Fachbereiche</h3>
      <a href="/leistungen/">Leistungen</a>
      <a href="/fachwissen/">Fachartikel</a>
      <a href="/schadenarten/">Schadenarten</a>
    </div>
    <div class="footer-column">
      <h3>Plattformen</h3>
      <a href="/gutachter-plattform/">Gutachter-Plattform</a>
      <a href="/svos/">SVOS</a>
    </div>
    <div class="footer-column">
      <h3>Service</h3>
      <a href="/kontakt/">Kontakt</a>
      <a href="/impressum/">Impressum</a>
      <a href="/datenschutzerklaerung/">Datenschutz</a>
    </div>
  </div>

  <div class="sv-container footer-proof">
    <p><strong>Zertifizierungshinweis</strong><br />Sachverständigenkompetenz nach DIN EN ISO/IEC 17024 im Netzwerk. Projektbezogene Zuständigkeiten und Qualifikationen werden im jeweiligen Auftrag ausgewiesen.</p>
    <p><strong>Standort</strong><br />Aalen, Baden-Württemberg · Koordination bundesweiter Einsätze</p>
  </div>

  <div class="sv-container footer-bottom">
    <span>© {year} {site.legalName}</span>
    <span>SVOS · Struktur für Schadenwissen und Zusammenarbeit</span>
  </div>
</footer>

<style>
  .site-footer{position:relative;overflow:hidden;padding-top:clamp(4rem,7vw,6.5rem);background:#051424;color:#d7e4ed}.footer-accent{position:absolute;top:-22rem;right:-14rem;width:42rem;aspect-ratio:1;border-radius:50%;background:radial-gradient(circle,rgba(20,107,149,.48),transparent 68%)}
  .footer-lead{position:relative;display:grid;grid-template-columns:auto minmax(18rem,1fr) auto;align-items:end;gap:clamp(2rem,5vw,5rem);padding-bottom:3rem;border-bottom:1px solid rgba(255,255,255,.14)}
  .footer-brand{display:flex;align-items:center;gap:.8rem}.footer-brand__mark{display:grid;width:2.8rem;place-items:center;color:var(--sv-color-accent)}.footer-brand strong,.footer-brand small{display:block}.footer-brand strong{color:#fff}.footer-brand small{margin-top:.2rem;color:#96adbc;font-size:.68rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase}
  .footer-lead__copy{max-width:46rem}.footer-lead .sv-eyebrow{color:#e9b75e}.footer-lead h2{margin:0;color:#fff;font-size:clamp(1.8rem,3.2vw,3.4rem)}.footer-contact{display:inline-flex;align-items:center;gap:.6rem;color:#fff;font-weight:900;text-decoration:none}.footer-contact span{color:var(--sv-color-accent)}
  .footer-directory{position:relative;display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:clamp(1.25rem,2.5vw,2.5rem);padding-block:3.5rem}.footer-column h3{margin-bottom:1rem;color:#fff;font-size:.78rem;letter-spacing:.08em;text-transform:uppercase}.footer-column a{display:block;margin:.55rem 0;color:#c5d4de;font-size:.84rem;text-decoration:none}.footer-column a:hover{color:#fff}.footer-column p{margin:.55rem 0;color:#93aab9;font-size:.82rem}
  .footer-proof{display:grid;grid-template-columns:1.4fr 1fr;gap:2rem;padding-block:1.6rem;border-top:1px solid rgba(255,255,255,.12);color:#91a8b7}.footer-proof p{margin:0;font-size:.78rem}.footer-proof strong{color:#dce7ed}
  .footer-bottom{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding-block:1.25rem;border-top:1px solid rgba(255,255,255,.12);color:#8fa6b5;font-size:.76rem}
  @media(max-width:72rem){.footer-lead{grid-template-columns:auto 1fr}.footer-contact{grid-column:2}.footer-directory{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:48rem){.footer-lead{grid-template-columns:1fr;align-items:start}.footer-contact{grid-column:auto}.footer-directory{grid-template-columns:repeat(2,1fr)}.footer-proof{grid-template-columns:1fr}.footer-bottom{align-items:flex-start;flex-direction:column}}
  @media(max-width:28rem){.footer-directory{grid-template-columns:1fr}}
</style>
