---
import { site } from '../data/site';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-glow"></div>
  <div class="sv-container footer-top">
    <div class="footer-brand"><div class="footer-logo"><span>SV</span></div><div><strong>SV-Netzwerk</strong><small>Kompetenzzentrum für Bau- und Versicherungsschäden</small></div></div>
    <a class="footer-contact" href="/kontakt/">Kontakt aufnehmen <span>→</span></a>
  </div>
  <div class="sv-container footer-grid">
    <div class="footer-intro"><h2>Belastbare Entscheidungen bei komplexen Schäden.</h2><p>Technische Bewertung, strukturierte Regulierung und vernetzte Fachkompetenz – verbunden durch SVOS.</p></div>
    <div><h3>Leistungen</h3><a href="/leistungen/">Übersicht</a><a href="/komplexschaeden/">Komplexschäden</a><a href="/grossschadenregulierung/">Großschadenregulierung</a><a href="/schaden-melden/">Schaden melden</a></div>
    <div><h3>Wissen & SVOS</h3><a href="/fachwissen/">Fachwissen</a><a href="/praxisfaelle/">Praxisfälle</a><a href="/downloads/">Downloads</a><a href="/svos/">SV Operating System</a></div>
    <div><h3>Kontakt</h3><p>{site.author.name}<br />{site.address[0]}<br />{site.address[1]}</p><a href={`mailto:${site.email}`}>{site.email}</a><a href={`tel:${site.phone.replace(/\D/g,'')}`}>{site.phone}</a></div>
  </div>
  <div class="sv-container footer-bottom"><span>© {year} {site.legalName}</span><nav aria-label="Rechtliches"><a href="/impressum/">Impressum</a><a href="/datenschutz/">Datenschutz</a><a href="/barrierefreiheit/">Barrierefreiheit</a></nav></div>
</footer>
<style>
.site-footer{position:relative;overflow:hidden;padding-top:4rem;background:#051424;color:#d7e4ed}.footer-glow{position:absolute;top:-18rem;left:20%;width:36rem;aspect-ratio:1;border-radius:50%;background:radial-gradient(circle,rgba(11,79,122,.45),transparent 68%)}.footer-top{position:relative;display:flex;align-items:center;justify-content:space-between;gap:2rem;padding-bottom:2rem;border-bottom:1px solid rgba(255,255,255,.13)}.footer-brand{display:flex;align-items:center;gap:.85rem}.footer-logo{display:grid;width:3rem;aspect-ratio:1;place-items:center;border-radius:.85rem;background:var(--sv-color-accent);color:#111;font-weight:900}.footer-brand strong,.footer-brand small{display:block}.footer-brand small{margin-top:.25rem;color:#9fb5c5;font-size:.72rem}.footer-contact{display:flex;align-items:center;gap:.7rem;color:white;font-weight:850;text-decoration:none}.footer-contact span{color:var(--sv-color-accent)}.footer-grid{position:relative;display:grid;grid-template-columns:2fr repeat(3,1fr);gap:clamp(2rem,5vw,5rem);padding-block:4rem}.footer-intro h2{max-width:34rem;color:white;font-size:clamp(1.8rem,3vw,3rem)}.footer-intro p{max-width:32rem;color:#aebfca}.site-footer h3{color:white;font-size:.95rem;letter-spacing:.05em}.site-footer a{display:block;margin:.55rem 0;color:#d7e4ed;text-decoration:none}.site-footer a:hover{color:white}.site-footer p{color:#9fb5c5}.footer-bottom{position:relative;display:flex;align-items:center;justify-content:space-between;gap:1rem;padding-block:1.35rem;border-top:1px solid rgba(255,255,255,.13);font-size:.84rem}.footer-bottom nav{display:flex;gap:1.25rem}@media(max-width:62rem){.footer-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:42rem){.footer-top,.footer-bottom{align-items:flex-start;flex-direction:column}.footer-grid{grid-template-columns:1fr}.footer-bottom nav{flex-wrap:wrap}}
</style>
