---
import {site} from '../data/site'; const year=new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-top"><div class="sv-container footer-call"><div><p>SV-NETZWERK · BAU & SCHADEN</p><h2>Komplexe Schäden brauchen klare Entscheidungen.</h2></div><a class="sv-button sv-button-primary" href="/schaden-melden/">Schaden melden <span aria-hidden="true">→</span></a></div></div>
  <div class="sv-container footer-grid">
    <div class="footer-brand"><span class="footer-mark">SV</span><p>Technische Bewertung, strukturierte Regulierung und vernetzte Fachkompetenz – nachvollziehbar dokumentiert.</p><small>{site.author.qualification}</small></div>
    <div><h3>Leistungen</h3><a href="/leistungen/">Sachverständigenleistungen</a><a href="/komplexschaeden/">Komplexschäden</a><a href="/grossschadenregulierung/">Großschadenregulierung</a><a href="/schaden-melden/">Schaden melden</a></div>
    <div><h3>Wissen & SVOS</h3><a href="/fachwissen/">Fachwissensbibliothek</a><a href="/praxisfaelle/">Praxisfälle</a><a href="/downloads/">Download Center</a><a href="/svos/">SV Operating System</a></div>
    <div><h3>Kontakt</h3><p>{site.author.name}<br />{site.address[0]}<br />{site.address[1]}</p><a href={`mailto:${site.email}`}>{site.email}</a><a href={`tel:${site.phone.replace(/\D/g,'')}`}>{site.phone}</a></div>
  </div>
  <div class="sv-container footer-bottom"><span>© {year} {site.legalName}</span><nav aria-label="Rechtliches"><a href="/impressum/">Impressum</a><a href="/datenschutz/">Datenschutz</a><a href="/barrierefreiheit/">Barrierefreiheit</a></nav></div>
</footer>
<style>
.site-footer{background:var(--sv-color-ink);color:#dce7ee}.footer-top{border-bottom:1px solid rgba(255,255,255,.14);background:#0a1c29}.footer-call{display:flex;align-items:center;justify-content:space-between;gap:2rem;padding-block:clamp(2.8rem,6vw,4.5rem)}.footer-call p{margin:0 0 .7rem;color:#f0c36d;font-size:.72rem;font-weight:900;letter-spacing:.15em}.footer-call h2{max-width:52rem;margin:0;color:white;font-size:clamp(2rem,4vw,3.7rem)}.footer-grid{display:grid;grid-template-columns:1.6fr repeat(3,1fr);gap:clamp(2rem,5vw,5rem);padding-block:clamp(4rem,8vw,6.5rem)}.footer-brand p{max-width:27rem;color:#b9cbd5}.footer-brand small{color:#8fa6b2}.footer-mark{display:grid;width:3.2rem;aspect-ratio:1;place-items:center;margin-bottom:1.5rem;border-radius:.75rem;background:var(--sv-color-primary);color:white;font-weight:900;box-shadow:inset -5px 0 var(--sv-color-accent)}.site-footer h3{color:white;font-family:var(--sv-font-sans);font-size:.82rem;letter-spacing:.11em;text-transform:uppercase}.site-footer a{display:block;margin:.6rem 0;color:#c5d5de;text-decoration:none}.site-footer a:hover{color:white}.site-footer p{color:#aebfca}.footer-bottom{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding-block:1.35rem;border-top:1px solid rgba(255,255,255,.14);font-size:.82rem}.footer-bottom nav{display:flex;gap:1.25rem}@media(max-width:64rem){.footer-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:44rem){.footer-call{align-items:flex-start;flex-direction:column}.footer-grid{grid-template-columns:1fr}.footer-bottom{align-items:flex-start;flex-direction:column}}
</style>
