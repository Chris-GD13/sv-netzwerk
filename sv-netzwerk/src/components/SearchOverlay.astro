<div class="search-overlay" data-search-overlay hidden><div class="search-panel" role="dialog" aria-modal="true" aria-labelledby="search-title"><div class="search-head"><div><p class="sv-eyebrow">SVOS Suche</p><h2 id="search-title">Fachwissen durchsuchen</h2></div><button type="button" data-search-close aria-label="Suche schließen">×</button></div><label for="site-search">Suchbegriff</label><input id="site-search" type="search" placeholder="z. B. Leitungswasser, Rückbau, Brandschaden" autocomplete="off" data-search-input/><div class="search-results" data-search-results aria-live="polite"><p>Geben Sie mindestens zwei Zeichen ein.</p></div><p class="search-hint"><a href="/suche/">Erweiterte Suche und Filter öffnen</a></p></div></div>
<script is:inline>
let searchData=[];const overlay=document.querySelector('[data-search-overlay]');const input=document.querySelector('[data-search-input]');const results=document.querySelector('[data-search-results]');
async function load(){if(!searchData.length){searchData=await fetch('/search-index.json').then(r=>r.json()).catch(()=>[]);}}
function render(q){const n=q.trim().toLowerCase();if(n.length<2){results.innerHTML='<p>Geben Sie mindestens zwei Zeichen ein.</p>';return;}const found=searchData.filter(i=>[i.title,i.description,i.category,...i.tags].join(' ').toLowerCase().includes(n)).slice(0,8);results.innerHTML=found.length?found.map(i=>`<a href="${i.href}"><strong>${i.title}</strong><span>${i.category} · ${i.description}</span></a>`).join(''):'<p>Keine passenden Inhalte gefunden.</p>';}
document.querySelectorAll('[data-search-open]').forEach(b=>b.addEventListener('click',async()=>{await load();overlay.hidden=false;document.body.classList.add('search-open');setTimeout(()=>input.focus(),0);}));document.querySelector('[data-search-close]')?.addEventListener('click',()=>{overlay.hidden=true;document.body.classList.remove('search-open');});overlay?.addEventListener('click',e=>{if(e.target===overlay){overlay.hidden=true;document.body.classList.remove('search-open');}});input?.addEventListener('input',e=>render(e.target.value));document.addEventListener('keydown',e=>{if(e.key==='Escape'&&!overlay.hidden){overlay.hidden=true;document.body.classList.remove('search-open');}});
</script>
<style>.search-overlay{position:fixed;inset:0;z-index:100;background:rgba(8,24,36,.68);backdrop-filter:blur(8px);padding:clamp(1rem,6vw,5rem)}.search-panel{max-width:52rem;margin:auto;padding:clamp(1.25rem,4vw,2.5rem);border-radius:var(--sv-radius-xl);background:white;box-shadow:var(--sv-shadow-lg)}.search-head{display:flex;align-items:flex-start;justify-content:space-between;gap:1rem}.search-head button{border:0;background:transparent;font-size:2rem;cursor:pointer}.search-panel label{display:block;margin-bottom:.4rem;font-weight:800}.search-panel input{width:100%;padding:1rem;border:2px solid var(--sv-color-line);border-radius:.8rem}.search-results{display:grid;gap:.5rem;margin-top:1rem;max-height:45vh;overflow:auto}.search-results :global(a){display:grid;padding:1rem;border:1px solid var(--sv-color-line);border-radius:.75rem;text-decoration:none}.search-results :global(span){color:var(--sv-color-muted);font-size:.9rem}.search-hint{margin:1rem 0 0}</style>
