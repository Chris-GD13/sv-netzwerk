---
interface Props { eyebrow?: string; title: string; text: string; primaryLabel?: string; primaryHref?: string; secondaryLabel?: string; secondaryHref?: string; compact?: boolean; }
const { eyebrow, title, text, primaryLabel, primaryHref, secondaryLabel, secondaryHref, compact=false }=Astro.props;
---
<section class:list={['hero',{compact}]}>
  <div class="hero-grid-overlay" aria-hidden="true"></div>
  <div class="sv-container hero-grid">
    <div class="hero-copy">
      {eyebrow&&<p class="hero-eyebrow"><span></span>{eyebrow}</p>}
      <h1>{title}</h1>
      <p class="hero-lead">{text}</p>
      <div class="sv-stack">{primaryLabel&&primaryHref&&<a class="sv-button sv-button-primary" href={primaryHref}>{primaryLabel}<span aria-hidden="true">→</span></a>}{secondaryLabel&&secondaryHref&&<a class="sv-button hero-outline" href={secondaryHref}>{secondaryLabel}</a>}</div>
      {!compact&&<div class="hero-trust"><span>DIN EN ISO/IEC 17024</span><span>Großschadenregulierung</span><span>Dokumentationsstark</span></div>}
    </div>
    <div class="hero-visual" aria-label="SV Operating System – Struktur, Prüfung und Entscheidung">
      <div class="visual-top"><span>SVOS / 01</span><b>OPERATING SYSTEM</b></div>
      <div class="visual-core"><strong>SV</strong><span>Struktur<br/>Prüfung<br/>Entscheidung</span></div>
      <div class="visual-flow"><i></i><span>Erfassen</span><i></i><span>Bewerten</span><i></i><span>Freigeben</span></div>
      <div class="visual-corner"></div>
    </div>
  </div>
</section>
<style>
.hero{position:relative;overflow:hidden;padding-block:clamp(5.5rem,10vw,9.5rem);background:#0e2637;color:white}.hero::before{position:absolute;inset:0;background:radial-gradient(circle at 85% 20%,rgba(37,115,157,.34),transparent 34%),linear-gradient(120deg,#0e2637 0%,#123d58 72%,#0e2637 100%);content:""}.hero-grid-overlay{position:absolute;inset:0;opacity:.17;background-image:linear-gradient(rgba(255,255,255,.12) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.12) 1px,transparent 1px);background-size:64px 64px;mask-image:linear-gradient(to right,transparent 0%,black 55%,black 100%)}.hero.compact{padding-block:4.5rem}.hero-grid{position:relative;display:grid;grid-template-columns:minmax(0,1.15fr) minmax(22rem,.85fr);align-items:center;gap:clamp(3rem,7vw,7rem)}.hero-copy{position:relative;z-index:2}.hero h1{max-width:58rem;margin-bottom:1.5rem;font-size:clamp(3rem,6.4vw,6.4rem);letter-spacing:-.055em}.hero-eyebrow{display:flex;align-items:center;gap:.75rem;margin:0 0 1.2rem;color:#f3c66c;font-size:.75rem;font-weight:900;letter-spacing:.16em;text-transform:uppercase}.hero-eyebrow span{width:2.2rem;height:2px;background:var(--sv-color-accent)}.hero-lead{max-width:46rem;margin-bottom:2rem;color:#d9e5eb;font-size:clamp(1.12rem,2vw,1.38rem)}.hero-outline{border-color:rgba(255,255,255,.48);color:white}.hero-outline:hover{background:white;color:var(--sv-color-primary)}.hero-trust{display:flex;flex-wrap:wrap;gap:.8rem 1.4rem;margin-top:2.25rem;color:#b9ccd7;font-size:.73rem;font-weight:800;letter-spacing:.07em;text-transform:uppercase}.hero-trust span{display:flex;align-items:center;gap:.5rem}.hero-trust span::before{width:.38rem;height:.38rem;border-radius:50%;background:var(--sv-color-accent);content:""}.hero-visual{position:relative;min-height:30rem;padding:2rem;border:1px solid rgba(255,255,255,.2);border-radius:1.6rem;background:rgba(255,255,255,.055);box-shadow:0 40px 100px rgba(0,0,0,.3);backdrop-filter:blur(10px)}.visual-top{display:flex;justify-content:space-between;color:#a9c0cc;font-size:.66rem;letter-spacing:.14em}.visual-core{display:flex;align-items:end;justify-content:space-between;margin-top:6rem}.visual-core strong{font-size:clamp(5rem,10vw,8rem);line-height:.8;letter-spacing:-.09em}.visual-core span{padding-left:1rem;border-left:3px solid var(--sv-color-accent);color:#dce7ed;font-size:.85rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase}.visual-flow{position:absolute;right:2rem;bottom:2rem;left:2rem;display:grid;grid-template-columns:1fr auto 1fr auto 1fr auto;align-items:center;gap:.6rem;color:#b9ccd7;font-size:.63rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase}.visual-flow i{height:1px;background:rgba(255,255,255,.3)}.visual-corner{position:absolute;top:-1px;right:-1px;width:6rem;height:6rem;border-top:3px solid var(--sv-color-accent);border-right:3px solid var(--sv-color-accent);border-radius:0 1.6rem 0 0}@media(max-width:58rem){.hero-grid{grid-template-columns:1fr}.hero-visual{min-height:21rem}.visual-core{margin-top:3.5rem}}@media(max-width:34rem){.hero-visual{display:none}}
</style>
