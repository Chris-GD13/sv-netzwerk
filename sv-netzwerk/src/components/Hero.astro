---
interface Props { eyebrow?: string; title: string; text: string; primaryLabel?: string; primaryHref?: string; secondaryLabel?: string; secondaryHref?: string; compact?: boolean; }
const { eyebrow, title, text, primaryLabel, primaryHref, secondaryLabel, secondaryHref, compact=false } = Astro.props;
---
<section class:list={['hero-v3',{compact}]}>
  <div class="hero-orb orb-one"></div><div class="hero-orb orb-two"></div>
  <div class="sv-container hero-layout">
    <div class="hero-copy">
      {eyebrow && <p class="hero-eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      <p class="hero-lead">{text}</p>
      <div class="hero-actions">
        {primaryLabel && primaryHref && <a class="sv-button sv-button-primary" href={primaryHref}>{primaryLabel}<span>→</span></a>}
        {secondaryLabel && secondaryHref && <a class="sv-button hero-secondary" href={secondaryHref}>{secondaryLabel}</a>}
      </div>
      <div class="hero-trust"><span>Technisch belastbar</span><span>Dokumentationsstark</span><span>Bundesweit vernetzt</span></div>
    </div>
    <div class="hero-system" aria-label="SVOS Prozessübersicht">
      <div class="system-head"><span>SV Operating System</span><b>LIVE</b></div>
      <div class="system-flow">
        <article><small>01</small><strong>Erfassen</strong><p>Schadenbild, Unterlagen und Beteiligte strukturiert zusammenführen.</p></article>
        <article><small>02</small><strong>Prüfen</strong><p>Kausalität, Umfang, Plausibilität und Kosten fachlich bewerten.</p></article>
        <article><small>03</small><strong>Entscheiden</strong><p>Freigaben, Reserven und Empfehlungen nachvollziehbar dokumentieren.</p></article>
      </div>
      <div class="system-status"><span><i></i> Prozessstandard aktiv</span><strong>SVOS 3.0</strong></div>
    </div>
  </div>
</section>
<style>
.hero-v3{position:relative;isolation:isolate;overflow:hidden;padding-block:clamp(5rem,10vw,9rem);background:linear-gradient(125deg,#06172a 0%,#0a3154 56%,#0c5b87 100%);color:white}.hero-v3.compact{padding-block:4rem}.hero-v3::before{position:absolute;inset:0;z-index:-1;background-image:linear-gradient(rgba(255,255,255,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.035) 1px,transparent 1px);background-size:44px 44px;content:"";mask-image:linear-gradient(to bottom,black,transparent)}.hero-orb{position:absolute;z-index:-1;border-radius:50%;filter:blur(8px)}.orb-one{top:-14rem;right:-8rem;width:34rem;aspect-ratio:1;background:radial-gradient(circle,rgba(255,157,18,.22),transparent 68%)}.orb-two{bottom:-16rem;left:25%;width:30rem;aspect-ratio:1;background:radial-gradient(circle,rgba(41,145,204,.32),transparent 68%)}.hero-layout{display:grid;grid-template-columns:minmax(0,1.1fr) minmax(22rem,.9fr);align-items:center;gap:clamp(3rem,7vw,7rem)}.hero-copy h1{max-width:57rem}.hero-eyebrow{display:inline-flex;margin:0 0 1.3rem;padding:.48rem .75rem;border:1px solid rgba(255,255,255,.18);border-radius:999px;background:rgba(255,255,255,.06);color:#ffc56f;font-size:.76rem;font-weight:900;letter-spacing:.13em;text-transform:uppercase}.hero-lead{max-width:47rem;margin-bottom:2rem;color:#d4e2ed;font-size:clamp(1.08rem,2vw,1.35rem)}.hero-actions{display:flex;flex-wrap:wrap;gap:.8rem}.hero-secondary{border-color:rgba(255,255,255,.38);background:rgba(255,255,255,.06);color:white}.hero-secondary:hover{background:white;color:var(--sv-color-primary)}.hero-trust{display:flex;flex-wrap:wrap;gap:1rem;margin-top:2rem;color:#b9cbd8;font-size:.82rem;font-weight:750}.hero-trust span{display:flex;align-items:center;gap:.45rem}.hero-trust span::before{width:.45rem;aspect-ratio:1;border-radius:50%;background:var(--sv-color-accent);content:""}.hero-system{padding:1rem;border:1px solid rgba(255,255,255,.16);border-radius:1.65rem;background:rgba(255,255,255,.08);box-shadow:0 34px 80px rgba(0,0,0,.28);backdrop-filter:blur(18px)}.system-head,.system-status{display:flex;align-items:center;justify-content:space-between}.system-head{padding:.35rem .35rem 1rem;color:#d8e6ef;font-size:.82rem;font-weight:850}.system-head b{padding:.28rem .5rem;border-radius:999px;background:rgba(52,204,133,.15);color:#75e5ad;font-size:.66rem;letter-spacing:.08em}.system-flow{display:grid;gap:.75rem}.system-flow article{position:relative;padding:1.15rem 1.15rem 1.15rem 4rem;border:1px solid rgba(255,255,255,.12);border-radius:1rem;background:rgba(255,255,255,.07)}.system-flow small{position:absolute;top:1.1rem;left:1.15rem;display:grid;width:2rem;aspect-ratio:1;place-items:center;border-radius:.6rem;background:rgba(255,157,18,.17);color:#ffc56f;font-weight:900}.system-flow strong{display:block;margin-bottom:.25rem;font-size:1.05rem}.system-flow p{margin:0;color:#c7d8e4;font-size:.84rem;line-height:1.5}.system-status{margin-top:.8rem;padding:.85rem .35rem .15rem;color:#afc4d3;font-size:.75rem}.system-status span{display:flex;align-items:center;gap:.45rem}.system-status i{width:.55rem;aspect-ratio:1;border-radius:50%;background:#4add92;box-shadow:0 0 0 5px rgba(74,221,146,.12)}.system-status strong{color:white}@media(max-width:62rem){.hero-layout{grid-template-columns:1fr}.hero-system{max-width:42rem}}@media(max-width:38rem){.hero-v3{padding-top:4rem}.hero-actions{display:grid}.hero-actions .sv-button{width:100%}.hero-trust{display:grid;gap:.55rem}}
</style>
