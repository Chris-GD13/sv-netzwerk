---
interface Props { eyebrow?:string; title:string; text:string; primaryLabel?:string; primaryHref?:string; secondaryLabel?:string; secondaryHref?:string; compact?:boolean; }
const {eyebrow,title,text,primaryLabel,primaryHref,secondaryLabel,secondaryHref,compact=false}=Astro.props;
---
<section class:list={['hero-v2',{compact}]}>
  <div class="hero-grid sv-container">
    <div class="hero-copy">
      {eyebrow&&<p class="hero-eyebrow"><span></span>{eyebrow}</p>}
      <h1>{title}</h1>
      <p class="hero-lead">{text}</p>
      <div class="sv-stack hero-actions">
        {primaryLabel&&primaryHref&&<a class="sv-button sv-button-primary" href={primaryHref}>{primaryLabel}<span aria-hidden="true">→</span></a>}
        {secondaryLabel&&secondaryHref&&<a class="sv-button hero-secondary" href={secondaryHref}>{secondaryLabel}</a>}
      </div>
      <div class="hero-trust"><span>DIN EN ISO/IEC 17024</span><span>Großschadenregulierung</span><span>Bundesweite Einsätze</span></div>
    </div>
    <div class="hero-visual" aria-label="SVOS Prozessdarstellung">
      <div class="visual-orbit orbit-a"></div><div class="visual-orbit orbit-b"></div>
      <div class="visual-core"><small>SVOS</small><strong>Struktur schafft Klarheit.</strong><p>Von der Schadenaufnahme bis zur dokumentierten Entscheidung.</p></div>
      <div class="process-card card-a"><b>01</b><span>Erfassen</span><small>Schadenbild und Unterlagen</small></div>
      <div class="process-card card-b"><b>02</b><span>Prüfen</span><small>Kausalität und Kosten</small></div>
      <div class="process-card card-c"><b>03</b><span>Entscheiden</span><small>Empfehlung und Freigabe</small></div>
    </div>
  </div>
</section>
<style>
.hero-v2{position:relative;overflow:hidden;padding-block:clamp(5rem,10vw,9rem);background:radial-gradient(circle at 78% 20%,rgba(27,103,160,.45),transparent 28%),linear-gradient(135deg,#041426 0%,#082d50 58%,#0e4e7e 100%);color:white}.hero-v2::before{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.025) 1px,transparent 1px);background-size:42px 42px;content:"";mask-image:linear-gradient(to bottom,black,transparent)}.hero-v2.compact{padding-block:4.5rem}.hero-grid{position:relative;display:grid;grid-template-columns:minmax(0,1.1fr) minmax(25rem,.9fr);align-items:center;gap:clamp(3rem,7vw,7rem)}.hero-copy{position:relative;z-index:2}.hero-eyebrow{display:flex;align-items:center;gap:.65rem;margin-bottom:1rem;color:#ffc95f;font-size:.78rem;font-weight:900;letter-spacing:.14em;text-transform:uppercase}.hero-eyebrow span{width:2.5rem;height:2px;background:var(--sv-color-accent)}.hero-v2 h1{max-width:58rem;margin-bottom:1.5rem}.hero-lead{max-width:47rem;margin-bottom:2rem;color:#dceaf4;font-size:clamp(1.12rem,2vw,1.38rem)}.hero-secondary{border-color:rgba(255,255,255,.4);background:rgba(255,255,255,.07);color:white}.hero-secondary:hover{background:white;color:var(--sv-color-primary)}.hero-trust{display:flex;flex-wrap:wrap;gap:.65rem 1.5rem;margin-top:2rem;color:#bcd0df;font-size:.78rem;font-weight:800}.hero-trust span::before{margin-right:.45rem;color:var(--sv-color-accent);content:"✓"}.hero-visual{position:relative;min-height:34rem}.visual-core{position:absolute;inset:50% auto auto 50%;z-index:3;width:17rem;transform:translate(-50%,-50%);padding:2rem;border:1px solid rgba(255,255,255,.2);border-radius:1.5rem;background:rgba(255,255,255,.1);box-shadow:0 30px 90px rgba(0,0,0,.28);backdrop-filter:blur(16px)}.visual-core small{color:#ffc95f;font-weight:900;letter-spacing:.15em}.visual-core strong{display:block;margin:.65rem 0;font-size:1.55rem;line-height:1.15}.visual-core p{margin:0;color:#cbddea;font-size:.88rem}.visual-orbit{position:absolute;inset:50% auto auto 50%;border:1px solid rgba(255,255,255,.14);border-radius:50%;transform:translate(-50%,-50%)}.orbit-a{width:27rem;aspect-ratio:1}.orbit-b{width:20rem;aspect-ratio:1}.process-card{position:absolute;z-index:4;display:grid;min-width:11rem;padding:1rem;border:1px solid rgba(255,255,255,.2);border-radius:1rem;background:rgba(4,20,38,.72);box-shadow:var(--sv-shadow-md);backdrop-filter:blur(12px)}.process-card b{color:var(--sv-color-accent);font-size:.72rem}.process-card span{font-weight:900}.process-card small{color:#b9cedd}.card-a{top:8%;left:0}.card-b{top:18%;right:0}.card-c{right:6%;bottom:8%}
@media(max-width:62rem){.hero-grid{grid-template-columns:1fr}.hero-visual{min-height:25rem;max-width:38rem}.card-a{left:4%}.card-b{right:4%}.card-c{right:12%;bottom:2%}}
@media(max-width:38rem){.hero-v2{padding-block:4.5rem}.hero-actions{display:grid}.hero-actions .sv-button{width:100%}.hero-trust{display:grid}.hero-visual{min-height:23rem}.visual-core{width:14rem;padding:1.4rem}.process-card{min-width:9rem;padding:.75rem;font-size:.85rem}.card-a{top:2%;left:0}.card-b{top:4%;right:0}.card-c{right:2%;bottom:0}.orbit-a{width:22rem}.orbit-b{width:16rem}}
</style>
