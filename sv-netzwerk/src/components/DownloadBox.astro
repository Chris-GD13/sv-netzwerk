---
interface Props {
  title: string;
  description?: string;
  href: string;
  fileType?: string;
  fileSize?: string;
}

const { title, description, href, fileType, fileSize } = Astro.props;
const meta = [fileType, fileSize].filter(Boolean).join(' · ');
---

<aside class="download sv-card">
  <div>
    <strong>{title}</strong>
    {description && <p>{description}</p>}
    {meta && <small>{meta}</small>}
  </div>
  <a href={href} download>Herunterladen</a>
</aside>

<style>
  .download {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sv-space-5);
    padding: var(--sv-space-5);
  }

  p {
    margin: var(--sv-space-2) 0 0;
    color: var(--sv-color-muted);
  }

  small {
    color: var(--sv-color-muted);
  }

  a {
    flex: none;
    font-weight: 650;
  }
</style>
