---
const services = [
  { number: '01', title: 'Sachverständigenleistungen', text: 'Belastbare Feststellungen, technische Bewertungen und klare Empfehlungen für Auftraggeber und Versicherer.', href: '/leistungen/', icon: 'M5 19V5h14v14H5Zm4-9h6M9 14h4' },
  { number: '02', title: 'Komplexschäden', text: 'Interdisziplinäre Ursachenklärung und strukturierte Bearbeitung anspruchsvoller Schadenbilder.', href: '/komplexschaeden/', icon: 'M12 3 4 7v10l8 4 8-4V7l-8-4Zm0 0v18M4 7l8 4 8-4' },
  { number: '03', title: 'Großschadenregulierung', text: 'Nachvollziehbare Steuerung von der Erstaufnahme über die Reserve bis zur Schlusserklärung.', href: '/grossschadenregulierung/', icon: 'M4 19V9l8-5 8 5v10H4Zm4 0v-5h8v5' },
  { number: '04', title: 'Gutachter-Plattform', text: 'Digitale Akten, Wissenszugriff und standardisierte Zusammenarbeit für moderne Gutachtenprozesse.', href: '/gutachter-plattform/', icon: 'M4 5h16v12H4V5Zm5 16h6M12 17v4' },
];
---
<section class="v4-section v4-services" id="leistungen">
  <div class="v4-shell"><div class="v4-section-head"><div><p class="v4-kicker"><span></span>Was wir leisten</p><h2>Ein Netzwerk.<br/>Klare Verantwortung.</h2></div><p>Wir verbinden spezialisierte Fachkompetenz mit einem durchgängigen Arbeitsmodell. So entstehen Entscheidungen, die fachlich tragen und praktisch umsetzbar sind.</p></div>
  <div class="v4-services__grid">{services.map((service) => <a href={service.href}><div class="v4-services__top"><span>{service.number}</span><svg viewBox="0 0 24 24" aria-hidden="true"><path d={service.icon}/></svg></div><h3>{service.title}</h3><p>{service.text}</p><b>Mehr erfahren <span>→</span></b></a>)}</div></div>
</section>
