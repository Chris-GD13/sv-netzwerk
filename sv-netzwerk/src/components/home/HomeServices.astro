---
const services = [
  { number: '01', title: 'Sachverständigenleistungen', text: 'Belastbare Feststellungen, technische Bewertungen und klare Empfehlungen für Auftraggeber und Versicherer.', href: '/leistungen/#sachverstaendigenleistungen', icon: 'M5 19V5h14v14H5Zm4-9h6M9 14h4' },
  { number: '02', title: 'Kumulschadenmanagement', text: 'Strukturierte Steuerung zahlreicher Schäden aus einem gemeinsamen Unwetterereignis – mit priorisierter Erstaufnahme, einheitlicher Dokumentation und fortlaufender Statusübersicht.', href: '/leistungen/#kumulschadenmanagement', icon: 'M4 17h16M6 13h12M9 9h6M12 4v5m-5 8v3m10-3v3' },
  { number: '03', title: 'Leistungen für Versicherer', text: 'Prüffähige Entscheidungsgrundlagen, KVA- und Rechnungsprüfung sowie klare Kommunikation zu offenen Punkten, Reserven und Handlungsbedarf.', href: '/leistungen/#versicherer', icon: 'M12 3 4 7v4c0 4.5 3.2 8.4 8 9.6 4.8-1.2 8-5.1 8-9.6V10l-8-7Zm-3 9 2 2 4-4' },
  { number: '04', title: 'Großschaden- und Komplexschadenregulierung', text: 'Nachvollziehbare Steuerung umfangreicher und komplexer Schadenfälle – von der Erstaufnahme über die Reservenbildung bis zur dokumentierten Schlusserklärung.', href: '/leistungen/#grossschaden-und-komplexschadenregulierung', icon: 'M4 19V9l8-5 8 5v10H4Zm4 0v-5h8v5' },
];
---
<section class="v4-section v4-services" id="leistungen">
  <div class="v4-shell"><div class="v4-section-head"><div><p class="v4-kicker"><span></span>Was wir leisten</p><h2>Ein Netzwerk.<br/>Klare Verantwortung.</h2></div><p>Wir verbinden spezialisierte Fachkompetenz mit einem durchgängigen Arbeitsmodell. So entstehen Entscheidungen, die fachlich tragen und praktisch umsetzbar sind.</p></div>
  <div class="v4-services__grid">{services.map((service) => <a href={service.href}><div class="v4-services__top"><span>{service.number}</span><svg viewBox="0 0 24 24" aria-hidden="true"><path d={service.icon}/></svg></div><h3>{service.title}</h3><p>{service.text}</p><b>Mehr erfahren <span>→</span></b></a>)}</div></div>
</section>
