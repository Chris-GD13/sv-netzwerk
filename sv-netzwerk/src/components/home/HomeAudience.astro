---
const entries = [
  {
    title: 'Für Versicherer',
    text: 'Schäden effizient steuern und qualifizierte Sachverständige bundesweit beauftragen.',
    href: '/grossschadenregulierung/#grossschaden-formular',
    cta: 'Großschaden melden',
  },
  {
    title: 'Für Regulierer',
    text: 'Kumul- und Unwetterschäden zentral priorisieren und direkt beauftragen.',
    href: '/leistungen/kumulschadenmanagement/#kumulschaden-formular',
    cta: 'Kumulschaden melden',
  },
  {
    title: 'Für Geschädigte',
    text: 'Schnelle Hilfe bei Gebäude- und Großschäden.',
    href: '/schaden-melden/',
    cta: 'Schaden melden',
  },
];
---

<section class="v4-section v4-audience" aria-labelledby="zielgruppen">
  <div class="v4-shell">
    <div class="v4-section-head">
      <div>
        <p class="v4-kicker"><span></span>Weitere Einstiege</p>
        <h2 id="zielgruppen">Schneller Zugang nach Zielgruppe</h2>
      </div>
    </div>
    <div class="v4-audience__grid">
      {entries.map((entry, index) => (
        <article class="v4-audience__card">
          <small>{`0${index + 1}`}</small>
          <h3>{entry.title}</h3>
          <p>{entry.text}</p>
          <a href={entry.href}>{entry.cta} <span aria-hidden="true">→</span></a>
        </article>
      ))}
    </div>
  </div>
</section>
