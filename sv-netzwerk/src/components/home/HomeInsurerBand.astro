---
import { insurerClients } from '../../data/insurer-clients';
---

<section class="v4-insurer-band" aria-labelledby="versicherer-band-title">
  <div class="v4-shell">
    <div class="v4-insurer-band__head">
      <p class="v4-kicker"><span></span>Versicherer-Netzwerk</p>
      <h2 id="versicherer-band-title">Für diese Versicherer sind wir tätig</h2>
      <a href="/versicherer/fuer-wen-wir-taetig-sind/">Zur Übersicht <span aria-hidden="true">→</span></a>
    </div>
    <div class="v4-insurer-band__logos">
      {insurerClients.map((insurer) => (
        <span class="v4-insurer-band__chip">
          {insurer.logo ? (
            <img src={insurer.logo} alt={insurer.logoAlt ?? `Logo ${insurer.name}`} loading="lazy" />
          ) : (
            insurer.name
          )}
        </span>
      ))}
    </div>
  </div>
</section>

<style>
  .v4-insurer-band{padding:1rem 0 0}
  .v4-insurer-band__head{display:flex;align-items:end;justify-content:space-between;gap:1rem}
  .v4-insurer-band__head h2{margin:.25rem 0 0;font-size:clamp(1.1rem,1.8vw,1.45rem)}
  .v4-insurer-band__head a{font-weight:850;text-decoration:none;white-space:nowrap}
  .v4-insurer-band__logos{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:.55rem;margin-top:.95rem}
  .v4-insurer-band__chip{display:grid;place-items:center;min-height:3rem;padding:.65rem .8rem;border:1px solid #c9d7df;border-radius:.65rem;background:rgba(255,255,255,.86);font-size:.82rem;font-weight:850;text-align:center}
  .v4-insurer-band__chip img{max-width:100%;max-height:1.75rem;width:auto;height:auto;object-fit:contain}
  @media(max-width:70rem){.v4-insurer-band__logos{grid-template-columns:repeat(4,minmax(0,1fr))}}
  @media(max-width:54rem){.v4-insurer-band__head{align-items:start;flex-direction:column}.v4-insurer-band__logos{grid-template-columns:repeat(2,minmax(0,1fr))}}
</style>
