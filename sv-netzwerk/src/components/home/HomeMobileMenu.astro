---
import type { HomeNavItem } from './HomeHeader.astro';
interface Props { items: HomeNavItem[]; currentPath: string }
const { items, currentPath } = Astro.props;
const active = (href: string) => href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<div class="v4-mobile-backdrop" data-v4-menu-backdrop hidden></div>
<aside class="v4-mobile" id="v4-mobile-menu" aria-hidden="true" data-v4-mobile-menu>
  <div class="v4-mobile__head"><span>Navigation</span><button type="button" aria-label="Menü schließen" data-v4-menu-close><svg viewBox="0 0 24 24"><path d="M5 5l14 14M19 5 5 19"/></svg></button></div>
  <nav aria-label="Mobile Hauptnavigation">
    <a class:list={{ 'is-active': currentPath === '/' }} href="/">Startseite</a>
    {items.map((item) => item.children ? (
      <details open={active(item.href)}><summary>{item.label}<span>+</span></summary><div><a href={item.href}>{item.label} – Übersicht</a>{item.children.map((child) => <a href={child.href}>{child.label}</a>)}</div></details>
    ) : <a class:list={{ 'is-active': active(item.href) }} href={item.href}>{item.label}</a>)}
  </nav>
  <div class="v4-mobile__foot"><a href="/schaden-melden/">Schaden melden <span>→</span></a><p>Direkter Kontakt<br/><strong>07367 / 393 97 83</strong></p></div>
</aside>

<script is:inline>
  const v4Menu = document.querySelector('[data-v4-mobile-menu]');
  const v4Backdrop = document.querySelector('[data-v4-menu-backdrop]');
  const v4Open = document.querySelector('[data-v4-menu-open]');
  const v4Close = document.querySelector('[data-v4-menu-close]');
  let v4LastFocus = null;
  const toggleV4Menu = (open) => {
    if (!v4Menu || !v4Backdrop || !v4Open) return;
    if (open) v4LastFocus = document.activeElement;
    v4Menu.setAttribute('aria-hidden', String(!open)); v4Open.setAttribute('aria-expanded', String(open));
    v4Menu.classList.toggle('is-open', open); v4Backdrop.hidden = !open; document.documentElement.classList.toggle('v4-menu-open', open);
    requestAnimationFrame(() => v4Backdrop.classList.toggle('is-open', open));
    if (open) v4Close?.focus(); else if (v4LastFocus instanceof HTMLElement) v4LastFocus.focus();
  };
  v4Open?.addEventListener('click', () => toggleV4Menu(true)); v4Close?.addEventListener('click', () => toggleV4Menu(false)); v4Backdrop?.addEventListener('click', () => toggleV4Menu(false));
  v4Menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => toggleV4Menu(false)));
  document.addEventListener('keydown', (event) => { if (event.key === 'Escape') toggleV4Menu(false); });
</script>
