---
import type { TeamCardProps } from '../types/components';
const props = Astro.props as TeamCardProps;
const { name, role, qualification, href, image, imageAlt = name } = props;
const initials = props.initials ?? name.split(' ').map((part)=>part[0]).join('').slice(0,2);
---
<article class="team-card sv-card">
  {image ? <img class="avatar-image" src={image} alt={imageAlt} loading="lazy" decoding="async" /> : <div class="avatar" aria-hidden="true">{initials}</div>}
  <div class="team-content"><h3>{name}</h3><p>{role}</p>{qualification&&<small>{qualification}</small>}{href&&<a href={href}>Profil ansehen <span aria-hidden="true">→</span></a>}</div>
</article>
<style>
  .team-card{display:grid;grid-template-columns:5rem 1fr;gap:1.25rem;padding:1.5rem}.avatar,.avatar-image{width:5rem;aspect-ratio:1;border-radius:1rem}.avatar{display:grid;place-items:center;background:linear-gradient(145deg,var(--sv-color-primary),var(--sv-color-ink));color:white;font-size:1.4rem;font-weight:900}.avatar-image{object-fit:cover}.team-card p{margin-bottom:.25rem;color:var(--sv-color-muted)}small{display:block;margin-bottom:.75rem;color:var(--sv-color-muted)}a{font-weight:800;text-decoration:none}@media(max-width:34rem){.team-card{grid-template-columns:1fr}.avatar,.avatar-image{width:4.5rem}}
</style>
