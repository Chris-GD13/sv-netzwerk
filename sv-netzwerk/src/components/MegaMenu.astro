---
import type { NavItem } from '../data/navigation';

interface Props { item: NavItem; id: string; currentPath: string }
const { item, id, currentPath } = Astro.props;
const active = (href: string) => {
  if (href.includes('#')) return false;
  return href === '/' ? currentPath === '/' : currentPath.startsWith(href);
};
---

<div class="mega-menu" id={id} data-mega-menu hidden>
  <div class="mega-menu__overview">
    <span>{item.label}</span>
    <h2>{item.description}</h2>
    <a href={item.href}>Bereich entdecken <b aria-hidden="true">→</b></a>
  </div>
  <div class="mega-menu__links">
    {item.children?.map((child, index) => (
      <a class:list={{ 'is-active': active(child.href) }} href={child.href} aria-current={active(child.href) ? 'page' : undefined}>
        <span class="mega-menu__index" aria-hidden="true">0{index + 1}</span>
        <span><strong>{child.label}</strong><small>{child.description}</small></span>
        <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M6 14 14 6m-7 0h7v7" /></svg>
      </a>
    ))}
  </div>
</div>
