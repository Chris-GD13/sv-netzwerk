---
import type { PortalRoute } from '../../lib/internal/types';

interface Props {
  route: PortalRoute;
  recordId?: string;
}

const { route, recordId = '' } = Astro.props;
---

<section class="intern-shell sv-section">
  <div class="sv-container">
    <div class="intern-shell__surface">
      <div data-internal-app data-route={route} data-record-id={recordId}>
        <div class="intern-loading" aria-live="polite">
          <p>Interner Bereich wird geladen…</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { mountInternalPortal } from '../../lib/internal/client';

  const roots = document.querySelectorAll('[data-internal-app]');
  roots.forEach((root) => {
    if (root instanceof HTMLElement) mountInternalPortal(root);
  });
</script>
