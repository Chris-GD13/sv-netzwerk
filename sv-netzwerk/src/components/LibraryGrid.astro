---
import ArticleCard from './ArticleCard.astro';
import type { LibraryItem } from '../data/library';
interface Props { items: LibraryItem[]; }
const { items } = Astro.props;
---
<div class="library-grid">
  {items.map((item) => (
    <div data-library-card data-search={`${item.title} ${item.description} ${item.category} ${item.tags.join(' ')}`}>
      <ArticleCard {...item} />
    </div>
  ))}
</div>
<style>.library-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:1.25rem}.library-grid>[hidden]{display:none}@media(max-width:64rem){.library-grid{grid-template-columns:repeat(2,minmax(0,1fr))}}@media(max-width:42rem){.library-grid{grid-template-columns:1fr}}</style>
