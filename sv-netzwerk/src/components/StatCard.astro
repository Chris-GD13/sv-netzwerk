---
import type { StatCardProps } from '../types/components';
const { value, label, text, suffix } = Astro.props as StatCardProps;
---
<div class="stat-card" role="group" aria-label={`${value}${suffix ?? ''} ${label}`}>
  <strong>{value}{suffix && <span class="suffix">{suffix}</span>}</strong><span class="label">{label}</span>{text&&<p>{text}</p>}
</div>
<style>.stat-card{padding:1.5rem;border-left:3px solid var(--sv-color-accent)}strong,.label{display:block}strong{font-family:var(--sv-font-display);font-size:clamp(2rem,5vw,3.8rem);line-height:1;color:var(--sv-color-primary)}.suffix{font-size:.48em}.label{margin-top:.5rem;font-weight:850}p{margin:.5rem 0 0;color:var(--sv-color-muted)}</style>
