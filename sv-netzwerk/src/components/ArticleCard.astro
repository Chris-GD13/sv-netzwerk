---
import { formatDate, slugify, type LibraryItem } from '../data/library';

interface Props extends LibraryItem {}

const { category, title, description, href, date, tags, type, featured = false } = Astro.props;
const typeLabel = type === 'video' ? 'Video' : 'Fachbeitrag';
---
<article class:list={['article', 'sv-card', 'sv-card-lift', { featured }]}>
  <div class="article-meta">
    <a href={`/fachwissen/kategorie/${slugify(category)}/`}>{category}</a>
    <span>{typeLabel}</span>
  </div>
  <h2><a href={href}>{title}</a></h2>
  <p>{description}</p>
  <ul class="tag-list" aria-label="Schlagwörter">
    {tags.map((tag) => <li><a href={`/fachwissen/tag/${slugify(tag)}/`}>#{tag}</a></li>)}
  </ul>
  <div class="article-footer">
    <time datetime={date}>{formatDate(date)}</time>
    <a class="read" href={href}>{type === 'video' ? 'Video ansehen' : 'Beitrag lesen'} <span aria-hidden="true">→</span></a>
  </div>
</article>

<style>
  .article{display:flex;min-height:100%;flex-direction:column;padding:1.75rem}
  .article.featured{border-color:color-mix(in srgb,var(--sv-color-accent) 45%,var(--sv-color-border));box-shadow:var(--sv-shadow-md)}
  .article-meta{display:flex;justify-content:space-between;gap:1rem;margin-bottom:1.25rem;color:var(--sv-color-muted);font-size:.76rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase}
  .article-meta a{color:var(--sv-color-primary);text-decoration:none}
  .article h2{font-size:clamp(1.2rem,2vw,1.5rem);line-height:1.25}
  .article h2 a{color:var(--sv-color-ink);text-decoration:none}
  .article p{color:var(--sv-color-muted)}
  .tag-list{display:flex;flex-wrap:wrap;gap:.45rem;margin:1rem 0 1.5rem;padding:0;list-style:none}
  .tag-list a{display:inline-flex;padding:.32rem .58rem;border-radius:999px;background:var(--sv-color-surface-alt);color:var(--sv-color-muted);font-size:.78rem;text-decoration:none}
  .article-footer{display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-top:auto;padding-top:1rem;border-top:1px solid var(--sv-color-border)}
  .article-footer time{color:var(--sv-color-muted);font-size:.82rem}
  .read{font-weight:750;text-decoration:none}
</style>
