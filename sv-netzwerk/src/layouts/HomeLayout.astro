---
import SEO from '../components/SEO.astro';
import PerformanceHints from '../components/PerformanceHints.astro';
import AccessibilityStatus from '../components/AccessibilityStatus.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SearchOverlay from '../components/SearchOverlay.astro';
import '../styles/global.css';
import '../styles/header.css';
import '../styles/navigation.css';
import '../styles/home-v4.css';

interface Props { title: string; description: string }
const props = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a2238" />
    <meta name="color-scheme" content="light" />
    <PerformanceHints />
    <SEO {...props} />
  </head>
  <body class="home-v4">
    <a class="skip-link" href="#main-content">Zum Inhalt springen</a>
    <AccessibilityStatus />
    <Header />
    <main id="main-content" tabindex="-1"><slot /></main>
    <Footer />
    <SearchOverlay />
  </body>
</html>

<style is:global>
  .skip-link{position:fixed;top:.65rem;left:.65rem;z-index:220;transform:translateY(-160%);padding:.7rem 1rem;border-radius:.65rem;background:#fff;color:var(--sv-color-ink);font-weight:900;box-shadow:var(--sv-shadow-md)}
  .skip-link:focus{transform:none}
  .search-open{overflow:hidden}
  #main-content:focus{outline:none}
</style>
