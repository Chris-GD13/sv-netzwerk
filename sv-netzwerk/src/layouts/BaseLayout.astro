---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SearchOverlay from '../components/SearchOverlay.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PerformanceHints from '../components/PerformanceHints.astro';
import AccessibilityStatus from '../components/AccessibilityStatus.astro';
import { site } from '../data/site';
import '../styles/global.css';
import '../styles/header.css';
import '../styles/navigation.css';

interface BreadcrumbItem { label: string; href?: string }
interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  preloadImage?: string;
  breadcrumbs?: BreadcrumbItem[];
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const props = Astro.props;
const organizationId = `${site.url.replace(/\/$/, '')}#organization`;
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': organizationId,
  name: site.legalName,
  url: site.url,
  email: site.email,
  telephone: site.phone,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address[0],
    postalCode: '73432',
    addressLocality: 'Aalen',
    addressCountry: 'DE',
  },
};

const breadcrumbItems = (props.breadcrumbs ?? []).map((item, index) => {
  const node: Record<string, unknown> = {
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
  };
  if (item.href) node.item = new URL(item.href, site.url).toString();
  return node;
});

const breadcrumbSchema = breadcrumbItems.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbItems,
    }
  : null;

const pageSchemas = Array.isArray(props.structuredData)
  ? props.structuredData
  : props.structuredData
    ? [props.structuredData]
    : [];

const schemas = [
  organizationSchema,
  ...(breadcrumbSchema ? [breadcrumbSchema] : []),
  ...pageSchemas,
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#071a2e" />
    <meta name="color-scheme" content="light" />
    <PerformanceHints preloadImage={props.preloadImage} />
    <SEO {...props} />
    {schemas.map((schema) => <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />)}
  </head>
  <body>
    <a class="skip-link" href="#main-content">Zum Inhalt springen</a>
    <AccessibilityStatus />
    <Header />
    <main id="main-content" tabindex="-1">
      {props.breadcrumbs && (
        <div class="sv-container breadcrumb-wrap"><Breadcrumbs items={props.breadcrumbs} /></div>
      )}
      <slot />
    </main>
    <Footer />
    <SearchOverlay />
  </body>
</html>

<style is:global>
  .skip-link{position:fixed;top:.65rem;left:.65rem;z-index:200;transform:translateY(-160%);padding:.7rem 1rem;border-radius:.65rem;background:#fff;color:var(--sv-color-ink);font-weight:900;box-shadow:var(--sv-shadow-md)}
  .skip-link:focus{transform:none}
  .search-open{overflow:hidden}
  .breadcrumb-wrap{padding-top:var(--sv-space-4)}
  #main-content:focus{outline:none}
</style>
