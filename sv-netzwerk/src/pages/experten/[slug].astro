---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import CallToAction from '../../components/CallToAction.astro';
import { experts } from '../../data/experts';
import type { ExpertProfile } from '../../types/platform';
export function getStaticPaths(){return experts.filter((expert)=>expert.status==='active').map((expert)=>({params:{slug:expert.slug},props:{expert}}));}
interface Props { expert: ExpertProfile }
const { expert } = Astro.props;
const personSchema={'@context':'https://schema.org','@type':'Person',name:expert.name,jobTitle:expert.function,email:expert.contact.email,knowsAbout:expert.expertise,sameAs:expert.linkedin?[expert.linkedin]:undefined,worksFor:{'@type':'Organization',name:'SV-Netzwerk'}};
---
<BaseLayout title={`${expert.name} | Experten`} description={expert.shortProfile} breadcrumbs={[{label:'Start',href:'/'},{label:'Experten',href:'/experten/'},{label:expert.name}]}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <Hero compact eyebrow={expert.group === 'backoffice' ? 'Backoffice' : expert.role} title={expert.name} text={expert.shortProfile} primaryLabel="Kontakt aufnehmen" primaryHref={`mailto:${expert.contact.email}`} secondaryLabel="Alle Experten" secondaryHref="/experten/" />
  <section class="sv-section profile-intro"><div class="sv-container profile-intro__grid">{expert.image&&<img src={expert.image} alt={`Portrait von ${expert.name}`} width="720" height="720"/>}<div><p class="sv-eyebrow">{expert.group === 'backoffice' ? 'Organisation im Netzwerk' : 'Expertenprofil'}</p><h2>{expert.function}</h2><p class="sv-lead">{expert.shortProfile}</p>{expert.contact.phone&&<p><strong>Telefon:</strong> <a href={`tel:${expert.contact.phone.replace(/[^+\d]/g,'')}`}>{expert.contact.phone}</a></p>}{expert.linkedin&&<p><a class="linkedin-link" href={expert.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn-Profil von {expert.name} <span aria-hidden="true">↗</span></a></p>}</div></div></section>
  <section class="sv-section"><div class="sv-container"><SectionHeader eyebrow="Fachgebiete" title="Aufgaben und Schwerpunkte"/><div class="sv-grid sv-grid-3">{expert.expertise.map((item,index)=><FeatureCard index={String(index+1).padStart(2,'0')} title={item} text="Fachliche Bearbeitung mit dokumentierter Grundlage, Aussagegrenze und Verantwortung."/>)}</div></div></section>
  <section class="sv-section sv-section-alt"><div class="sv-container profile-grid"><div><h2>Regionen</h2><ul>{expert.regions.map((item)=><li>{item}</li>)}</ul></div><div><h2>Qualifikationen</h2><ul>{expert.qualifications.map((item)=><li>{item}</li>)}</ul></div><div><h2>Zertifizierungen</h2>{expert.certifications.length?<ul>{expert.certifications.map((item)=><li>{item}</li>)}</ul>:<p>Für diese Funktion sind keine personenbezogenen Zertifizierungen ausgewiesen.</p>}</div></div></section>
  <section class="sv-section"><div class="sv-container"><SectionHeader eyebrow="Verknüpfte Arbeit" title="Publikationen, Praxisfälle und Fachartikel"/><nav class="work-links" aria-label="Verknüpfte Experteninhalte"><a href="/fachwissen/">Fachartikel</a><a href="/praxisfaelle/">Praxisfälle</a><a href="/downloads/">Downloads und Arbeitshilfen</a></nav></div></section>
  <CallToAction title={`${expert.name} als Ansprechpartner anfragen`} text="Bitte Schadenart, Objekt, Region und konkrete Fragestellung angeben." href="/kontakt/" label="Anfrage stellen" />
</BaseLayout>
<style>.profile-intro{padding-top:0}.profile-intro__grid{display:grid;grid-template-columns:minmax(15rem,.65fr) minmax(0,1.35fr);align-items:center;gap:clamp(2rem,7vw,6rem)}.profile-intro img{width:100%;max-height:34rem;aspect-ratio:4/3;border-radius:var(--sv-radius-xl);box-shadow:var(--sv-shadow-lg);object-fit:cover;object-position:center 24%}.linkedin-link{display:inline-flex;align-items:center;gap:.4rem;font-weight:850;text-decoration:none}.profile-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem}.profile-grid>div{padding:1.5rem;border:1px solid var(--sv-color-line);border-radius:var(--sv-radius-lg);background:rgba(255,255,255,.68);backdrop-filter:blur(16px)}.profile-grid li{margin:.5rem 0}.work-links{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.work-links a{padding:1.2rem;border:1px solid var(--sv-color-line);border-radius:.8rem;font-weight:850;text-decoration:none}@media(max-width:48rem){.profile-intro__grid,.profile-grid,.work-links{grid-template-columns:1fr}.profile-intro img{max-width:30rem}}</style>
