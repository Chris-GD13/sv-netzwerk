---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import ExpertCard from '../../components/platform/ExpertCard.astro';
import CallToAction from '../../components/CallToAction.astro';
import { experts, expertDisciplines } from '../../data/experts';
const qualificationPrinciples=['Fachgebiet und tatsächlicher Einsatzbereich','Regionale Verfügbarkeit und Reaktionsweg','Nachvollziehbare Qualifikationen und Zertifizierungen','Klare Verantwortung für Feststellung und Bewertung'];
const specialists=experts.filter((expert)=>expert.status==='active'&&expert.group==='expert');
const backoffice=experts.filter((expert)=>expert.status==='active'&&expert.group==='backoffice');
---
<BaseLayout title="Experten | Menschen im SV-Netzwerk" description="Sachverständige, Großschadenregulierer, Regulierer, Fachberater und spezialisierte Partner im SV-Netzwerk." breadcrumbs={[{label:'Start',href:'/'},{label:'Experten'}]}>
  <Hero compact eyebrow="Die Menschen im Netzwerk" title="Unsere Experten im SV-Netzwerk." text="Fachgebiete, Regionen, Qualifikationen und persönliche Verantwortung auf einen Blick." />
  <section class="sv-section" id="sachverstaendige"><div class="sv-container"><SectionHeader eyebrow="Sachverständige und Regulierer" title="Alle fachlichen Experten im Netzwerk" text="Profile mit Fachgebieten, Qualifikationen, Einsatzregionen und persönlichen Ansprechpartnern."/><div class="experts-grid">{specialists.map((expert)=><ExpertCard expert={expert}/>)}</div></div></section>
  <section class="sv-section sv-section-alt" id="backoffice"><div class="sv-container"><SectionHeader eyebrow="Backoffice" title="Organisation, Koordination und kaufmännische Begleitung" text="Das Backoffice hält Termine, Unterlagen, Kommunikation und kaufmännische Abläufe zusammen und sorgt für verlässliche Übergaben an die fachlich Verantwortlichen."/><div class="experts-grid experts-grid--backoffice">{backoffice.map((expert)=><ExpertCard expert={expert}/>)}</div></div></section>
  <section class="sv-section"><div class="sv-container intro"><div><p class="sv-eyebrow">Warum ein Expertennetzwerk?</p><h2>Die Fragestellung bestimmt, wer in den Vorgang gehört.</h2></div><div class="sv-prose"><p>Komplexe Schäden lassen sich nicht durch ein beliebig großes Kontaktverzeichnis lösen. Entscheidend ist die fachlich begründete Zuordnung: Welche Disziplin wird benötigt, wer trägt die Verantwortung und wie werden Ergebnisse an den Gesamtvorgang übergeben?</p><p>Die Profile zeigen Fachgebiete, Qualifikationen, Einsatzregionen und fachliche Beiträge. So bleibt jede Zuordnung fachlich und persönlich nachvollziehbar.</p></div></div></section>
  <section class="sv-section sv-section-alt" id="fachrichtungen"><div class="sv-container"><SectionHeader eyebrow="Unsere Fachrichtungen" title="Rollen mit klaren Aufgaben" text="Die Plattform trennt Rollen, ohne die Zusammenarbeit zu trennen."/><div class="sv-grid sv-grid-3">{expertDisciplines.map((item,index)=><FeatureCard index={String(index+1).padStart(2,'0')} title={item.title} text={item.text} tone="soft"/>)}</div></div></section>
  <section class="sv-section sv-section-alt" id="regionen"><div class="sv-container split"><div><p class="sv-eyebrow">Regionen</p><h2>Regional erreichbar, fachlich passend zugeordnet.</h2><p>Die Einsatzgebiete am Profil erleichtern die Zuordnung nach Schadenort, Aufgabenstellung und erforderlicher Reaktionszeit.</p></div><div><p class="sv-eyebrow">Qualifikationen und Zertifizierungen</p><ul>{qualificationPrinciples.map((item)=><li>{item}</li>)}</ul></div></div></section>
  <section class="sv-section" id="ansprechpartner"><div class="sv-container split"><div><p class="sv-eyebrow">Ansprechpartner</p><h2>Zentrale Zuordnung statt ungerichteter Weiterleitung.</h2><p>Anfragen werden nach Schadenart, Objekt, Region, Dringlichkeit und Prüfziel eingeordnet.</p><a class="sv-button sv-button-secondary" href="/kontakt/">Ansprechpartner kontaktieren</a></div><div id="mitglied-werden"><p class="sv-eyebrow">Mitglied werden</p><h2>Fachgebiet und Verantwortung sichtbar machen.</h2><p>Für die Aufnahme werden Tätigkeitsschwerpunkt, Regionen, Qualifikationen, Zertifizierungen und belastbare Arbeitsproben geprüft.</p><a class="sv-button sv-button-primary" href="/kontakt/">Aufnahme anfragen</a></div></div></section>
  <CallToAction title="Gutachter-Plattform für die Zusammenarbeit" text="Klare Auftragsdaten, persönliche Verantwortung und fachliche Beiträge bilden eine gemeinsame Arbeitsgrundlage." href="/gutachter-plattform/" label="Gutachter-Plattform öffnen" />
</BaseLayout>
<style>.intro,.split{display:grid;grid-template-columns:.85fr 1.15fr;gap:clamp(2rem,7vw,7rem)}.experts-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:1.25rem}.experts-grid--backoffice{grid-template-columns:repeat(2,minmax(0,1fr));max-width:58rem}.split>div{padding:1.6rem;border-top:1px solid var(--sv-color-line)}.split ul{display:grid;gap:.7rem;padding-left:1.2rem}@media(max-width:64rem){.experts-grid{grid-template-columns:repeat(2,minmax(0,1fr))}}@media(max-width:48rem){.intro,.split,.experts-grid,.experts-grid--backoffice{grid-template-columns:1fr}}</style>
