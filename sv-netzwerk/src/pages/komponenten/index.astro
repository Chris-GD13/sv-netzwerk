---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import TeamCard from '../../components/TeamCard.astro';
import StatCard from '../../components/StatCard.astro';
import InfoGrid from '../../components/InfoGrid.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import Timeline from '../../components/Timeline.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import IconList from '../../components/IconList.astro';
const timeline=[{date:'Phase 1',title:'Schadenaufnahme',text:'Sachverhalt, Ursache und Schadenumfang werden strukturiert dokumentiert.'},{date:'Phase 2',title:'Technische Bewertung',text:'Erforderliche Maßnahmen werden technisch und wirtschaftlich abgegrenzt.'},{date:'Phase 3',title:'Regulierung',text:'Die Ergebnisse werden prüffähig aufbereitet und nachvollziehbar freigegeben.'}];
const faqs=[{question:'Wofür ist diese Seite gedacht?',answer:'Sie dokumentiert die wiederverwendbaren Bausteine des SV-Netzwerk-Designsystems.'},{question:'Darf sie produktiv erreichbar sein?',answer:'Ja. Sie kann als interne Referenz bestehen oder später über Robots-Metadaten ausgeblendet werden.'}];
---
<BaseLayout title="Komponentenbibliothek" description="Referenzseite für die wiederverwendbaren Astro-Komponenten von SV-Netzwerk." breadcrumbs={[{label:'Start',href:'/'},{label:'Komponentenbibliothek'}]}>
  <section class="sv-section"><div class="sv-container">
    <SectionHeader eyebrow="SVOS Designsystem" title="Komponentenbibliothek v1.5.3" text="Wiederverwendbare, responsive und barrierearme Komponenten für Unternehmensseite, Fachwissen und Schadenregulierung." />
    <InfoGrid columns={3}>
      <FeatureCard index="01" eyebrow="Fachwissen" title="Technisch belastbar" text="Komplexe Sachverhalte werden verständlich, nachvollziehbar und fachlich sauber dargestellt." href="/fachwissen/" tone="soft" />
      <FeatureCard index="02" eyebrow="Regulierung" title="Prüffähige Unterlagen" text="Berichte, Bewertungen und Freigaben folgen einem einheitlichen Dokumentationsstandard." href="/leistungen/" tone="accent" />
      <FeatureCard index="03" eyebrow="SVOS" title="Wiederverwendbare Systeme" text="Komponenten und Datenstrukturen lassen sich konsistent über alle Bereiche einsetzen." href="/netzwerk/" tone="dark" />
    </InfoGrid>
  </div></section>

  <section class="sv-section sv-section-alt"><div class="sv-container">
    <SectionHeader eyebrow="Leistungen" title="Servicekarten" text="Einheitliche Darstellung zentraler Leistungsbereiche." />
    <InfoGrid columns={3}>
      <ServiceCard number="01" title="Großschadenregulierung" text="Strukturierte Steuerung komplexer Sach-, Gebäude- und Betriebsunterbrechungsschäden." href="/leistungen/" />
      <ServiceCard number="02" title="Technische Gutachten" text="Nachvollziehbare Feststellungen und belastbare Bewertungen für Versicherer und Auftraggeber." href="/leistungen/" tone="soft" />
      <ServiceCard number="03" title="Fachliche Prüfung" text="Positionsweise Prüfung von Angeboten, Nachträgen und Rechnungen." href="/leistungen/" tone="accent" />
    </InfoGrid>
  </div></section>

  <section class="sv-section"><div class="sv-container">
    <SectionHeader eyebrow="Kennzahlen" title="Statistik und Team" />
    <InfoGrid columns={3}>
      <StatCard value="24" suffix="h" label="strukturierte Reaktionszeit" text="für priorisierte Großschadenlagen" />
      <StatCard value="100" suffix="%" label="nachvollziehbare Dokumentation" text="vom Ortstermin bis zur Freigabe" />
      <TeamCard name="Christian Wächter" role="Sachverständiger & Großschadenregulierer" qualification="DIN EN ISO/IEC 17024 zertifiziert" href="/netzwerk/" />
    </InfoGrid>
  </div></section>

  <section class="sv-section sv-section-alt"><div class="sv-container">
    <SectionHeader eyebrow="Abläufe" title="Timeline, FAQ und Checklisten" />
    <div class="demo-two"><Timeline items={timeline} /><div><FAQAccordion items={faqs} /><div class="checklist sv-card"><h3>Qualitätsmerkmale</h3><IconList items={['responsive aufgebaut','mit gemeinsamen Props typisiert','Design Tokens statt Einzelwerte','barrierearme Fokus- und Interaktionszustände']} /></div></div></div>
  </div></section>
</BaseLayout>
<style>.demo-two{display:grid;grid-template-columns:1.15fr .85fr;gap:var(--sv-space-7)}.checklist{margin-top:1rem;padding:var(--sv-card-padding)}@media(max-width:52rem){.demo-two{grid-template-columns:1fr}}</style>
