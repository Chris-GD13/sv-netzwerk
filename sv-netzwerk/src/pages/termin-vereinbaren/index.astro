---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';

const sent = Astro.url.searchParams.get('gesendet') === '1';
const error = Astro.url.searchParams.get('fehler');
---

<BaseLayout
  title="Termin vereinbaren"
  description="Terminvereinbarung für Ortstermine, Schadenaufnahmen und Rückfragen."
  breadcrumbs={[{ label: 'Start', href: '/' }, { label: 'Termin vereinbaren' }]}
>
  <Hero
    compact
    eyebrow="Terminservice"
    title="Ortstermin oder Videocall anfragen."
    text="Übermitteln Sie Ihren Terminwunsch mit den relevanten Eckdaten. Die Anfrage wird serverseitig verarbeitet."
  />

  <section class="sv-section">
    <div class="sv-container grid">
      <article class="sv-card">
        <h2>Was wir zur Koordination brauchen</h2>
        <ul>
          <li>Schadenort und grobe Schadenart</li>
          <li>bevorzugte Zeitfenster</li>
          <li>Ansprechpartner vor Ort</li>
          <li>bestehende Schaden- oder Vorgangsnummer</li>
        </ul>
      </article>
      <article class="sv-card">
        <h2>Terminformular</h2>
        {sent && <p class="status success">Die Terminanfrage wurde übermittelt. Sie erhalten eine Eingangsbestätigung per E-Mail.</p>}
        {error && <p class="status error">Die Übermittlung ist fehlgeschlagen. Bitte prüfen Sie die Eingaben.</p>}
        <form action="/anfrage.php" method="post" accept-charset="UTF-8">
          <input type="text" name="website" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <input type="hidden" name="Formular" value="Terminvereinbarung" />

          <label>Name / Auftraggeber
            <input name="Name" required />
          </label>
          <label>E-Mail
            <input name="E-Mail" type="email" required />
          </label>
          <label>Telefon
            <input name="Telefon" type="tel" />
          </label>
          <label>Terminwunsch / Thema
            <input name="Thema" required />
          </label>
          <label>Nachricht
            <textarea name="Nachricht" rows="7" required></textarea>
          </label>

          <button class="sv-button sv-button-primary" type="submit">Termin anfragen</button>
        </form>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .grid{display:grid;grid-template-columns:minmax(18rem,.9fr) minmax(0,1.1fr);gap:2rem}
  .sv-card{padding:clamp(1.4rem,3vw,2.3rem)}
  ul{padding-left:1.2rem}
  form{display:grid;gap:.85rem}
  label{display:grid;gap:.45rem;font-weight:800}
  input,textarea{width:100%;padding:.8rem;border:1px solid var(--sv-color-line);border-radius:.6rem;background:white}
  .status{padding:.85rem 1rem;border-radius:.6rem;font-weight:700}
  .status.success{background:#e7f7ef;border:1px solid #6db58d;color:#174f31}
  .status.error{background:#fbe9e9;border:1px solid #cc7e7e;color:#6d1f1f}
  .hp-field{position:absolute;left:-100vw;width:1px;height:1px;opacity:0}
  @media (max-width:54rem){.grid{grid-template-columns:1fr}}
</style>
