---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import KnowledgeMeta from '../../components/knowledge/KnowledgeMeta.astro';
import RelatedKnowledge from '../../components/knowledge/RelatedKnowledge.astro';
import CallToAction from '../../components/CallToAction.astro';
import { getPublishedKnowledge, estimateReadingMinutes, findRelatedKnowledge } from '../../utils/knowledge';
export async function getStaticPaths(){const entries=await getCollection('knowledge',({data})=>data.publication.status==='published');return entries.map((entry)=>({params:{id:entry.id},props:{entry}}));}
interface Props { entry: CollectionEntry<'knowledge'> }
const { entry } = Astro.props;
const { Content } = await render(entry);
const allEntries=await getPublishedKnowledge();
const related=findRelatedKnowledge(entry,allEntries);
const readingMinutes=estimateReadingMinutes(entry.body??'',entry.data.readingMinutes);
const published=entry.data.publication.publishedAt;
const updated=entry.data.publication.updatedAt??published;
const articleSchema={'@context':'https://schema.org','@type':'Article',headline:entry.data.title,description:entry.data.description,datePublished:published.toISOString(),dateModified:updated.toISOString(),author:{'@type':'Person',name:'Christian Wächter'},publisher:{'@type':'Organization',name:'SV-Netzwerk'},mainEntityOfPage:new URL(`/fachwissen/${entry.id}/`,Astro.site).toString()};
const category=(entry.data.category??'').toLowerCase();
const tags=(entry.data.tags??[]).map((tag)=>tag.toLowerCase());
const damageTypes=(entry.data.damageTypes??[]).map((damage)=>damage.toLowerCase());
const matchesTag=(needle:string)=>tags.some((tag)=>tag.includes(needle));
const matchesDamage=(needle:string)=>damageTypes.some((damage)=>damage.includes(needle));
const serviceLinkCandidates=[
  { href:'/leistungen/kumulschadenmanagement/', label:'Kumulschadenmanagement für Versicherer', match: category.includes('kumul') || matchesTag('kumul') || category.includes('starkregen') || category.includes('hochwasser') || matchesTag('starkregen') || matchesTag('hochwasser') || matchesTag('überflutung') || matchesDamage('sturm') || matchesDamage('hochwasser') || matchesDamage('ueberflutung') },
  { href:'/grossschadenregulierung/', label:'Großschadenregulierung für Versicherer', match: matchesTag('grossschaden') || category.includes('sturm') || category.includes('hochwasser') || matchesDamage('sturm') || matchesDamage('brand') },
  { href:'/leistungen/rechnungs-und-kva-pruefung/', label:'Rechnungs- und KVA-Prüfung', match: matchesTag('rechnungsprüfung') || matchesTag('kalkulation') || matchesTag('regiekosten') || matchesTag('prüffähigkeit') || category.includes('prozessqualität') },
  { href:'/leistungen/schadenregulierung-fuer-versicherer/', label:'Schadenregulierung für Versicherer', match: matchesTag('schadenregulierung') || category.includes('schadenregulierung') || category.includes('prozessqualität') },
];
const serviceLinks=serviceLinkCandidates.filter((candidate)=>candidate.match).filter((candidate,index,candidates)=>candidates.findIndex((entry)=>entry.href===candidate.href)===index).slice(0,2);
---
<BaseLayout title={entry.data.seo.title??entry.data.title} description={entry.data.seo.description??entry.data.description} canonical={entry.data.seo.canonical} image={entry.data.seo.image} imageAlt={entry.data.seo.imageAlt} type="article" breadcrumbs={[{label:'Start',href:'/'},{label:'Fachartikel',href:'/fachwissen/'},{label:entry.data.title}]}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <article class="sv-section"><div class="sv-container article-shell"><header><p class="sv-eyebrow">{entry.data.category}{entry.data.contentLevel&&` · ${entry.data.contentLevel}-Beitrag`}</p><h1>{entry.data.title}</h1><p class="lead">{entry.data.teaser??entry.data.description}</p><KnowledgeMeta author={entry.data.author} publishedAt={published} updatedAt={updated} readingMinutes={readingMinutes}/></header><div class="prose"><Content /></div>{serviceLinks.length>0&&<aside class="service-links"><h2>Passende Leistungen</h2><ul>{serviceLinks.map((item)=><li><a href={item.href}>{item.label}</a></li>)}</ul></aside>}<footer><ul>{entry.data.tags.map((tag)=><li><span>#{tag}</span></li>)}</ul></footer><RelatedKnowledge entries={related}/></div></article>
  {entry.data.cta&&<CallToAction title="Fachliche Einordnung für Ihren Vorgang" text="Schadenart, Objekt, Region und konkrete Fragestellung strukturiert übermitteln." href={entry.data.cta.href} label={entry.data.cta.label}/>} 
</BaseLayout>
<style>.article-shell{max-width:58rem}.article-shell h1{max-width:20ch}.lead{max-width:65ch;color:var(--sv-color-muted);font-size:1.2rem}.focus-notice{margin:1rem 0 0;padding:.85rem 1rem;border:1px solid #d9e4ea;border-left:4px solid var(--sv-color-accent);border-radius:.75rem;background:#f8fcff;color:#2f5062;font-size:.92rem}.prose{margin-top:var(--sv-space-7);font-size:1.04rem;line-height:1.78}.prose :global(h2){margin-top:2.5rem}.prose :global(h3){margin-top:2rem}.prose :global(a){text-underline-offset:.18em}.service-links{margin-top:var(--sv-space-7);padding:1rem 1.15rem;border:1px solid var(--sv-color-line);border-radius:.75rem;background:rgba(255,255,255,.72)}.service-links h2{margin:0 0 .65rem;font-size:1.05rem}.service-links ul{display:grid;gap:.45rem;margin:0;padding-left:1.2rem}footer ul{display:flex;flex-wrap:wrap;gap:.5rem;margin:var(--sv-space-7) 0 0;padding:0;list-style:none}footer span{display:inline-flex;padding:.35rem .65rem;border-radius:999px;background:var(--sv-color-surface-alt)}</style>
