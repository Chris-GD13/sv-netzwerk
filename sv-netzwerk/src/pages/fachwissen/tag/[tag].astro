---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import LibraryFilters from '../../../components/LibraryFilters.astro';
import LibraryGrid from '../../../components/LibraryGrid.astro';
import { sortedLibrary, tags, slugify } from '../../../data/library';

export function getStaticPaths() {
  return tags.map((tag) => ({ params: { tag: slugify(tag) }, props: { tag } }));
}

const { tag } = Astro.props;
const items = sortedLibrary.filter((item) => item.tags.includes(tag));
---
<BaseLayout title={`#${tag} – Fachartikel | SV-Netzwerk`} description={`Fachbeiträge und Praxishinweise des SV-Netzwerks zum Schlagwort ${tag}.`} noindex>
  <Hero eyebrow="Fachartikel nach Schlagwort" title={`#${tag}`} text={`${items.length} ${items.length === 1 ? 'Beitrag' : 'Beiträge'} mit diesem Schlagwort.`} />
  <section class="sv-section">
    <div class="sv-container">
      <Breadcrumbs items={[{ label: 'Start', href: '/' }, { label: 'Fachartikel', href: '/fachwissen/' }, { label: `#${tag}` }]} />
      <LibraryFilters activeTag={tag} />
      <LibraryGrid items={items} />
    </div>
  </section>
</BaseLayout>
