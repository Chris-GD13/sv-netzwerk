---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import LibraryFilters from '../../../components/LibraryFilters.astro';
import LibraryGrid from '../../../components/LibraryGrid.astro';
import { categories, sortedLibrary, slugify } from '../../../data/library';

export function getStaticPaths() {
  return categories.map((category) => ({ params: { category: slugify(category) }, props: { category } }));
}

const { category } = Astro.props;
const items = sortedLibrary.filter((item) => item.category === category);
---
<BaseLayout title={`${category} – Fachartikel | SV-Netzwerk`} description={`Fachartikel, Praxishinweise und technische Bewertungen aus der Kategorie ${category}.`}>
  <Hero eyebrow="Fachartikel nach Kategorie" title={category} text={`${items.length} ${items.length === 1 ? 'Beitrag' : 'Beiträge'} zu ${category}.`} />
  <section class="sv-section">
    <div class="sv-container">
      <Breadcrumbs items={[{ label: 'Start', href: '/' }, { label: 'Fachartikel', href: '/fachwissen/' }, { label: category }]} />
      <LibraryFilters activeCategory={category} />
      <LibraryGrid items={items} />
    </div>
  </section>
</BaseLayout>
