---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import LibraryFilters from '../../../components/LibraryFilters.astro';
import LibraryGrid from '../../../components/LibraryGrid.astro';
import Pagination from '../../../components/Pagination.astro';
import { PAGE_SIZE, sortedLibrary } from '../../../data/library';

export function getStaticPaths() {
  const totalPages = Math.ceil(sortedLibrary.length / PAGE_SIZE);
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => {
    const page = index + 2;
    return { params: { page: String(page) }, props: { page, totalPages } };
  });
}

const { page, totalPages } = Astro.props;
const start = (page - 1) * PAGE_SIZE;
const pageItems = sortedLibrary.slice(start, start + PAGE_SIZE);
---
<BaseLayout title={`Fachartikel – Seite ${page} | SV-Netzwerk`} description={`Weitere Fachbeiträge aus dem SV-Netzwerk Fachartikel-Bereich, Seite ${page}.`} noindex>
  <Hero eyebrow="SVOS Fachartikel" title={`Fachartikel – Seite ${page}`} text="Weitere technische und regulierungsrelevante Fachbeiträge." />
  <section class="sv-section">
    <div class="sv-container">
      <LibraryFilters />
      <LibraryGrid items={pageItems} />
      <Pagination currentPage={page} totalPages={totalPages} />
    </div>
  </section>
</BaseLayout>
