const description = 'Technische und regulierungssichere Kriterien zur Abgrenzung notwendiger Trocknungs-, Öffnungs- und Rückbaumaßnahmen bei Leitungswasserschäden.';
const canonical = 'https://www.sv-netzwerk.eu/fachwissen/wasserschaden-rueckbau-technische-abgrenzung/';
const published = '2026-07-14';
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: published,
  dateModified: published,
  mainEntityOfPage: canonical,
  author: {
    '@type': 'Person',
    name: 'Christian Wächter',
    jobTitle: 'Sachverständiger & Großschadenregulierer'
  },
  publisher: {
    '@type': 'Organization',
    name: 'SV-Netzwerk',
    url: 'https://www.sv-netzwerk.eu/'
  },
  image: 'https://www.sv-netzwerk.eu/og-default.svg'
