---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import DamageCard from '../../components/platform/DamageCard.astro';
import ProcessFlow from '../../components/platform/ProcessFlow.astro';
import CallToAction from '../../components/CallToAction.astro';
import { damageTypes } from '../../data/damage-types';
const steps=[{title:'Schadenbild',text:'Sichtbare und verdeckte Betroffenheit erfassen.'},{title:'Einwirkungsweg',text:'Ursache und Ausbreitung nachvollziehen.'},{title:'Konstruktion',text:'Bauteile, Materialien und Schnittstellen prüfen.'},{title:'Abgrenzung',text:'Ereignisschaden von Vorschäden trennen.'},{title:'Maßnahmen',text:'Erforderliche Schritte fachlich herleiten.'},{title:'Kosten',text:'Mengen und Leistungen prüffähig zuordnen.'},{title:'Entscheidung',text:'Bewertung und Grenzen dokumentieren.'}];
---
<BaseLayout title="Digitales Kompetenzzentrum | Schadenarten" description="Zwölf datengetriebene Kompetenzbereiche für Bau-, Sach- und Versicherungsschäden." breadcrumbs={[{label:'Start',href:'/'},{label:'Schadenarten'}]}>
  <Hero compact eyebrow="Digitales Kompetenzzentrum" title="Schadenarten mit einer belastbaren Prüflogik verbinden." text="Jeder Kompetenzbereich führt typische Schadenbilder, Prüfgegenstände, Fachwissen, Praxisfälle, Downloads und zuständige Experten aus einer gemeinsamen Datenquelle zusammen." primaryLabel="Schaden melden" primaryHref="/schaden-melden/" />
  <section class="sv-section"><div class="sv-container"><SectionHeader eyebrow="Kompetenzbereiche" title="Zwölf Einstiege in die technische Schadenbewertung" text="Die Detailseiten bilden die Grundlage für spätere Fall-, Wissens- und Expertenverknüpfungen."/><div class="sv-grid sv-grid-3">{damageTypes.map((item,index)=><DamageCard item={item} index={index+1}/>)}</div></div></section>
  <section class="sv-section sv-section-alt"><div class="sv-container"><SectionHeader eyebrow="Gemeinsamer Standard" title="Vom Schadenbild zur dokumentierten Entscheidung"/><ProcessFlow steps={steps}/></div></section>
  <CallToAction title="Schadenart noch nicht eindeutig?" text="Die Erstklassifizierung wird anhand von Schadenbild, Objekt, Einwirkungsweg und verfügbaren Unterlagen geprüft." href="/schaden-melden/" label="Schaden strukturiert erfassen" />
</BaseLayout>
