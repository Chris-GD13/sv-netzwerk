---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import CallToAction from '../../components/CallToAction.astro';

const lossTypes = [
  { id: 'brand', title: 'Brand', focus: 'Brandentstehung, Beaufschlagung, Ruß- und Löschmittelfolgen', checks: 'Spurenlage, Materialschädigung, Kontamination und Sanierungsgrenzen' },
  { id: 'leitungswasser', title: 'Leitungswasser', focus: 'Austrittsstelle, Wasserweg und Durchfeuchtungsumfang', checks: 'Leitungsbezug, Bauteilfeuchte, Rückbaugrenzen und Trocknung' },
  { id: 'sturm', title: 'Sturm', focus: 'Windwirkung und Versagen von Dach- oder Fassadenbauteilen', checks: 'Befestigung, Vorschäden, Öffnungen und schadenbedingte Folgemaßnahmen' },
  { id: 'elementar', title: 'Elementar', focus: 'Überflutung, Rückstau, Starkregen und Naturgefahren', checks: 'Eintrittsweg, Wasserstand, Kontamination und Wiederherstellbarkeit' },
  { id: 'schimmel', title: 'Schimmel', focus: 'Feuchteursache und mikrobieller Befall', checks: 'Nutzung, Konstruktion, Messwerte, Ausbreitung und Sanierungskonzept' },
  { id: 'haftpflicht', title: 'Haftpflicht', focus: 'Technischer Verursachungsbeitrag und betroffener Bereich', checks: 'Kausalität, Sowieso-Kosten, Vorschäden und erforderliche Wiederherstellung' },
  { id: 'photovoltaik', title: 'Photovoltaik', focus: 'Module, Leitungsführung, Unterkonstruktion und Dachanschlüsse', checks: 'Elektrische und mechanische Schäden, Montagezustand und Folgewirkung' },
  { id: 'fenster-fassade', title: 'Fenster und Fassade', focus: 'Anschlüsse, Dichtheit, Verformung und Oberflächen', checks: 'Schlagregen, Luftdichtheit, Befestigung, Beschichtung und Einbauzustand' },
  { id: 'tga', title: 'Technische Gebäudeausrüstung', focus: 'Heizung, Sanitär, Lüftung, Elektro und Gebäudeautomation', checks: 'Anlagenfunktion, Schnittstellen, Leitungsverlauf und Reparaturumfang' },
];
---

<BaseLayout title="Schadenarten | SV-Netzwerk" description="Technische Einordnung von Brand-, Leitungswasser-, Sturm-, Elementar-, Schimmel- und weiteren Bau- und Versicherungsschäden." breadcrumbs={[{label:'Start',href:'/'},{label:'Schadenarten'}]}>
  <Hero compact eyebrow="Schadenarten" title="Jedes Schadenbild verlangt eine eigene Prüflogik." text="Die fachliche Bearbeitung folgt nicht nur der sichtbaren Beschädigung. Entscheidend sind Ursache, Einwirkungsweg, betroffene Konstruktion und der nachweisbar schadenbedingte Umfang." primaryLabel="Schaden melden" primaryHref="/schaden-melden/" />
  <section class="sv-section">
    <div class="sv-container">
      <SectionHeader eyebrow="Technische Schwerpunkte" title="Neun Schadenbereiche im Überblick" text="Die Übersicht zeigt, welche Kernfragen bei der Erstzuordnung und technischen Prüfung im Vordergrund stehen." />
      <div class="loss-grid">
        {lossTypes.map((item, index) => (
          <article id={item.id} class="loss-card sv-card">
            <span>0{index + 1}</span><h2>{item.title}</h2><p><strong>Fokus</strong>{item.focus}</p><p><strong>Prüfpunkte</strong>{item.checks}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
  <section class="sv-section sv-section-alt"><div class="sv-container method"><div><p class="sv-eyebrow">Gemeinsamer Standard</p><h2>Vom sichtbaren Schaden zur technischen Abgrenzung.</h2></div><ol><li><span>01</span><div><strong>Schadenbild erfassen</strong><p>Bauteile, Ausdehnung, zeitlicher Verlauf und bereits getroffene Maßnahmen dokumentieren.</p></div></li><li><span>02</span><div><strong>Ursache und Weg prüfen</strong><p>Einwirkung, Kausalität und technische Alternativursachen nachvollziehbar bewerten.</p></div></li><li><span>03</span><div><strong>Umfang abgrenzen</strong><p>Schadenbedingte Arbeiten von Vorschaden, Mangel und Instandhaltung trennen.</p></div></li></ol></div></section>
  <CallToAction title="Schadenart noch nicht eindeutig?" text="Eine belastbare Zuordnung entsteht häufig erst aus Fotos, Unterlagen und der technischen Erstprüfung." href="/kontakt/" label="Fall einordnen lassen" />
</BaseLayout>

<style>
  .loss-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:var(--sv-space-5)}.loss-card{scroll-margin-top:7rem;padding:1.6rem}.loss-card>span{color:var(--sv-color-accent-hover);font-size:.7rem;font-weight:950}.loss-card h2{margin-top:1.2rem;font-size:1.5rem}.loss-card p{color:var(--sv-color-muted);font-size:.9rem}.loss-card p strong{display:block;margin-bottom:.2rem;color:var(--sv-color-ink)}.method{display:grid;grid-template-columns:.8fr 1.2fr;gap:clamp(2rem,7vw,7rem)}.method ol{display:grid;gap:1rem;margin:0;padding:0;list-style:none}.method li{display:grid;grid-template-columns:auto 1fr;gap:1rem;padding:1.2rem;border-top:1px solid var(--sv-color-line)}.method li>span{color:var(--sv-color-accent-hover);font-weight:950}.method li p{margin:.2rem 0 0;color:var(--sv-color-muted)}
  @media(max-width:60rem){.loss-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:42rem){.loss-grid,.method{grid-template-columns:1fr}}
</style>
