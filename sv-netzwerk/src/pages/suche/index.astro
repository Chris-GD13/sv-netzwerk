---
import BaseLayout from '../../layouts/BaseLayout.astro'; import Hero from '../../components/Hero.astro'; import {library,categories} from '../../data/library';
---
<BaseLayout title="Suche" description="Fachwissen, Downloads und Videos des SV-Netzwerks durchsuchen."><Hero compact eyebrow="Suche" title="SVOS Wissenssuche" text="Durchsuchen Sie Fachbeiträge, Downloads und Videos nach Begriffen, Kategorien und Schlagworten."/><section class="sv-section"><div class="sv-container search-layout"><aside class="sv-card filters"><label>Suchbegriff<input type="search" data-q placeholder="Suchbegriff"/></label><label>Kategorie<select data-cat><option value="all">Alle Kategorien</option>{categories.map(c=><option value={c}>{c}</option>)}</select></label><label>Inhaltstyp<select data-type><option value="all">Alle Typen</option><option value="article">Fachbeiträge</option><option value="download">Downloads</option><option value="video">Videos</option></select></label></aside><div><p data-count>{library.length} Inhalte</p><div class="results" data-results>{library.map(i=><a class="sv-card" href={i.href} data-item data-search={`${i.title} ${i.description} ${i.category} ${i.tags.join(' ')}`.toLowerCase()} data-cat={i.category} data-type={i.type}><span class="sv-pill">{i.category}</span><h2>{i.title}</h2><p>{i.description}</p><small>{i.tags.join(' · ')}</small></a>)}</div></div></div></section></BaseLayout>
<script is:inline>const q=document.querySelector('[data-q]'),cat=document.querySelector('[data-cat]'),type=document.querySelector('[data-type]'),items=[...document.querySelectorAll('[data-item]')],count=document.querySelector('[data-count]');function run(){let n=0;items.forEach(i=>{const ok=i.dataset.search.includes(q.value.toLowerCase())&&(cat.value==='all'||i.dataset.cat===cat.value)&&(type.value==='all'||i.dataset.type===type.value);i.hidden=!ok;if(ok)n++;});count.textContent=`${n} Inhalte`;};[q,cat,type].forEach(x=>x.addEventListener('input',run));</script>
<style>.search-layout{display:grid;grid-template-columns:18rem 1fr;gap:2rem}.filters{display:grid;align-self:start;gap:1rem;padding:1.25rem;position:sticky;top:6rem}.filters label{font-weight:850}.filters input,.filters select{width:100%;margin-top:.35rem;padding:.75rem;border:1px solid var(--sv-color-line);border-radius:.6rem;background:white}.results{display:grid;gap:1rem}.results a{display:block;padding:1.25rem;text-decoration:none}.results h2{margin:.75rem 0 .5rem;font-family:var(--sv-font-sans);font-size:1.35rem}.results p{color:var(--sv-color-muted)}@media(max-width:50rem){.search-layout{grid-template-columns:1fr}.filters{position:static}}</style>
