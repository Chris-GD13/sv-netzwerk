---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import { categories, tags } from '../../data/library';
import { searchIndex as searchDocuments } from '../../lib/search';

const typeLabels = {
  article: 'Fachbeitrag',
  download: 'Download',
  video: 'Video',
};
---
<BaseLayout title="Suche" description="Fachwissen, Downloads und Videos des SV-Netzwerks durchsuchen." breadcrumbs={[{ label: 'Start', href: '/' }, { label: 'Suche' }]}>
  <Hero compact eyebrow="Suche" title="SVOS Wissenssuche" text="Durchsuchen Sie Fachbeiträge, Downloads und Videos nach Begriffen, Kategorien und Schlagworten." />

  <section class="sv-section">
    <div class="sv-container search-layout">
      <aside class="sv-card filters" aria-label="Suchfilter">
        <div class="filter-heading">
          <h2>Suche filtern</h2>
          <button type="button" data-reset>Zurücksetzen</button>
        </div>
        <label>
          Suchbegriff
          <input type="search" data-q placeholder="Begriff eingeben" autocomplete="off" />
        </label>
        <label>
          Kategorie
          <select data-cat>
            <option value="all">Alle Kategorien</option>
            {categories.map((category) => <option value={category}>{category}</option>)}
          </select>
        </label>
        <label>
          Inhaltstyp
          <select data-type>
            <option value="all">Alle Typen</option>
            <option value="article">Fachbeiträge</option>
            <option value="download">Downloads</option>
            <option value="video">Videos</option>
          </select>
        </label>
        <fieldset>
          <legend>Häufige Schlagworte</legend>
          <div class="tag-options">
            {tags.slice(0, 12).map((tag) => <button type="button" data-tag={tag}>{tag}</button>)}
          </div>
        </fieldset>
      </aside>

      <div class="result-column">
        <div class="result-toolbar">
          <p data-count>{searchDocuments.length} Inhalte</p>
          <label>
            Sortierung
            <select data-sort>
              <option value="relevance">Relevanz</option>
              <option value="newest">Neueste zuerst</option>
              <option value="az">A–Z</option>
            </select>
          </label>
        </div>

        <div class="results" data-results>
          {searchDocuments.map((item) => (
            <article
              class="sv-card search-card"
              data-item
              data-title={item.title.toLocaleLowerCase('de-DE')}
              data-date={item.date}
              data-search={item.searchable}
              data-tokens={item.tokens.join('|')}
              data-cat={item.category}
              data-type={item.type}
              data-tags={item.tags.join('|')}
            >
              <div class="card-meta">
                <span class="sv-pill">{item.category}</span>
                <span>{typeLabels[item.type]}</span>
              </div>
              <h2><a href={item.href}>{item.title}</a></h2>
              <p>{item.description}</p>
              <div class="card-tags">{item.tags.map((tag) => <span>{tag}</span>)}</div>
              <a class="card-link" href={item.href}>Inhalt öffnen <span aria-hidden="true">→</span></a>
            </article>
          ))}
        </div>
        <div class="no-results" data-empty hidden>
          <h2>Keine passenden Inhalte</h2>
          <p>Reduzieren Sie die Filter oder verwenden Sie einen allgemeineren Suchbegriff.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const q = document.querySelector('[data-q]');
  const cat = document.querySelector('[data-cat]');
  const type = document.querySelector('[data-type]');
  const sort = document.querySelector('[data-sort]');
  const reset = document.querySelector('[data-reset]');
  const tagButtons = [...document.querySelectorAll('[data-tag]')];
  const container = document.querySelector('[data-results]');
  const items = [...document.querySelectorAll('[data-item]')];
  const count = document.querySelector('[data-count]');
  const empty = document.querySelector('[data-empty]');
  let selectedTag = '';

  const normalize = (value = '') => value.toLocaleLowerCase('de-DE').normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/ß/g, 'ss').replace(/[^a-z0-9]+/g, ' ').trim();

  function syncUrl() {
    const params = new URLSearchParams();
    if (q.value) params.set('q', q.value);
    if (cat.value !== 'all') params.set('category', cat.value);
    if (type.value !== 'all') params.set('type', type.value);
    if (selectedTag) params.set('tag', selectedTag);
    if (sort.value !== 'relevance') params.set('sort', sort.value);
    history.replaceState(null, '', `${location.pathname}${params.size ? `?${params}` : ''}`);
  }

  function score(item, term) {
    if (!term) return 0;
    let value = 0;
    if (normalize(item.dataset.title) === term) value += 100;
    if (normalize(item.dataset.title).startsWith(term)) value += 70;
    if (normalize(item.dataset.title).includes(term)) value += 45;
    if (item.dataset.search.includes(term)) value += 10;
    const queryTokens = term.split(/\s+/).filter(Boolean);
    const tokens = (item.dataset.tokens || '').split('|');
    value += queryTokens.filter((token) => tokens.some((candidate) => candidate.includes(token))).length * 8;
    return value;
  }

  function run() {
    const term = normalize(q.value);
    const visible = items.filter((item) => {
      const matchesQuery = !term || item.dataset.search.includes(term);
      const matchesCategory = cat.value === 'all' || item.dataset.cat === cat.value;
      const matchesType = type.value === 'all' || item.dataset.type === type.value;
      const matchesTag = !selectedTag || item.dataset.tags.split('|').includes(selectedTag);
      const matches = matchesQuery && matchesCategory && matchesType && matchesTag;
      item.hidden = !matches;
      item.dataset.score = String(score(item, term));
      return matches;
    });

    visible.sort((a, b) => {
      if (sort.value === 'newest') return b.dataset.date.localeCompare(a.dataset.date);
      if (sort.value === 'az') return a.dataset.title.localeCompare(b.dataset.title, 'de');
      return Number(b.dataset.score) - Number(a.dataset.score) || b.dataset.date.localeCompare(a.dataset.date);
    }).forEach((item) => container.appendChild(item));

    count.textContent = visible.length === 1 ? '1 Inhalt' : `${visible.length} Inhalte`;
    empty.hidden = visible.length > 0;
    syncUrl();
  }

  function selectTag(tag) {
    selectedTag = selectedTag === tag ? '' : tag;
    tagButtons.forEach((button) => button.classList.toggle('is-active', button.dataset.tag === selectedTag));
    run();
  }

  const params = new URLSearchParams(location.search);
  q.value = params.get('q') || '';
  cat.value = params.get('category') || 'all';
  type.value = params.get('type') || 'all';
  sort.value = params.get('sort') || 'relevance';
  selectedTag = params.get('tag') || '';
  tagButtons.forEach((button) => {
    button.classList.toggle('is-active', button.dataset.tag === selectedTag);
    button.addEventListener('click', () => selectTag(button.dataset.tag));
  });

  [q, cat, type, sort].forEach((element) => element.addEventListener('input', run));
  reset.addEventListener('click', () => {
    q.value = '';
    cat.value = 'all';
    type.value = 'all';
    sort.value = 'relevance';
    selectedTag = '';
    tagButtons.forEach((button) => button.classList.remove('is-active'));
    run();
  });
  run();
</script>

<style>
  .search-layout{display:grid;grid-template-columns:minmax(16rem,20rem) minmax(0,1fr);gap:2rem}.filters{display:grid;align-self:start;gap:1rem;padding:1.35rem;position:sticky;top:6rem}.filter-heading{display:flex;align-items:center;justify-content:space-between;gap:1rem}.filter-heading h2{margin:0;font-family:var(--sv-font-sans);font-size:1.15rem}.filter-heading button{padding:0;border:0;background:transparent;color:var(--sv-color-primary);font-weight:800;cursor:pointer}.filters label,.filters legend{font-weight:850}.filters input,.filters select,.result-toolbar select{width:100%;margin-top:.35rem;padding:.75rem;border:1px solid var(--sv-color-line);border-radius:.6rem;background:white}.filters fieldset{padding:0;border:0}.tag-options{display:flex;flex-wrap:wrap;gap:.45rem;margin-top:.6rem}.tag-options button{padding:.45rem .6rem;border:1px solid var(--sv-color-line);border-radius:999px;background:white;color:var(--sv-color-ink-soft);font-size:.78rem;cursor:pointer}.tag-options button:hover,.tag-options button.is-active{border-color:var(--sv-color-primary);background:var(--sv-color-primary);color:white}.result-toolbar{display:flex;align-items:flex-end;justify-content:space-between;gap:1rem;margin-bottom:1rem}.result-toolbar p{margin:0;font-weight:850}.result-toolbar label{width:min(15rem,45%);font-size:.8rem;font-weight:800}.results{display:grid;gap:1rem}.search-card{display:grid;gap:.75rem;padding:1.35rem}.search-card h2{margin:0;font-family:var(--sv-font-sans);font-size:1.35rem}.search-card h2 a{color:inherit;text-decoration:none}.search-card h2 a:hover{color:var(--sv-color-primary)}.search-card p{margin:0;color:var(--sv-color-muted)}.card-meta{display:flex;align-items:center;justify-content:space-between;gap:1rem;color:var(--sv-color-muted);font-size:.82rem}.card-tags{display:flex;flex-wrap:wrap;gap:.4rem}.card-tags span{padding:.25rem .45rem;border-radius:.35rem;background:var(--sv-color-surface-alt);color:var(--sv-color-muted);font-size:.75rem}.card-link{font-weight:850;text-decoration:none}.no-results{padding:2rem;border:1px dashed var(--sv-color-line);border-radius:var(--sv-radius-lg);text-align:center}.no-results h2{margin-top:0}@media(max-width:50rem){.search-layout{grid-template-columns:1fr}.filters{position:static}.result-toolbar{align-items:stretch;flex-direction:column}.result-toolbar label{width:100%}}
</style>
