---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import { site } from '../../data/site';

const sent = Astro.url.searchParams.get('gesendet') === '1';
const error = Astro.url.searchParams.get('fehler');
---

<BaseLayout
  title="Kontakt"
  description="Kontaktformular für Schadenfälle, Rückfragen und Beauftragungen beim SV-Netzwerk."
  breadcrumbs={[{ label: 'Start', href: '/' }, { label: 'Kontakt' }]}
>
  <Hero
    compact
    eyebrow="Kontakt"
    title="Schadenfall oder Projektanfrage einreichen."
    text="Nutzen Sie das Kontaktformular für eine strukturierte Erstaufnahme. Wir prüfen Ihr Anliegen und melden uns zeitnah zurück."
  />

  <section class="sv-section">
    <div class="sv-container contact-grid">
      <article class="sv-card contact-card">
        <p class="sv-eyebrow">Direkter Kontakt</p>
        <h2>{site.legalName}</h2>
        <p>{site.address[0]}<br />{site.address[1]}</p>
        <p><a href={`mailto:${site.email}`}>{site.email}</a><br /><a href={`tel:${site.phone.replace(/\D/g, '')}`}>{site.phone}</a></p>
        <p>Für Terminabstimmungen nutzen Sie die dedizierte Seite <a href="/termin-vereinbaren/">Termin vereinbaren</a>.</p>
      </article>

      <article class="sv-card form-card">
        <h2>Kontaktformular</h2>
        {sent && <p class="status success">Ihre Anfrage wurde erfolgreich übermittelt. Sie erhalten zusätzlich eine Eingangsbestätigung per E-Mail.</p>}
        {error && <p class="status error">Die Anfrage konnte nicht verarbeitet werden. Bitte prüfen Sie die Eingaben und senden Sie erneut.</p>}
        <form action="/anfrage.php" method="post" accept-charset="UTF-8">
          <input type="text" name="website" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <input type="hidden" name="Formular" value="Kontaktformular" />

          <label>Name / Auftraggeber
            <input name="Name" required />
          </label>
          <label>E-Mail
            <input name="E-Mail" type="email" required />
          </label>
          <label>Telefon (optional)
            <input name="Telefon" type="tel" />
          </label>
          <label>Thema
            <input name="Thema" required />
          </label>
          <label>Nachricht
            <textarea name="Nachricht" rows="7" required></textarea>
          </label>

          <button class="sv-button sv-button-primary" type="submit">Anfrage senden</button>
        </form>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid{display:grid;grid-template-columns:minmax(18rem,.9fr) minmax(0,1.1fr);gap:2rem}
  .contact-card,.form-card{padding:clamp(1.4rem,3vw,2.3rem)}
  form{display:grid;gap:.85rem}
  label{display:grid;gap:.45rem;font-weight:800}
  input,textarea{width:100%;padding:.8rem;border:1px solid var(--sv-color-line);border-radius:.6rem;background:white}
  .status{padding:.85rem 1rem;border-radius:.6rem;font-weight:700}
  .status.success{background:#e7f7ef;border:1px solid #6db58d;color:#174f31}
  .status.error{background:#fbe9e9;border:1px solid #cc7e7e;color:#6d1f1f}
  .hp-field{position:absolute;left:-100vw;width:1px;height:1px;opacity:0}
  @media (max-width:54rem){.contact-grid{grid-template-columns:1fr}}
</style>
