---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import TeamCard from '../../components/TeamCard.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import InfoGrid from '../../components/InfoGrid.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import CallToAction from '../../components/CallToAction.astro';
---

<BaseLayout title="Netzwerk | SV-Netzwerk" description="Sachverständige, Fachpartner und geregelte Zusammenarbeit für komplexe Bau- und Versicherungsschäden." breadcrumbs={[{label:'Start',href:'/'},{label:'Netzwerk'}]}>
  <Hero compact eyebrow="Netzwerk" title="Spezialwissen gezielt zusammenführen." text="Fachgebiete werden nicht pauschal gebündelt. Sie werden mit einer klaren Fragestellung, definierten Schnittstellen und dokumentierter Verantwortung in den Vorgang eingebunden." primaryLabel="Zusammenarbeit anfragen" primaryHref="/kontakt/" />
  <section class="sv-section"><div class="sv-container"><SectionHeader eyebrow="Ansprechpartner" title="Koordination und technische Verantwortung" text="Die zentrale Zuordnung verbindet Schadenart, Region, Verfügbarkeit und erforderliche Qualifikation."/><InfoGrid columns={2}><TeamCard name="Christian Wächter" role="Sachverständiger & Großschadenregulierer" qualification="DIN EN ISO/IEC 17024 zertifiziert" href="/experten/christian-waechter/"/><TeamCard name="SV-Netzwerk Backoffice" role="Organisation, Dokumentation und Koordination" qualification="Zentrale Vorgangs- und Terminsteuerung im SVOS"/></InfoGrid></div></section>
  <section class="sv-section sv-section-alt"><div class="sv-container"><SectionHeader eyebrow="Zusammenarbeit" title="Drei verbindliche Schnittstellen"/><div class="sv-grid sv-grid-3"><FeatureCard index="01" title="Auftrag und Fragestellung" text="Jeder Fachbeitrag beginnt mit einem abgegrenzten Prüfziel und den dafür verfügbaren Unterlagen."/><FeatureCard index="02" title="Dokumentation und Übergabe" text="Feststellungen, Dateien und offene Punkte werden einheitlich benannt und dem Vorgang zugeordnet."/><FeatureCard index="03" title="Bewertung und Verantwortung" text="Beiträge bleiben fachlich zuordenbar; die Gesamtbewertung macht Abhängigkeiten und Grenzen sichtbar."/></div></div></section>
  <section class="sv-section"><div class="sv-container network-fields"><div><p class="sv-eyebrow">Fachgebiete</p><h2>Kompetenz nach Schadenbild besetzen.</h2></div><ul><li>Bautechnik und Baukonstruktion</li><li>Fenster, Türen und Fassaden</li><li>Feuchte, Schimmel und Innenraumschadstoffe</li><li>Brand- und Elektroschäden</li><li>Technische Gebäudeausrüstung</li><li>Großschadenregulierung und Schadensteuerung</li></ul></div></section>
  <CallToAction title="Fachkompetenz für einen Vorgang anfragen" text="Nennen Sie Schadenart, Ort, Fragestellung und gewünschten Bearbeitungszeitraum." href="/kontakt/" label="Netzwerkanfrage stellen" />
</BaseLayout>

<style>.network-fields{display:grid;grid-template-columns:.8fr 1.2fr;gap:clamp(2rem,7vw,7rem)}.network-fields ul{display:grid;grid-template-columns:repeat(2,1fr);gap:.7rem;margin:0;padding:0;list-style:none}.network-fields li{padding:1rem;border:1px solid var(--sv-color-line);border-radius:.8rem;background:var(--sv-color-surface-alt);font-weight:800}@media(max-width:48rem){.network-fields,.network-fields ul{grid-template-columns:1fr}}</style>
