---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import NoticeBox from '../../components/NoticeBox.astro';
import { damageTypes } from '../../data/damage-types';
const steps=['Schadenart','Objekt','Versicherungsverhältnis','Kontaktdaten','Beschreibung','Bilder und Dokumente','Zusammenfassung','Übermittlung'];
---
<BaseLayout title="Schaden melden | Strukturierte Erstaufnahme" description="Schadenart, Objekt und Kontaktdaten für eine fachliche Erstklassifizierung sicher vorbereiten." breadcrumbs={[{label:'Start',href:'/'},{label:'Schaden melden'}]}>
  <Hero compact eyebrow="Strukturierte Erstaufnahme" title="Einen Schaden fachlich vorbereitet melden." text="Die Erfassung ordnet die Angaben in acht nachvollziehbare Schritte. In Version 5.1 werden Eingaben ausschließlich lokal im Browser für die Zusammenfassung verarbeitet und noch nicht an einen Server übertragen." />
  <section class="sv-section"><div class="sv-container report-layout">
    <aside><h2>Ablauf</h2><ol>{steps.map((step,index)=><li class:list={{'is-current':index===0}} data-step-indicator={index+1}><span>{index+1}</span>{step}</li>)}</ol></aside>
    <div>
      <NoticeBox title="Technischer Status">Dieses Formular versendet noch keine Daten und lädt keine Dateien hoch. Für die verbindliche Schadenmeldung nutzen Sie nach der Zusammenfassung Telefon oder E-Mail. Eine API-Anbindung folgt erst mit Authentifizierung, Datenschutzprüfung und sicherer Dateiübertragung.</NoticeBox>
      <form class="sv-card report-form" data-report-form novalidate>
        <fieldset data-step="1"><legend>1. Schadenart</legend><p>Welche Erstklassifizierung passt am ehesten?</p><label>Schadenart<select name="damageType" required><option value="">Bitte auswählen</option>{damageTypes.map((item)=><option value={item.shortTitle}>{item.title}</option>)}</select></label></fieldset>
        <fieldset data-step="2" hidden><legend>2. Objekt</legend><label>Objektart<select name="objectType" required><option value="">Bitte auswählen</option><option>Wohngebäude</option><option>Gewerbegebäude</option><option>Industrieanlage</option><option>Hausrat</option><option>Sonstiges Objekt</option></select></label><label>Schadenort<input name="location" autocomplete="address-level2" required /></label></fieldset>
        <fieldset data-step="3" hidden><legend>3. Versicherungsverhältnis</legend><label>Ihre Rolle<select name="insuranceRole" required><option value="">Bitte auswählen</option><option>Versicherungsnehmer</option><option>Versicherer oder Regulierer</option><option>Hausverwaltung</option><option>beauftragter Dienstleister</option><option>sonstige Beteiligung</option></select></label></fieldset>
        <fieldset data-step="4" hidden><legend>4. Kontaktdaten</legend><label>Name<input name="name" autocomplete="name" required /></label><label>E-Mail<input name="email" type="email" autocomplete="email" required /></label><label>Telefon<input name="phone" type="tel" autocomplete="tel" /></label></fieldset>
        <fieldset data-step="5" hidden><legend>5. Schadenbeschreibung</legend><label>Zeitpunkt oder Feststellungsdatum<input name="date" type="date" required /></label><label>Was ist geschehen?<textarea name="description" rows="7" minlength="30" required></textarea></label></fieldset>
        <fieldset data-step="6" hidden><legend>6. Bilder und Dokumente</legend><p>In Version 5.1 können noch keine Dateien sicher hochgeladen werden. Halten Sie Übersichtsfotos, Detailfotos, Versicherungsnummer und vorhandene Berichte für den anschließenden Kontakt bereit.</p><label><input name="filesReady" type="checkbox" /> Unterlagen sind für die weitere Abstimmung verfügbar</label></fieldset>
        <fieldset data-step="7" hidden><legend>7. Zusammenfassung</legend><dl data-summary></dl></fieldset>
        <fieldset data-step="8" hidden><legend>8. Sichere Übermittlung</legend><p>Die lokale Vorbereitung ist abgeschlossen. Es wurden keine Daten übertragen.</p><div class="contact-options"><a class="sv-button sv-button-primary" href="mailto:cw@sv-schuett.eu">Per E-Mail fortsetzen</a><a class="sv-button sv-button-secondary" href="tel:+4973673939783">07367 / 393 97 83</a></div></fieldset>
        <p class="form-error" data-form-error role="alert" hidden>Bitte füllen Sie die erforderlichen Angaben dieses Schritts aus.</p>
        <div class="form-actions"><button class="sv-button sv-button-secondary" type="button" data-back hidden>Zurück</button><button class="sv-button sv-button-primary" type="button" data-next>Weiter</button></div>
      </form>
    </div>
  </div></section>
</BaseLayout>
<script is:inline>
  (()=>{const form=document.querySelector('[data-report-form]');if(!form)return;const fields=[...form.querySelectorAll('fieldset[data-step]')];const indicators=[...document.querySelectorAll('[data-step-indicator]')];const back=form.querySelector('[data-back]');const next=form.querySelector('[data-next]');const error=form.querySelector('[data-form-error]');let current=0;
  const show=()=>{fields.forEach((field,index)=>field.hidden=index!==current);indicators.forEach((item,index)=>item.classList.toggle('is-current',index===current));back.hidden=current===0;next.hidden=current===fields.length-1;next.textContent=current===fields.length-2?'Zusammenfassung bestätigen':'Weiter';error.hidden=true;if(current===6){const data=new FormData(form);const summary=form.querySelector('[data-summary]');summary.innerHTML='';[['Schadenart','damageType'],['Objekt','objectType'],['Ort','location'],['Rolle','insuranceRole'],['Name','name'],['E-Mail','email'],['Datum','date'],['Beschreibung','description']].forEach(([label,key])=>{const dt=document.createElement('dt');const dd=document.createElement('dd');dt.textContent=label;dd.textContent=String(data.get(key)||'–');summary.append(dt,dd);});}fields[current].querySelector('input,select,textarea')?.focus();};
  next.addEventListener('click',()=>{const controls=[...fields[current].querySelectorAll('[required]')];if(!controls.every((control)=>control.checkValidity())){error.hidden=false;controls.find((control)=>!control.checkValidity())?.focus();return;}if(current<fields.length-1){current+=1;show();}});back.addEventListener('click',()=>{if(current>0){current-=1;show();}});show();})();
</script>
<style>.report-layout{display:grid;grid-template-columns:minmax(15rem,.55fr) minmax(0,1.45fr);gap:2rem;align-items:start}.report-layout aside{position:sticky;top:7rem}.report-layout aside ol{display:grid;gap:.25rem;padding:0;list-style:none}.report-layout aside li{display:flex;align-items:center;gap:.7rem;padding:.65rem;border-radius:.6rem;color:var(--sv-color-muted)}.report-layout aside li.is-current{background:var(--sv-color-surface-alt);color:var(--sv-color-ink);font-weight:850}.report-layout aside span{display:grid;width:1.8rem;aspect-ratio:1;place-items:center;border:1px solid var(--sv-color-line);border-radius:50%;font-size:.72rem}.report-form{margin-top:1rem;padding:clamp(1.3rem,4vw,2.3rem)}.report-form fieldset{display:grid;gap:1rem;padding:0;border:0}.report-form legend{margin-bottom:1.2rem;font-family:var(--sv-font-display);font-size:2rem;font-weight:850}.report-form label{display:grid;gap:.4rem;font-weight:850}.report-form input,.report-form select,.report-form textarea{width:100%;padding:.8rem;border:1px solid var(--sv-color-line);border-radius:.65rem;background:white}.report-form input[type=checkbox]{width:auto}.form-actions,.contact-options{display:flex;justify-content:space-between;gap:1rem;margin-top:2rem}.form-error{color:#9c251d;font-weight:850}.report-form dl{display:grid;grid-template-columns:minmax(8rem,.4fr) 1fr}.report-form dt,.report-form dd{margin:0;padding:.65rem;border-bottom:1px solid var(--sv-color-line)}.report-form dt{font-weight:850}@media(max-width:52rem){.report-layout{grid-template-columns:1fr}.report-layout aside{position:static}.report-layout aside ol{grid-template-columns:repeat(4,1fr)}.report-layout aside li{display:grid;font-size:.7rem}}@media(max-width:35rem){.report-layout aside ol{grid-template-columns:repeat(2,1fr)}.form-actions,.contact-options{flex-direction:column}}</style>
