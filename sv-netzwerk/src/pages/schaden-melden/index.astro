---
import BaseLayout from '../../layouts/BaseLayout.astro';

const sent = Astro.url.searchParams.get('gesendet') === '1';
const error = Astro.url.searchParams.get('fehler');
---

<BaseLayout
  title="Schaden melden"
  description="Schadenmeldung mit Dateiupload für eine schnelle Erstbearbeitung."
  breadcrumbs={[{ label: 'Start', href: '/' }, { label: 'Schaden melden' }]}
>
  <section class="sv-section">
    <div class="sv-container entry-header">
      <p class="sv-eyebrow">Schadenmeldung</p>
      <h1>Schadenfall direkt einreichen</h1>
      <p class="sv-lead">Schadenart, Schadendatum und Objekt direkt übermitteln. Datei-Uploads für Erstunterlagen sind möglich.</p>
    </div>
  </section>

  <section class="sv-section">
    <div class="sv-container report-grid">
      <article class="sv-card info-card">
        <h2>Hinweise zur Einreichung</h2>
        <ul>
          <li>Mögliche Dateiformate: JPG, PNG, WEBP, HEIC, PDF (je Datei bis 10 MB)</li>
          <li>Bitte Schadendatum und Schadenort möglichst exakt angeben</li>
          <li>Sie erhalten automatisch eine Eingangsbestätigung per E-Mail</li>
          <li>Das Team meldet sich mit dem weiteren Vorgehen zurück</li>
        </ul>
      </article>

      <article class="sv-card form-card">
        <h2>Schadenformular</h2>
        {sent && <p class="status success">Die Schadenmeldung wurde erfolgreich übermittelt.</p>}
        {error && <p class="status error">Die Schadenmeldung konnte nicht verarbeitet werden. Bitte Eingaben prüfen.</p>}

        <form action="/schadenmeldung.php" method="post" enctype="multipart/form-data" accept-charset="UTF-8">
          <input type="text" name="website" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true" />

          <div class="form-grid">
            <label>Schadenart
              <select name="Schadenart" required>
                <option value="">Bitte auswählen</option>
                <option>Leitungswasser</option>
                <option>Brand</option>
                <option>Sturm / Hagel</option>
                <option>Elementar</option>
                <option>Haftpflicht</option>
                <option>Sonstiges</option>
              </select>
            </label>
            <label>Objektart
              <select name="Objektart" required>
                <option value="">Bitte auswählen</option>
                <option>Wohngebäude</option>
                <option>Gewerbe</option>
                <option>Industrie</option>
                <option>Hausrat</option>
                <option>Sonstiges Objekt</option>
              </select>
            </label>
            <label>Schadenort
              <input name="Schadenort" required />
            </label>
            <label>Schadennummer (optional)
              <input name="Schadennummer" />
            </label>
            <label>Name
              <input name="Name" required />
            </label>
            <label>Unternehmen / Auftraggeber
              <input name="Unternehmen" />
            </label>
            <label>E-Mail
              <input name="E-Mail" type="email" required />
            </label>
            <label>Telefon
              <input name="Telefon" type="tel" />
            </label>
            <label>Schadendatum
              <input name="Schadendatum" type="date" required />
            </label>
            <label>Dringlichkeit
              <select name="Dringlichkeit" required>
                <option value="">Bitte auswählen</option>
                <option>Akut (Sofortmaßnahmen nötig)</option>
                <option>Hoch (Bearbeitung innerhalb 24h)</option>
                <option>Normal</option>
              </select>
            </label>
            <label class="full">Kurzbeschreibung
              <textarea name="Kurzbeschreibung" rows="8" minlength="30" required></textarea>
            </label>
            <label class="full">Dateien
              <input name="Dateien[]" type="file" multiple accept=".jpg,.jpeg,.png,.pdf,.webp,.heic" />
            </label>
            <label class="full check">
              <input type="checkbox" name="Datenschutz" value="akzeptiert" required />
              Ich bestätige die datenschutzkonforme Verarbeitung zur Bearbeitung meiner Schadenmeldung.
            </label>
          </div>

          <button class="sv-button sv-button-primary" type="submit">Schadenmeldung senden</button>
        </form>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .entry-header{display:grid;gap:1rem}
  .entry-header h1{margin:0}
  .entry-header .sv-lead{margin:0}
  .report-grid{display:grid;grid-template-columns:minmax(16rem,.7fr) minmax(0,1.3fr);gap:2rem}
  .info-card,.form-card{padding:clamp(1.4rem,3vw,2.2rem)}
  .focus-note{margin:0 0 1rem;padding:.85rem 1rem;border:1px solid #d9e4ea;border-left:4px solid var(--sv-color-accent);border-radius:.75rem;background:#f8fcff}
  .info-card ul{padding-left:1.2rem}
  .form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.85rem}
  .form-grid .full{grid-column:1/-1}
  label{display:grid;gap:.42rem;font-weight:800}
  input,select,textarea{width:100%;padding:.8rem;border:1px solid var(--sv-color-line);border-radius:.6rem;background:white}
  .check{display:flex;align-items:flex-start;gap:.6rem;font-weight:700}
  .check input{width:auto;margin-top:.2rem}
  .status{padding:.85rem 1rem;border-radius:.6rem;font-weight:700}
  .status.success{background:#e7f7ef;border:1px solid #6db58d;color:#174f31}
  .status.error{background:#fbe9e9;border:1px solid #cc7e7e;color:#6d1f1f}
  .hp-field{position:absolute;left:-100vw;width:1px;height:1px;opacity:0}
  @media (max-width:58rem){.report-grid,.form-grid{grid-template-columns:1fr}}
</style>
