---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Hero from '../../../../components/Hero.astro';
import KnowledgeCard from '../../../../components/knowledge/KnowledgeCard.astro';
import { getPublishedKnowledge, getKnowledgeCategories, filterByCategory } from '../../../../utils/knowledge';

export async function getStaticPaths() {
  const entries = await getPublishedKnowledge();
  return getKnowledgeCategories(entries).map((term) => ({ params:{category:term.slug}, props:{label:term.label} }));
}
const { category } = Astro.params;
const { label } = Astro.props;
const entries = filterByCategory(await getPublishedKnowledge(), category!);
---
<BaseLayout title={`${label} | SVOS Fachwissen`} description={`Fachbeiträge der Kategorie ${label}.`} breadcrumbs={[{label:'Start',href:'/'},{label:'SVOS',href:'/svos/'},{label:'Fachwissen',href:'/svos/fachwissen/'},{label}]}><Hero eyebrow="Kategorie" title={label} text={`${entries.length} veröffentlichte Fachbeiträge`}/><section class="sv-section"><div class="sv-container grid">{entries.map((entry)=><KnowledgeCard entry={entry}/>)}</div></section></BaseLayout>
<style>.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,20rem),1fr));gap:var(--sv-space-5)}</style>
