---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import StatCard from '../../components/StatCard.astro';
import InfoGrid from '../../components/InfoGrid.astro';
import ProcessFlow from '../../components/platform/ProcessFlow.astro';
import CallToAction from '../../components/CallToAction.astro';
import { damageTypes } from '../../data/damage-types';
import { experts } from '../../data/experts';
const [knowledge,practiceCases]=await Promise.all([getCollection('knowledge'),getCollection('practiceCases')]);
const steps=[{title:'Schadenmeldung',text:'Grunddaten und Unterlagen strukturiert erfassen.'},{title:'Erstklassifizierung',text:'Schadenart, Objekt und Dringlichkeit zuordnen.'},{title:'Technische Bewertung',text:'Prüfziel und erforderliche Fachdisziplin bestimmen.'},{title:'Sachverständigenzuordnung',text:'Qualifikation, Region und Verfügbarkeit abgleichen.'},{title:'Dokumentation',text:'Feststellungen und offene Punkte nachvollziehbar führen.'},{title:'Regulierung',text:'Maßnahmen, Kosten und Entscheidungen fortschreiben.'},{title:'Abschluss',text:'Ergebnis, Unterlagen und Erkenntnisse sichern.'}];
---
<BaseLayout title="SVOS Core Platform | SV-Netzwerk" description="Das SV Operating System verbindet Schadenmeldung, Kompetenz, Experten, Fachartikel, Fälle und Arbeitshilfen zu einer nachvollziehbaren Fachplattform." breadcrumbs={[{label:'Start',href:'/'},{label:'SVOS'}]}>
  <Hero compact eyebrow="SVOS Core Platform" title="Vom Schadenereignis zur nachvollziehbaren Entscheidung." text="SVOS ist die gemeinsame Daten-, Fachartikel- und Prozessstruktur des SV-Netzwerks. Es ersetzt keine fachliche Verantwortung, sondern macht Zuständigkeiten, Grundlagen und Bearbeitungsstände überprüfbar." primaryLabel="Schadenmeldung" primaryHref="/schaden-melden/" secondaryLabel="Fachartikel" secondaryHref="/fachwissen/" />
  <section class="sv-section sv-section-alt"><div class="sv-container"><SectionHeader eyebrow="Im Überblick" title="Inhalte und Verantwortlichkeiten zentral verbunden"/><InfoGrid columns={4}><StatCard value={String(damageTypes.length)} label="Schadenarten"/><StatCard value={String(knowledge.length)} label="Fachbeiträge"/><StatCard value={String(practiceCases.length)} label="Praxisfälle"/><StatCard value={String(experts.length)} label="bestätigte Expertenprofile"/></InfoGrid></div></section>
  <section class="sv-section"><div class="sv-container"><SectionHeader eyebrow="Prozess" title="Sieben Stationen mit dokumentierter Übergabe"/><ProcessFlow steps={steps}/></div></section>
  <section class="sv-section sv-section-alt"><div class="sv-container"><SectionHeader eyebrow="Vorteile" title="Ein System für unterschiedliche Rollen"/><div class="audiences"><article><h3>Versicherer</h3><p>Prüffähige Bearbeitungsstände, klare Zuständigkeiten und vergleichbare Dokumentation.</p></article><article><h3>Sachverständige</h3><p>Abgegrenzte Aufträge, strukturierte Unterlagen und sichtbare fachliche Verantwortung.</p></article><article><h3>Regulierer</h3><p>Verknüpfte Feststellungen, Maßnahmen, Kosten und Entscheidungspunkte.</p></article><article><h3>Dienstleister</h3><p>Klare Leistungsgrenzen, Übergaben und nachvollziehbare Rückmeldungen.</p></article></div></div></section>
  <CallToAction title="SVOS für einen konkreten Anwendungsfall einordnen" text="Wir prüfen Aufgabenstellung, beteiligte Rollen, benötigte Unterlagen und fachliche Übergaben gemeinsam." href="/kontakt/" label="Anwendungsfall besprechen" />
</BaseLayout>
<style>.audiences{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}.audiences article{padding:1.4rem;border-top:3px solid var(--sv-color-accent);background:white}.audiences p{color:var(--sv-color-muted)}@media(max-width:58rem){.audiences{grid-template-columns:repeat(2,1fr)}}@media(max-width:36rem){.audiences{grid-template-columns:1fr}}</style>
