---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import StatCard from '../../components/StatCard.astro';
import InfoGrid from '../../components/InfoGrid.astro';
import ModuleCard from '../../components/platform/ModuleCard.astro';
import ProcessFlow from '../../components/platform/ProcessFlow.astro';
import CallToAction from '../../components/CallToAction.astro';
import { damageTypes } from '../../data/damage-types';
import { experts } from '../../data/experts';
import type { PlatformModule } from '../../types/platform';
const [knowledge,practiceCases]=await Promise.all([getCollection('knowledge'),getCollection('practiceCases')]);
const modules:PlatformModule[]=[
 {title:'Schadenmeldung',description:'Strukturierter Einstieg für Schadenart, Objekt, Beteiligte und vorhandene Unterlagen.',href:'/schaden-melden/',status:'verfügbar',audience:['Auftraggeber','Versicherer']},
 {title:'Kompetenzzentrum',description:'Schadenarten mit Prüfpunkten, Wissen, Fällen, Downloads und Experten verbinden.',href:'/schadenarten/',status:'verfügbar',audience:['Sachverständige','Regulierer']},
 {title:'Fachwissen',description:'Versionierte Fachbeiträge mit Taxonomien, Autoren und verbindlichem Veröffentlichungslauf.',href:'/fachwissen/',status:'verfügbar',audience:['Alle Rollen']},
 {title:'Praxisfälle',description:'Anonymisierte Fälle mit Feststellung, Bewertung, Maßnahmen und Ergebnis.',href:'/praxisfaelle/',status:'verfügbar',audience:['Versicherer','Regulierer']},
 {title:'Downloadcenter',description:'Prüfschemata und Arbeitshilfen mit Version, Zielgruppe und Zuordnung.',href:'/downloads/',status:'verfügbar',audience:['Alle Rollen']},
 {title:'Expertennetzwerk',description:'Menschen, Fachgebiete, Regionen und Qualifikationen datengetrieben zuordnen.',href:'/experten/',status:'verfügbar',audience:['Auftraggeber','Experten']},
];
const steps=[{title:'Schadenmeldung',text:'Grunddaten und Unterlagen strukturiert erfassen.'},{title:'Erstklassifizierung',text:'Schadenart, Objekt und Dringlichkeit zuordnen.'},{title:'Technische Bewertung',text:'Prüfziel und erforderliche Fachdisziplin bestimmen.'},{title:'Sachverständigenzuordnung',text:'Qualifikation, Region und Verfügbarkeit abgleichen.'},{title:'Dokumentation',text:'Feststellungen und offene Punkte nachvollziehbar führen.'},{title:'Regulierung',text:'Maßnahmen, Kosten und Entscheidungen fortschreiben.'},{title:'Abschluss',text:'Ergebnis, Unterlagen und Erkenntnisse sichern.'}];
const roadmap=[{phase:'5.1',title:'Core Platform',text:'Schadenarten, Experten, Suche und täglicher Wissensstandard.'},{phase:'5.2',title:'Vorgangsmodelle',text:'Rollen, Status, Aufgaben und dokumentierte Übergaben.'},{phase:'5.3',title:'Sichere Zusammenarbeit',text:'Authentifizierung, Rechte und geprüfte Schnittstellen.'}];
---
<BaseLayout title="SVOS Core Platform | SV-Netzwerk" description="Das SV Operating System verbindet Schadenmeldung, Kompetenz, Experten, Wissen, Fälle und Arbeitshilfen zu einer nachvollziehbaren Fachplattform." breadcrumbs={[{label:'Start',href:'/'},{label:'SVOS'}]}>
  <Hero compact eyebrow="SVOS Core Platform" title="Vom Schadenereignis zur nachvollziehbaren Entscheidung." text="SVOS ist die gemeinsame Daten-, Wissens- und Prozessstruktur des SV-Netzwerks. Es ersetzt keine fachliche Verantwortung, sondern macht Zuständigkeiten, Grundlagen und Bearbeitungsstände überprüfbar." primaryLabel="Schadenmeldung" primaryHref="/schaden-melden/" secondaryLabel="Fachwissen" secondaryHref="/fachwissen/" />
  <section class="sv-section"><div class="sv-container"><SectionHeader eyebrow="Plattformstatus" title="Inhalte und Verantwortlichkeiten zentral verbunden"/><InfoGrid columns={4}><StatCard value={String(damageTypes.length)} label="Schadenarten"/><StatCard value={String(knowledge.length)} label="Fachbeiträge"/><StatCard value={String(practiceCases.length)} label="Praxisfälle"/><StatCard value={String(experts.length)} label="bestätigte Expertenprofile"/></InfoGrid></div></section>
  <section class="sv-section sv-section-alt"><div class="sv-container"><SectionHeader eyebrow="Module" title="Direkte Einstiege in die Core Platform" text="Jedes Modul besitzt einen fachlich abgegrenzten Zweck und gemeinsame Verknüpfungsfelder."/><div class="sv-grid sv-grid-3">{modules.map((module)=><ModuleCard module={module}/>)}</div></div></section>
  <section class="sv-section"><div class="sv-container"><SectionHeader eyebrow="Prozess" title="Sieben Stationen mit dokumentierter Übergabe"/><ProcessFlow steps={steps}/></div></section>
  <section class="sv-section sv-section-alt"><div class="sv-container"><SectionHeader eyebrow="Vorteile" title="Ein System für unterschiedliche Rollen"/><div class="audiences"><article><h3>Versicherer</h3><p>Prüffähige Bearbeitungsstände, klare Zuständigkeiten und vergleichbare Dokumentation.</p></article><article><h3>Sachverständige</h3><p>Abgegrenzte Aufträge, strukturierte Unterlagen und sichtbare fachliche Verantwortung.</p></article><article><h3>Regulierer</h3><p>Verknüpfte Feststellungen, Maßnahmen, Kosten und Entscheidungspunkte.</p></article><article><h3>Dienstleister</h3><p>Klare Leistungsgrenzen, Übergaben und nachvollziehbare Rückmeldungen.</p></article></div></div></section>
  <section class="sv-section"><div class="sv-container"><SectionHeader eyebrow="Entwicklungsroadmap" title="Schrittweise vom Wissenssystem zur Arbeitsplattform"/><ol class="roadmap">{roadmap.map((item)=><li><span>{item.phase}</span><div><h3>{item.title}</h3><p>{item.text}</p></div></li>)}</ol></div></section>
  <CallToAction title="SVOS für einen konkreten Anwendungsfall einordnen" text="Der nächste Entwicklungsschritt wird an realen Prozessanforderungen und gesicherten Rollenmodellen ausgerichtet." href="/kontakt/" label="Anwendungsfall besprechen" />
</BaseLayout>
<style>.audiences{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}.audiences article{padding:1.4rem;border-top:3px solid var(--sv-color-accent);background:white}.audiences p,.roadmap p{color:var(--sv-color-muted)}.roadmap{display:grid;gap:1rem;margin:0;padding:0;list-style:none}.roadmap li{display:grid;grid-template-columns:5rem 1fr;gap:1rem;padding:1.3rem;border-top:1px solid var(--sv-color-line)}.roadmap span{color:var(--sv-color-accent-hover);font-weight:950}@media(max-width:58rem){.audiences{grid-template-columns:repeat(2,1fr)}}@media(max-width:36rem){.audiences{grid-template-columns:1fr}}</style>
