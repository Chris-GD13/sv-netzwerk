---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';

const sent = Astro.url.searchParams.get('gesendet') === '1';
const error = Astro.url.searchParams.get('fehler');
---

<BaseLayout
  title="Plattform-Anfrage"
  description="Anfrageformular fuer Demo, Zugang und Kooperation zur Gutachter-Plattform."
  breadcrumbs={[{ label: 'Start', href: '/' }, { label: 'Gutachter-Plattform', href: '/gutachter-plattform/' }, { label: 'Anfrage' }]}
>
  <Hero
    compact
    eyebrow="Gutachter-Plattform Anfrage"
    title="Kontakt zur Plattform aufnehmen."
    text="Anfragen zu Demo, Zugang oder Kooperation werden serverseitig verarbeitet und an den Plattformbetrieb weitergeleitet."
  />

  <section class="sv-section">
    <div class="sv-container grid">
      <article class="sv-card">
        <h2>Empfaenger</h2>
        <p><strong>GASD GmbH</strong><br />vertreten durch den Geschaeftsfuehrer Goran Krstic<br />Hauptstr. 7, 76571 Gaggenau</p>
        <p>E-Mail: <a href="mailto:info@gutachter-plattform.de">info@gutachter-plattform.de</a></p>
      </article>
      <article class="sv-card">
        <h2>Plattformformular</h2>
        {sent && <p class="status success">Ihre Anfrage wurde uebermittelt. Eine Eingangsbestätigung wurde versendet.</p>}
        {error && <p class="status error">Die Anfrage konnte nicht verarbeitet werden. Bitte pruefen Sie Ihre Eingaben.</p>}
        <form action="/anfrage-gutachter-plattform.php" method="post" accept-charset="UTF-8">
          <input type="text" name="website" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <input type="hidden" name="Formular" value="Gutachter-Plattform Anfrage" />
          <input type="hidden" name="Herkunft" value="SV-Netzwerk.eu / Provisionshinweis" />

          <label>Name
            <input name="Name" required />
          </label>
          <label>Unternehmen / Organisation
            <input name="Unternehmen" />
          </label>
          <label>Rolle / Zielgruppe
            <select name="Rolle" required>
              <option value="">Bitte auswaehlen</option>
              <option value="Versicherer">Versicherer</option>
              <option value="Regulierer">Regulierer</option>
              <option value="Sachverstaendiger">Sachverstaendiger</option>
              <option value="Sanierer / Dienstleister">Sanierer / Dienstleister</option>
              <option value="Sonstige Anfrage">Sonstige Anfrage</option>
            </select>
          </label>
          <label>E-Mail
            <input name="E-Mail" type="email" required />
          </label>
          <label>Telefon
            <input name="Telefon" type="tel" />
          </label>
          <label>Thema
            <input name="Thema" required />
          </label>
          <label>Nachricht
            <textarea name="Nachricht" rows="7" required></textarea>
          </label>
          <label class="check">
            <input type="checkbox" name="Datenschutz" value="akzeptiert" required />
            Ich stimme der Weiterleitung meiner Angaben an die GASD GmbH zur Bearbeitung zu.
          </label>

          <button class="sv-button sv-button-primary" type="submit">Anfrage an die Plattform senden</button>
        </form>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .grid{display:grid;grid-template-columns:minmax(16rem,.8fr) minmax(0,1.2fr);gap:2rem}
  .sv-card{padding:clamp(1.4rem,3vw,2.2rem)}
  form{display:grid;gap:.85rem}
  label{display:grid;gap:.45rem;font-weight:800}
  input,select,textarea{width:100%;padding:.8rem;border:1px solid var(--sv-color-line);border-radius:.6rem;background:white}
  .check{display:flex;gap:.6rem;align-items:flex-start;font-weight:700}
  .check input{width:auto;margin-top:.2rem}
  .status{padding:.85rem 1rem;border-radius:.6rem;font-weight:700}
  .status.success{background:#e7f7ef;border:1px solid #6db58d;color:#174f31}
  .status.error{background:#fbe9e9;border:1px solid #cc7e7e;color:#6d1f1f}
  .hp-field{position:absolute;left:-100vw;width:1px;height:1px;opacity:0}
  @media (max-width:54rem){.grid{grid-template-columns:1fr}}
</style>
