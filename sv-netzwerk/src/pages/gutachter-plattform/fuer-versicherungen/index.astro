---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import CallToAction from '../../../components/CallToAction.astro';
---

<BaseLayout
  title="Gutachter-Plattform fuer Versicherungen"
  description="Steuerung von Beauftragungen, Transparenz und Qualitaet fuer Versicherer."
  breadcrumbs={[{ label: 'Start', href: '/' }, { label: 'Gutachter-Plattform', href: '/gutachter-plattform/' }, { label: 'Fuer Versicherungen' }]}
>
  <Hero
    compact
    eyebrow="Fuer Versicherer"
    title="Beauftragungen und Qualitaet sauber steuern."
    text="Die Plattform schafft Transparenz ueber Status, Unterlagen, Rueckfragen und naechste Entscheidungsschritte."
    primaryLabel="Plattform-Anfrage"
    primaryHref="/gutachter-plattform/anfrage/"
    secondaryLabel="Versicherer-Leistungen"
    secondaryHref="/versicherer/"
  />
  <CallToAction
    title="Plattformzugang fuer Ihr Team abstimmen"
    text="Wir richten den Pilotprozess mit Rollen, Unterlagenstandard und Kommunikationsweg aus."
    href="/gutachter-plattform/anfrage/"
    label="Anfrage senden"
  />
</BaseLayout>
