---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import CallToAction from '../../../components/CallToAction.astro';
---

<BaseLayout
  title="Gutachter-Plattform für Versicherungen"
  description="Steuerung von Beauftragungen, Transparenz und Qualität für Versicherer."
  breadcrumbs={[{ label: 'Start', href: '/' }, { label: 'Gutachter-Plattform', href: '/gutachter-plattform/' }, { label: 'Für Versicherungen' }]}
>
  <Hero
    compact
    eyebrow="Für Versicherer"
    title="Beauftragungen und Qualität sauber steuern."
    text="Die Plattform schafft Transparenz über Status, Unterlagen, Rückfragen und nächste Entscheidungsschritte."
    primaryLabel="Plattform-Anfrage"
    primaryHref="/gutachter-plattform/anfrage/"
    secondaryLabel="Versicherer-Leistungen"
    secondaryHref="/versicherer/"
  />
  <CallToAction
    title="Plattformzugang für Ihr Team abstimmen"
    text="Wir richten den Pilotprozess mit Rollen, Unterlagenstandard und Kommunikationsweg aus."
    href="/gutachter-plattform/anfrage/"
    label="Anfrage senden"
  />
</BaseLayout>
