---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import CallToAction from '../../../components/CallToAction.astro';
---

<BaseLayout
  title="Gutachter-Plattform fuer Sachverstaendige"
  description="Digitale Arbeitsabläufe fuer Sachverstaendige mit klaren Qualitaetsstandards."
  breadcrumbs={[{ label: 'Start', href: '/' }, { label: 'Gutachter-Plattform', href: '/gutachter-plattform/' }, { label: 'Fuer Sachverstaendige' }]}
>
  <Hero
    compact
    eyebrow="Fuer Sachverstaendige"
    title="Auftraege strukturiert und effizient bearbeiten."
    text="Die Plattform verbindet Auftragseingang, Dokumentation und Rueckfragenfuehrung in einem konsistenten Ablauf."
    primaryLabel="Registrierung anfragen"
    primaryHref="/gutachter-plattform/anfrage/"
    secondaryLabel="Expertenprofil ansehen"
    secondaryHref="/experten/"
  />
  <CallToAction
    title="Registrierung und Qualifikationsprofil abstimmen"
    text="Senden Sie Ihre Anfrage fuer Onboarding und Zugang zur Plattform."
    href="/gutachter-plattform/anfrage/"
    label="Registrierung anfragen"
  />
</BaseLayout>
