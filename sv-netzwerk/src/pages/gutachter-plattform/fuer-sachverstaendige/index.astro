---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import CallToAction from '../../../components/CallToAction.astro';
---

<BaseLayout
  title="Gutachter-Plattform für Sachverständige"
  description="Digitale Arbeitsabläufe für Sachverständige mit klaren Qualitätsstandards."
  breadcrumbs={[{ label: 'Start', href: '/' }, { label: 'Gutachter-Plattform', href: '/gutachter-plattform/' }, { label: 'Für Sachverständige' }]}
>
  <Hero
    compact
    eyebrow="Für Sachverständige"
    title="Aufträge strukturiert und effizient bearbeiten."
    text="Die Plattform verbindet Auftragseingang, Dokumentation und Rückfragenführung in einem konsistenten Ablauf."
    primaryLabel="Registrierung anfragen"
    primaryHref="/gutachter-plattform/anfrage/"
    secondaryLabel="Expertenprofil ansehen"
    secondaryHref="/experten/"
  />
  <CallToAction
    title="Registrierung und Qualifikationsprofil abstimmen"
    text="Senden Sie Ihre Anfrage für Onboarding und Zugang zur Plattform."
    href="/gutachter-plattform/anfrage/"
    label="Registrierung anfragen"
  />
</BaseLayout>
