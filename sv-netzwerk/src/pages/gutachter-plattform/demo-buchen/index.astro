---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import CallToAction from '../../../components/CallToAction.astro';
---

<BaseLayout
  title="Demo buchen"
  description="Demo-Termin zur Gutachter-Plattform fuer Versicherer, Regulierer und Sachverstaendige."
  breadcrumbs={[{ label: 'Start', href: '/' }, { label: 'Gutachter-Plattform', href: '/gutachter-plattform/' }, { label: 'Demo buchen' }]}
>
  <Hero
    compact
    eyebrow="Gutachter-Plattform"
    title="Demo-Termin vereinbaren."
    text="Für eine strukturierte Live-Demo senden Sie bitte den Anwendungsfall und den gewuenschten Zeitraum."
    primaryLabel="Plattform-Anfrage senden"
    primaryHref="/gutachter-plattform/anfrage/"
    secondaryLabel="Zurueck zur Plattform"
    secondaryHref="/gutachter-plattform/"
  />

  <CallToAction
    title="Demo jetzt abstimmen"
    text="Die Terminierung erfolgt ueber das Plattform-Anfrageformular."
    href="/gutachter-plattform/anfrage/"
    label="Anfrageformular"
  />
</BaseLayout>
