---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import CallToAction from '../../components/CallToAction.astro';

const items = [
  {
    title: 'Fuer Versicherer',
    text: 'Transparente Auftragsteuerung mit klarer Zuordnung, Statussicht und dokumentierten Entscheidungen.',
    href: '/gutachter-plattform/fuer-versicherungen/'
  },
  {
    title: 'Fuer Regulierer',
    text: 'Strukturierte Unterlagenpruefung, Rueckfragenfuehrung und belastbare Freigabegrundlagen.',
    href: '/gutachter-plattform/fuer-regulierer/'
  },
  {
    title: 'Fuer Sachverstaendige',
    text: 'Saubere Aktenstruktur, standardisierte Berichtspfade und konsistente Qualitaetsanforderungen.',
    href: '/gutachter-plattform/fuer-sachverstaendige/'
  }
];
---

<BaseLayout
  title="Gutachter-Plattform"
  description="Digitale Plattform fuer strukturierte Zusammenarbeit zwischen Versicherern, Regulierern und Sachverstaendigen."
  breadcrumbs={[{ label: 'Start', href: '/' }, { label: 'Gutachter-Plattform' }]}
>
  <Hero
    compact
    eyebrow="Gutachter-Plattform"
    title="Digitale Zusammenarbeit ohne Medienbrueche."
    text="Die Plattform verbindet Beauftragungen, Dokumentation und fachliche Qualitaet in einem klaren Prozessmodell."
    primaryLabel="Plattform-Anfrage senden"
    primaryHref="/gutachter-plattform/anfrage/"
    secondaryLabel="Demo buchen"
    secondaryHref="/gutachter-plattform/demo-buchen/"
  />

  <section class="sv-section">
    <div class="sv-container">
      <SectionHeader eyebrow="Zielgruppen" title="Direkter Einstieg nach Rolle" />
      <div class="sv-grid sv-grid-3">
        {items.map((item, index) => (
          <a class="entry-card" href={item.href}>
            <FeatureCard index={`0${index + 1}`} title={item.title} text={item.text} />
          </a>
        ))}
      </div>
    </div>
  </section>

  <CallToAction
    title="Plattformzugang oder Pilotprojekt abstimmen"
    text="Fuer Zugang, Demo und Integrationsfragen steht ein dediziertes Anfrageformular bereit."
    href="/gutachter-plattform/anfrage/"
    label="Zur Plattform-Anfrage"
  />
</BaseLayout>

<style>
  .entry-card{text-decoration:none;color:inherit}
</style>
