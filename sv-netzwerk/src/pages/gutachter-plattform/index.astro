---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FeatureCard from '../../components/FeatureCard.astro';

const roles = [
  { title: 'Für Versicherer', text: 'Plattformzugang, Pilotprojekte und Zusammenarbeit direkt anfragen.', href: '/gutachter-plattform/fuer-versicherungen/' },
  { title: 'Für Regulierer', text: 'Arbeitsprozesse, Übergaben und Bearbeitungsstände strukturiert abstimmen.', href: '/gutachter-plattform/fuer-regulierer/' },
  { title: 'Für Sachverständige', text: 'Rollen, Zuständigkeiten und digitale Zusammenarbeit verbindlich einbinden.', href: '/gutachter-plattform/fuer-sachverstaendige/' },
];
---

<BaseLayout
  title="Gutachter-Plattform | Direkter Einstieg"
  description="Direkter Einstieg in die Gutachter-Plattform mit Anfrageformular für Zugang und Zusammenarbeit."
  breadcrumbs={[{ label: 'Start', href: '/' }, { label: 'Gutachter-Plattform' }]}
>
  <section class="sv-section">
    <div class="sv-container entry-header">
      <p class="sv-eyebrow">Gutachter-Plattform</p>
      <h1>Plattformzugang direkt anfragen</h1>
      <p class="sv-lead">Der direkte Einstieg führt ohne vorgeschaltete Marketingseite zum Anfrageformular für Zugang, Pilotprojekt oder Zusammenarbeit.</p>
      <div class="entry-actions">
        <a class="sv-button sv-button-primary" href="/gutachter-plattform/anfrage/">Zur Plattform-Anfrage</a>
        <a class="sv-button sv-button-secondary" href="/schaden-melden/">Schaden melden</a>
      </div>
    </div>
  </section>

  <section class="sv-section sv-section-alt">
    <div class="sv-container role-grid">
      {roles.map((role, index) => <FeatureCard index={String(index + 1).padStart(2, '0')} title={role.title} text={role.text} href={role.href} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .entry-header{display:grid;gap:1rem}
  .entry-header h1{margin:0}
  .entry-header .sv-lead{margin:0}
  .entry-actions{display:flex;flex-wrap:wrap;gap:.75rem}
  .role-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:var(--sv-space-5)}
  @media(max-width:58rem){.entry-actions,.role-grid{display:grid;grid-template-columns:1fr}}
</style>
