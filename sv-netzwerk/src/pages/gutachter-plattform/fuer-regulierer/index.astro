---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import CallToAction from '../../../components/CallToAction.astro';
---

<BaseLayout
  title="Gutachter-Plattform für Regulierer"
  description="Strukturierte Dokumentation und klare Freigabepfade für Regulierer."
  breadcrumbs={[{ label: 'Start', href: '/' }, { label: 'Gutachter-Plattform', href: '/gutachter-plattform/' }, { label: 'Für Regulierer' }]}
>
  <Hero
    compact
    eyebrow="Für Regulierer"
    title="Schadenlagen mit prüffähigen Unterlagen steuern."
    text="Die Plattform unterstützt eine nachvollziehbare Vorprüfung mit klaren Rückfragen und verbindlichen Bearbeitungsständen."
    primaryLabel="Plattform-Anfrage"
    primaryHref="/gutachter-plattform/anfrage/"
    secondaryLabel="Schaden melden"
    secondaryHref="/schaden-melden/"
  />
  <CallToAction
    title="Regulierungsprozess aufsetzen"
    text="Wir stimmen Rollen, Unterlagenstandard und Freigabe-Logik gemeinsam ab."
    href="/gutachter-plattform/anfrage/"
    label="Anfrage senden"
  />
</BaseLayout>
