---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import CallToAction from '../../components/CallToAction.astro';
---

<BaseLayout title="Seminare" description="Seminare und Fachartikel-Transfer zu Schadenpraxis und Regulierung.">
  <Hero compact eyebrow="Seminare" title="Fachartikel-Transfer fuer Schadenpraxis und Regulierung." text="Seminar- und Inhouse-Formate werden inhaltlich auf Ihren Schadenkontext abgestimmt." primaryLabel="Kontakt" primaryHref="/kontakt/" secondaryLabel="Fachartikel" secondaryHref="/fachwissen/" />
  <CallToAction title="Seminaranfrage stellen" text="Senden Sie Themengebiet, Zielgruppe und gewuenschten Zeitraum fuer ein passendes Angebot." href="/kontakt/" label="Seminar anfragen" />
</BaseLayout>
