---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import DownloadCard from '../../components/downloads/DownloadCard.astro';
import DownloadFilters from '../../components/downloads/DownloadFilters.astro';
import { downloadCategories, downloadFormats, publishedDownloads } from '../../lib/downloads';

const downloads = publishedDownloads(await getCollection('downloads'));
const categories = downloadCategories(downloads);
const formats = downloadFormats(downloads);
---
<BaseLayout title="Download Center" description="Versionierte Checklisten, Prüfschemata und Arbeitshilfen für Schadenaufnahme, Dokumentation und Regulierung." breadcrumbs={[{label:'Start',href:'/'},{label:'Downloads'}]}>
  <Hero compact eyebrow="SVOS Download Center" title="Prüffähige Arbeitshilfen für die Praxis." text="Versionierte Checklisten, Prüfschemata und Vorlagen für eine strukturierte, nachvollziehbare Schadenbearbeitung." />
  <section class="sv-section">
    <div class="sv-container">
      <SectionHeader title="Arbeitshilfen" text="Alle veröffentlichten Dokumente sind nach Kategorie, Version und Aktualisierungsstand nachvollziehbar erfasst." />
      <DownloadFilters categories={categories} formats={formats} />
      <div class="sv-grid sv-grid-2" data-download-grid>
        {downloads.map((entry) => <DownloadCard id={entry.id} title={entry.data.title} description={entry.data.description} category={entry.data.category} tags={entry.data.tags} file={entry.data.file} fileType={entry.data.fileType} fileSize={entry.data.fileSize} version={entry.data.version} updatedAt={entry.data.publication.updatedAt ?? entry.data.publication.publishedAt} />)}
      </div>
      {downloads.length === 0 && <p>Derzeit sind keine Downloads veröffentlicht.</p>}
    </div>
  </section>
</BaseLayout>
