---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import CallToAction from '../../components/CallToAction.astro';
---

<BaseLayout title="Recht & Compliance" description="Rechtliche und compliance-relevante Grundlagen im SV-Netzwerk.">
  <Hero compact eyebrow="Recht & Compliance" title="Regelkonform und nachvollziehbar handeln." text="Rechtliche Rahmenbedingungen und Dokumentationspflichten werden in den Schadenprozessen verbindlich berücksichtigt." primaryLabel="Datenschutz" primaryHref="/datenschutzerklaerung/" secondaryLabel="Impressum" secondaryHref="/impressum/" />
  <CallToAction title="Compliance-Rückfrage stellen" text="Bei projektspezifischen Anforderungen stimmen wir den Dokumentationsstandard direkt ab." href="/kontakt/" label="Kontakt aufnehmen" />
</BaseLayout>
