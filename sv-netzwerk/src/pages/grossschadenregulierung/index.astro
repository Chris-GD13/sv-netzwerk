---
import BaseLayout from '../../layouts/BaseLayout.astro';

const sent = Astro.url.searchParams.get('gesendet') === '1';
const error = Astro.url.searchParams.get('fehler');
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Großschadenregulierung für Versicherer',
  serviceType: 'Großschadenregulierung und Komplexschadensteuerung',
  areaServed: 'DE',
  provider: { '@id': 'https://www.sv-netzwerk.eu/#organization' },
  url: 'https://www.sv-netzwerk.eu/grossschadenregulierung/',
};
---
<BaseLayout title="Großschadenregulierung für Versicherer | Großschaden beauftragen" description="Großschadenregulierung für Versicherer mit klaren Eskalationsstufen, strukturierter Kostenprüfung und belastbarer Entscheidungsvorlage." structuredData={serviceSchema} breadcrumbs={[{label:'Start',href:'/'},{label:'Leistungen',href:'/leistungen/'},{label:'Großschadenregulierung'}]}>
  <section class="sv-section" id="grossschaden-formular">
    <div class="sv-container gross-grid">
      <article class="sv-card form-card">
        <p class="sv-eyebrow">Großschaden</p>
        <h1>Großschadenregulierung für Versicherer direkt beauftragen</h1>
        <p class="sv-lead">Schadenlage, Dringlichkeit und Prüfziel übermitteln und die Bearbeitung mit klarem Eskalationsrahmen starten.</p>
        <h2>Großschaden-Formular</h2>
        {sent && <p class="status success">Der Auftrag wurde übermittelt. Sie erhalten eine Eingangsbestätigung per E-Mail.</p>}
        {error && <p class="status error">Die Übermittlung konnte nicht verarbeitet werden. Bitte Eingaben prüfen.</p>}
        <form action="/anfrage.php" method="post" accept-charset="UTF-8">
          <input type="text" name="website" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <input type="hidden" name="Formular" value="Großschadenregulierung" />

          <label>Versicherung / Auftraggeber
            <input name="Name" required />
          </label>
          <label>E-Mail
            <input name="E-Mail" type="email" required />
          </label>
          <label>Telefon
            <input name="Telefon" type="tel" />
          </label>
          <label>Schadenort
            <input name="Schadenort" required />
          </label>
          <label>Schadendatum
            <input name="Schadendatum" type="date" required />
          </label>
          <label>Dringlichkeit
            <select name="Dringlichkeit" required>
              <option value="">Bitte auswählen</option>
              <option>Akut</option>
              <option>Hoch</option>
              <option>Normal</option>
            </select>
          </label>
          <label>Schadenart
            <select name="Schadenart" required>
              <option value="">Bitte auswählen</option>
              <option>Brand</option>
              <option>Leitungswasser</option>
              <option>Sturm / Hagel</option>
              <option>Elementar</option>
              <option>Sonstiges</option>
            </select>
          </label>
          <label>Kurzbeschreibung
            <textarea name="Nachricht" rows="8" required></textarea>
          </label>

          <button class="sv-button sv-button-primary" type="submit">Großschaden melden</button>
        </form>
      </article>

      <article class="sv-card">
        <h2>Einsatzrahmen</h2>
        <ul>
          <li>Eskalationsstufe und Erstreaktion nach SLA-Vereinbarung</li>
          <li>Schadenort, Schadenart und belastbare Dringlichkeitsbegründung</li>
          <li>Ansprechpartner für Freigaben, Reserve und Berichtstakt</li>
          <li>Unterlagenstand für Erstbewertung und Nachprüfung</li>
        </ul>
        <a class="sv-button sv-button-secondary" href="/leistungen/kumulschadenmanagement/#kumulschaden-formular">Kumulschaden melden</a>
      </article>
    </div>
  </section>

  <section class="sv-section sv-section-alt">
    <div class="sv-container detail-grid">
      <article class="sv-card">
        <h2>Ablauf in 5 Schritten</h2>
        <ol>
          <li>Erstklassifizierung nach Schadenhöhe, Risiko und Komplexität.</li>
          <li>Technische Feststellung mit priorisiertem Vor-Ort-Umfang.</li>
          <li>Abgrenzung von Schadenanteil, Vorschaden und Instandhaltung.</li>
          <li>Kostenprüfung von KVA, Nachträgen und Rechnungen.</li>
          <li>Entscheidungsvorlage mit Reserve- und Maßnahmenstand.</li>
        </ol>
      </article>
      <article class="sv-card">
        <h2>Ergebnis für Versicherer</h2>
        <ul>
          <li>Strukturierte Großschadenakte mit klaren Entscheidungspunkten</li>
          <li>Belastbare Herleitung für Freigaben, Kürzungen und Rückfragen</li>
          <li>Fortlaufende Reserveeinschätzung mit dokumentierten Annahmen</li>
          <li>Einheitliche Kommunikation zwischen allen beteiligten Rollen</li>
        </ul>
      </article>
      <article class="sv-card">
        <h2>Verantwortung und Methodik</h2>
        <ul>
          <li><a href="/experten/christian-waechter/">Christian Wächter</a> führt Großschadenkoordination und technische Abgrenzung.</li>
          <li><a href="/experten/holger-roth/">Holger Roth</a> steuert Regulierungsabstimmung und Eskalation.</li>
          <li><a href="/experten/carmen-gohl/">Carmen Gohl</a> ergänzt komplexe Gebäudeschäden und Schadenzuordnung.</li>
          <li><a href="/praxisfaelle/">Praxisfälle</a> und <a href="/fachwissen/schadenabgrenzung/">Fachstandard Schadenabgrenzung</a> sind direkt eingebunden.</li>
        </ul>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .form-card h1{margin:0}
  .form-card .sv-lead{margin:0 0 .2rem}
  .gross-grid{display:grid;grid-template-columns:minmax(0,1.25fr) minmax(16rem,.75fr);gap:1.2rem}
  .sv-card{padding:clamp(1.3rem,2.8vw,2rem)}
  .detail-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:var(--sv-space-5)}
  ul{margin:0;padding-left:1.2rem;display:grid;gap:.5rem}
  ol{margin:0;padding-left:1.2rem;display:grid;gap:.5rem}
  form{display:grid;gap:.8rem}
  label{display:grid;gap:.4rem;font-weight:800}
  input,select,textarea{width:100%;padding:.78rem;border:1px solid var(--sv-color-line);border-radius:.6rem;background:#fff}
  .status{padding:.85rem 1rem;border-radius:.6rem;font-weight:700}
  .status.success{background:#e7f7ef;border:1px solid #6db58d;color:#174f31}
  .status.error{background:#fbe9e9;border:1px solid #cc7e7e;color:#6d1f1f}
  .hp-field{position:absolute;left:-100vw;width:1px;height:1px;opacity:0}
  @media(max-width:62rem){.detail-grid{grid-template-columns:1fr}}
  @media(max-width:58rem){.gross-grid{grid-template-columns:1fr;display:grid}}
</style>
