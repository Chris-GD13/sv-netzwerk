---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import CallToAction from '../../components/CallToAction.astro';
const phases=[
  {title:'Erstaufnahme und Struktur',text:'Schadenumfang, Beteiligte, Sofortmaßnahmen und Informationsbedarf werden in einer belastbaren Ausgangslage zusammengeführt.'},
  {title:'Reserve und Maßnahmen',text:'Kostenstände, technische Erfordernisse und Freigaben werden fortlaufend geprüft und dokumentiert.'},
  {title:'Steuerung und Abschluss',text:'Termine, Schnittstellen, Restpunkte und Abschlussunterlagen werden bis zur nachvollziehbaren Entscheidung koordiniert.'},
];
---
<BaseLayout title="Großschadenregulierung" description="Strukturierte Großschadenregulierung mit technischer Bewertung, transparenter Reserve und dokumentierter Steuerung." breadcrumbs={[{label:'Start',href:'/'},{label:'Leistungen',href:'/leistungen/'},{label:'Großschadenregulierung'}]}>
  <Hero compact eyebrow="Großschadenregulierung" title="Umfangreiche Schäden kontrolliert bearbeiten." text="Das SV-Netzwerk verbindet technische Schadenbewertung, koordinierte Kommunikation und dokumentierte Entscheidungsstände vom ersten Ortstermin bis zum Abschluss." primaryLabel="Schaden melden" primaryHref="/schaden-melden/" secondaryLabel="Experten" secondaryHref="/experten/" />
  <section class="sv-section"><div class="sv-container"><SectionHeader eyebrow="Ablauf" title="Drei Phasen mit klarer Verantwortung"/><div class="sv-grid sv-grid-3">{phases.map((item,index)=><FeatureCard index={`0${index+1}`} title={item.title} text={item.text}/>)}</div></div></section>
  <CallToAction title="Großschaden abstimmen" text="Für die Erstzuordnung genügen Schadenart, Objekt, Schadendatum und die vorhandenen Unterlagen." href="/kontakt/" label="Kontakt aufnehmen" />
</BaseLayout>
