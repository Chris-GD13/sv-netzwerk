---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import CallToAction from '../../components/CallToAction.astro';
import { site } from '../../data/site';
---

<BaseLayout title="Über uns | SV-Netzwerk" description="Arbeitsweise, Qualitätsverständnis und Standort des SV-Netzwerks für Bau- und Versicherungsschäden." breadcrumbs={[{label:'Start',href:'/'},{label:'Über uns'}]}>
  <Hero compact eyebrow="Über uns" title="Fachkompetenz braucht Struktur und Verantwortung." text="Das SV-Netzwerk verbindet technische Spezialisierung mit einem gemeinsamen Bearbeitungsstandard. Zuständigkeiten, Prüfgrundlagen und Ergebnisse bleiben in jedem Vorgang nachvollziehbar." primaryLabel="Netzwerk kennenlernen" primaryHref="/netzwerk/" secondaryLabel="Kontakt" secondaryHref="/kontakt/" />
  <section class="sv-section"><div class="sv-container"><SectionHeader eyebrow="Arbeitsverständnis" title="Nicht mehr Beteiligte, sondern klarere Zusammenarbeit" text="Das Netzwerk wird dort eingesetzt, wo ein Schaden mehrere Fachgebiete, Regionen oder Bearbeitungsphasen berührt."/><div class="sv-grid sv-grid-3"><FeatureCard index="01" title="Technisch belegt" text="Feststellungen werden mit Unterlagen, Ortsbefund, Messwerten und erkennbaren Annahmen verbunden."/><FeatureCard index="02" title="Prüfauftrag im Mittelpunkt" text="Bearbeitungstiefe und Aussagegrenzen richten sich nach der konkreten Fragestellung, nicht nach einem Standardschema."/><FeatureCard index="03" title="Verantwortlich koordiniert" text="Für jeden Vorgang bleiben Ansprechpartner, Fachbeiträge, offene Punkte und nächste Entscheidungen erkennbar."/></div></div></section>
  <section class="sv-section sv-section-alt"><div class="sv-container about-grid"><div><p class="sv-eyebrow">Standort Aalen</p><h2>Regional verankert, bundesweit koordiniert.</h2><p class="sv-lead">Von {site.address[0]} in {site.address[1]} werden Schadenaufnahmen, Fachpartner und Dokumentationsstände koordiniert. Die fachliche Besetzung richtet sich nach Schadenart, Objekt und notwendiger Qualifikation.</p></div><div class="about-facts sv-card"><dl><div><dt>Schwerpunkt</dt><dd>Bau- und Versicherungsschäden</dd></div><div><dt>Arbeitsmodell</dt><dd>Interdisziplinäres Sachverständigennetzwerk</dd></div><div><dt>Qualifikation</dt><dd>DIN EN ISO/IEC 17024 im Netzwerk</dd></div><div><dt>System</dt><dd>SVOS für einheitliche Bearbeitungsstände</dd></div></dl></div></div></section>
  <section class="sv-section"><div class="sv-container"><SectionHeader eyebrow="Qualität" title="Was Auftraggeber erwarten können"/><div class="principles"><p><strong>Klare Trennung:</strong> Feststellung, Bewertung und Empfehlung werden sprachlich und fachlich voneinander getrennt.</p><p><strong>Offene Grenzen:</strong> Fehlende Unterlagen, nicht zugängliche Bereiche und verbleibende Unsicherheiten werden benannt.</p><p><strong>Nachvollziehbare Übergaben:</strong> Weitere Fachgebiete werden mit konkreter Fragestellung eingebunden.</p></div></div></section>
  <CallToAction title="Den passenden Bearbeitungsweg festlegen" text="Schildern Sie Schadenbild, Objekt und Entscheidungsbedarf. Wir ordnen Zuständigkeit und nächste Schritte ein." href="/kontakt/" />
</BaseLayout>

<style>.about-grid{display:grid;grid-template-columns:1.1fr .9fr;align-items:start;gap:clamp(2rem,7vw,7rem)}.about-facts{padding:1.5rem 2rem}.about-facts dl{margin:0}.about-facts div{padding:1rem 0;border-bottom:1px solid var(--sv-color-line)}.about-facts div:last-child{border:0}.about-facts dt{color:var(--sv-color-muted);font-size:.75rem;font-weight:850;text-transform:uppercase}.about-facts dd{margin:.25rem 0 0;font-weight:850}.principles{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.principles p{padding:1.4rem;border-top:3px solid var(--sv-color-accent);background:var(--sv-color-surface-alt)}@media(max-width:48rem){.about-grid,.principles{grid-template-columns:1fr}}</style>
