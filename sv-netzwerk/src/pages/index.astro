---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import TeamCard from '../components/TeamCard.astro';
import CallToAction from '../components/CallToAction.astro';
import {library} from '../data/library';
const articles=library.filter(i=>i.type==='article').slice(0,3);
---
<BaseLayout title="Sachverständige und Großschadenregulierung" description="SV-Netzwerk: technische Schadenbewertung, Großschadenregulierung, Fachwissen und SV Operating System.">
  <Hero eyebrow="SV-Netzwerk · Bau & Schaden" title="Technische Klarheit. Belastbare Regulierung." text="Sachverständigenleistungen und Großschadenregulierung für komplexe Bau- und Versicherungsschäden – strukturiert geprüft, präzise bewertet und nachvollziehbar dokumentiert." primaryLabel="Schaden melden" primaryHref="/schaden-melden/" secondaryLabel="Leistungen ansehen" secondaryHref="/leistungen/" />

  <section class="principles"><div class="sv-container principles-grid"><div><span>01</span><strong>Feststellen</strong><p>Schadenbild, Ursache und Umfang technisch erfassen.</p></div><div><span>02</span><strong>Bewerten</strong><p>Kausalität, Plausibilität und Kosten sauber abgrenzen.</p></div><div><span>03</span><strong>Entscheiden</strong><p>Freigaben, Reserven und Empfehlungen belastbar dokumentieren.</p></div></div></section>

  <section class="sv-section services"><div class="sv-container"><SectionHeader eyebrow="Leistungsspektrum" title="Ein durchgängiger Prüf- und Entscheidungsprozess." text="Von der ersten Schadenaufnahme bis zur Schlusserklärung bleibt jeder Schritt fachlich, organisatorisch und dokumentarisch eindeutig."/><div class="sv-grid sv-grid-3"><ServiceCard number="01" title="Komplex- und Großschäden" text="Technische Einordnung, Reserven, Beteiligtensteuerung und nachvollziehbare Begleitung mehrstufiger Schadenverläufe." href="/komplexschaeden/" tone="accent"/><ServiceCard number="02" title="Sachverständigenleistungen" text="Feststellungen, Kausalitätsprüfung, Kostenbewertung und regulierungssichere Empfehlungen aus einer Hand." href="/leistungen/"/><ServiceCard number="03" title="SV Operating System" text="Einheitliche Standards für Prüfung, Dokumentation, Fachwissen und digitale Zusammenarbeit." href="/svos/" tone="dark"/></div></div></section>

  <section class="sv-section sv-section-alt"><div class="sv-container evidence-grid"><div class="evidence-copy"><SectionHeader eyebrow="SVOS" title="Aus Einzelfallwissen wird ein belastbarer Unternehmensstandard." text="Das SV Operating System verbindet Schadenpraxis, Fachwissen und wiederverwendbare Arbeitsstandards zu einer konsistenten Systematik."/><a class="sv-button sv-button-secondary" href="/svos/">SVOS kennenlernen <span aria-hidden="true">→</span></a></div><div class="evidence-board"><div class="board-head"><span>SVOS / WORKFLOW</span><b>STATUS: STRUKTURIERT</b></div><ol><li><span>01</span><div><strong>Auftragsklarheit</strong><p>Prüfgegenstand, Rollen und Zielsetzung festlegen.</p></div></li><li><span>02</span><div><strong>Technische Abgrenzung</strong><p>Schadenbedingte Maßnahmen von Mängeln und Vorschäden trennen.</p></div></li><li><span>03</span><div><strong>Kostenprüfung</strong><p>Mengen, Ansätze und Leistungsumfang plausibilisieren.</p></div></li><li><span>04</span><div><strong>Regulierungsentscheidung</strong><p>Empfehlung, Freigabe und Reserve nachvollziehbar dokumentieren.</p></div></li></ol></div></div></section>

  <section class="sv-section knowledge"><div class="sv-container"><SectionHeader eyebrow="Fachwissen" title="Aktuelle Beiträge aus Regulierung und Sachverständigenpraxis." text="Praxisfälle, technische Abgrenzungen und dokumentationsstarke Arbeitshilfen – thematisch geordnet und durchsuchbar." href="/fachwissen/" label="Bibliothek öffnen"/><div class="sv-grid sv-grid-3">{articles.map(a=><ArticleCard {...a} />)}</div><div class="knowledge-links"><a href="/praxisfaelle/"><b>Praxisfälle</b><span>Reale Schadenbilder und technische Bewertungen →</span></a><a href="/downloads/"><b>Download Center</b><span>Prüfschemata, Checklisten und Arbeitshilfen →</span></a><a href="/suche/"><b>Wissenssuche</b><span>Beiträge, Kategorien und Schlagwörter durchsuchen →</span></a></div></div></section>

  <section class="sv-section expert"><div class="sv-container expert-grid"><div class="expert-panel"><p class="sv-eyebrow">Verantwortung</p><h2>Persönliche Bearbeitung. Vernetzte Fachkompetenz.</h2><p>Der jeweilige Bearbeitungsstand bleibt klar zugeordnet. Spezialwissen wird gezielt eingebunden, ohne Verantwortlichkeiten zu verwischen.</p><div class="expert-facts"><span><b>DIN EN ISO/IEC 17024</b>Zertifizierte Sachverständigenkompetenz</span><span><b>Großschadenregulierung</b>Technische und organisatorische Steuerung</span></div><a class="sv-button sv-button-primary" href="/netzwerk/">Netzwerk ansehen</a></div><TeamCard name="Christian Wächter" role="Sachverständiger & Großschadenregulierer" qualification="DIN EN ISO/IEC 17024 zertifiziert" href="/experten/christian-waechter/"/></div></section>

  <CallToAction title="Ein Schadenfall braucht eine klare fachliche Linie." text="Übermitteln Sie die Eckdaten. Wir ordnen den Vorgang ein und benennen die nächsten sinnvollen Schritte." href="/schaden-melden/" label="Schadenfall einreichen"/>
</BaseLayout>
<style>
.principles{position:relative;z-index:3;margin-top:-2.2rem}.principles-grid{display:grid;grid-template-columns:repeat(3,1fr);overflow:hidden;border:1px solid var(--sv-color-line);border-radius:1.15rem;background:white;box-shadow:var(--sv-shadow-md)}.principles-grid>div{display:grid;grid-template-columns:auto 1fr;column-gap:1rem;padding:1.55rem 1.7rem}.principles-grid>div+div{border-left:1px solid var(--sv-color-line)}.principles span{grid-row:1/3;color:var(--sv-color-accent-strong);font-size:.72rem;font-weight:900;letter-spacing:.1em}.principles strong{font-size:1rem}.principles p{margin:.25rem 0 0;color:var(--sv-color-muted);font-size:.84rem}.services{padding-top:clamp(6rem,10vw,9rem)}.evidence-grid{display:grid;grid-template-columns:.85fr 1.15fr;align-items:center;gap:clamp(3rem,7vw,7rem)}.evidence-board{overflow:hidden;border-radius:1.25rem;background:var(--sv-color-ink);color:white;box-shadow:var(--sv-shadow-lg)}.board-head{display:flex;justify-content:space-between;padding:1rem 1.3rem;border-bottom:1px solid rgba(255,255,255,.14);color:#a9bfca;font-size:.65rem;letter-spacing:.12em}.board-head b{color:#efc36d}.evidence-board ol{margin:0;padding:0;list-style:none}.evidence-board li{display:grid;grid-template-columns:3.5rem 1fr;gap:1rem;padding:1.35rem 1.5rem;border-bottom:1px solid rgba(255,255,255,.1)}.evidence-board li:last-child{border:0}.evidence-board li>span{color:#efc36d;font-weight:900}.evidence-board strong{display:block;margin-bottom:.25rem}.evidence-board p{margin:0;color:#b8cbd5;font-size:.9rem}.knowledge-links{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-top:1.25rem}.knowledge-links a{display:flex;flex-direction:column;padding:1.1rem 1.2rem;border-left:3px solid var(--sv-color-accent);background:var(--sv-color-surface-alt);color:var(--sv-color-ink);text-decoration:none}.knowledge-links span{margin-top:.3rem;color:var(--sv-color-muted);font-size:.82rem}.expert{background:linear-gradient(120deg,#0e2637,#123f5b);color:white}.expert-grid{display:grid;grid-template-columns:1.25fr .75fr;align-items:center;gap:clamp(3rem,7vw,7rem)}.expert h2{color:white}.expert-panel>p:not(.sv-eyebrow){max-width:46rem;color:#c7d7df;font-size:1.08rem}.expert .sv-eyebrow{color:#efc36d}.expert-facts{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;margin:2rem 0}.expert-facts span{padding:1rem;border:1px solid rgba(255,255,255,.15);border-radius:.8rem;color:#b7cad4;font-size:.82rem}.expert-facts b{display:block;margin-bottom:.25rem;color:white}@media(max-width:58rem){.principles-grid,.evidence-grid,.expert-grid{grid-template-columns:1fr}.principles-grid>div+div{border-top:1px solid var(--sv-color-line);border-left:0}.knowledge-links{grid-template-columns:1fr}.principles{margin-top:0}.expert-facts{grid-template-columns:1fr}}
</style>
