---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CallToAction from '../components/CallToAction.astro';
import { library, type LibraryItem } from '../data/library';
const articles: LibraryItem[] = library.filter((item: LibraryItem) => item.type === 'article').slice(0,3);
const services=[
 {number:'01',title:'Komplex- und Großschäden',text:'Technische Bewertung, Koordination und nachvollziehbare Entscheidungen bei anspruchsvollen Schadenlagen.',href:'/komplexschaeden/',tone:'accent' as const},
 {number:'02',title:'Großschadenregulierung',text:'Strukturierte Schadenaufnahme, Kostenprüfung, Reserven und belastbare Kommunikation mit allen Beteiligten.',href:'/grossschadenregulierung/',tone:'default' as const},
 {number:'03',title:'Sachverständigenleistungen',text:'Fachlich fundierte Feststellungen zur Ursache, zum Umfang und zu schadenbedingten Maßnahmen.',href:'/leistungen/',tone:'soft' as const}
];
---
<BaseLayout title="SV-Netzwerk – Bau, Schaden und Regulierung" description="Sachverständige, Großschadenregulierung und SVOS für komplexe Bau- und Versicherungsschäden.">
  <Hero eyebrow="SV-Netzwerk Bau & Schaden" title="Klare Entscheidungen bei komplexen Bau- und Versicherungsschäden." text="Wir verbinden technische Expertise, Großschadenregulierung und digitale Prozesse. Für Versicherer, Auftraggeber, Sachverständige und Fachpartner entsteht eine zentrale, nachvollziehbare Arbeitsgrundlage." primaryLabel="Schaden melden" primaryHref="/schaden-melden/" secondaryLabel="Leistungen ansehen" secondaryHref="/leistungen/" />

  <section class="quick-nav"><div class="sv-container quick-grid"><a href="/leistungen/"><span>01</span><strong>Leistungen</strong><small>Technische Prüfung und Regulierung</small></a><a href="/fachwissen/"><span>02</span><strong>Fachwissen</strong><small>Beiträge, Normen und Praxiswissen</small></a><a href="/praxisfaelle/"><span>03</span><strong>Praxisfälle</strong><small>Reale Schäden nachvollziehbar dokumentiert</small></a><a href="/svos/"><span>04</span><strong>SVOS</strong><small>Ein Standard für alle Prozessschritte</small></a></div></section>

  <section class="sv-section"><div class="sv-container"><SectionHeader eyebrow="Leistungsspektrum" title="Technische Kompetenz trifft strukturierte Regulierung." text="Jeder Vorgang wird fachlich eingeordnet, dokumentiert und in einen klaren Bearbeitungsweg überführt."/><div class="sv-grid sv-grid-3">{services.map((service)=><ServiceCard {...service}/>)}</div></div></section>

  <section class="sv-section sv-section-blue"><div class="sv-container process-layout"><div><SectionHeader eyebrow="SV Operating System" title="Ein gemeinsamer Standard vom Erstkontakt bis zur Entscheidung." text="SVOS schafft eine einheitliche technische, organisatorische und dokumentarische Struktur. Dadurch bleiben Zuständigkeiten, Feststellungen und Freigaben jederzeit nachvollziehbar."/><a class="sv-button sv-button-secondary" href="/svos/">SVOS kennenlernen</a></div><ol class="process-list"><li><span>01</span><div><strong>Erfassen</strong><p>Schadenbild, Beteiligte, Unterlagen und offene Punkte vollständig zusammenführen.</p></div></li><li><span>02</span><div><strong>Prüfen</strong><p>Kausalität, Umfang, Plausibilität, Kosten und Abgrenzungen fachlich bewerten.</p></div></li><li><span>03</span><div><strong>Entscheiden</strong><p>Empfehlungen, Freigaben, Reserven und nächste Schritte belastbar dokumentieren.</p></div></li></ol></div></section>

  <section class="sv-section"><div class="sv-container"><div class="portal-head"><SectionHeader eyebrow="Fachportal" title="Wissen, Praxisfälle und Arbeitshilfen an einem Ort." text="Das Fachportal verbindet Beiträge, reale Fallbeispiele und Downloads zu einem wachsenden Wissenssystem."/><a class="sv-button sv-button-secondary" href="/fachwissen/">Bibliothek öffnen</a></div><div class="portal-grid"><a class="portal-card portal-main" href="/praxisfaelle/"><span>Praxisfälle</span><h3>Reale Schadenfälle strukturiert erklärt.</h3><p>Ursache, Schadenumfang, technische Abgrenzung und Regulierungsweg.</p><b>Praxisfälle ansehen →</b></a><a class="portal-card" href="/downloads/"><span>Downloads</span><h3>Prüflisten und Arbeitshilfen.</h3><p>Direkt nutzbare Unterlagen für Schadenaufnahme und Prüfung.</p><b>Downloadcenter →</b></a><a class="portal-card" href="/gutachter-plattform/"><span>Plattform</span><h3>Experten gezielt zusammenbringen.</h3><p>Auftragsklarheit, geprüfte Unterlagen und nachvollziehbare Prozesse.</p><b>Plattform öffnen →</b></a></div></div></section>

  <section class="sv-section sv-section-alt"><div class="sv-container"><div class="portal-head"><SectionHeader eyebrow="Aktuelles Fachwissen" title="Neue Beiträge aus Sachverständigenpraxis und Regulierung." text="Technische Einordnung ohne pauschale Antworten – mit Blick auf Kausalität, Erforderlichkeit und Kosten."/><a class="sv-button sv-button-secondary" href="/fachwissen/">Alle Beiträge</a></div><div class="sv-grid sv-grid-3">{articles.map((article: LibraryItem)=><ArticleCard {...article}/>)}</div></div></section>

  <section class="sv-section expert-section"><div class="sv-container expert-grid"><div class="expert-copy"><p class="sv-eyebrow">Persönliche Verantwortung</p><h2>Klare Zuständigkeit. Vernetzte Fachkompetenz.</h2><p class="sv-lead">Der Bearbeitungsstand bleibt eindeutig zugeordnet. Spezialwissen wird dort ergänzt, wo der Schadenfall es fachlich verlangt.</p><a class="sv-button sv-button-light" href="/netzwerk/">Netzwerk kennenlernen</a></div><div class="expert-card"><span>CW</span><div><strong>Christian Wächter</strong><p>Sachverständiger & Großschadenregulierer</p><small>DIN EN ISO/IEC 17024 zertifiziert</small></div></div></div></section>

  <CallToAction title="Ein Schadenfall braucht eine klare fachliche Linie." text="Übermitteln Sie die Eckdaten. Wir ordnen den Vorgang ein und benennen die nächsten sinnvollen Schritte." href="/schaden-melden/" label="Schadenfall einreichen"/>
</BaseLayout>
<style>
.quick-nav{position:relative;z-index:5;margin-top:-2.4rem}.quick-grid{display:grid;grid-template-columns:repeat(4,1fr);overflow:hidden;border:1px solid var(--sv-color-line);border-radius:1.2rem;background:white;box-shadow:var(--sv-shadow-md)}.quick-grid a{display:grid;padding:1.35rem 1.5rem;border-right:1px solid var(--sv-color-line);color:var(--sv-color-ink);text-decoration:none;transition:background var(--sv-transition),transform var(--sv-transition)}.quick-grid a:last-child{border-right:0}.quick-grid a:hover{background:var(--sv-color-surface-alt)}.quick-grid span{color:var(--sv-color-accent);font-size:.72rem;font-weight:900}.quick-grid strong{margin:.25rem 0}.quick-grid small{color:var(--sv-color-muted);line-height:1.35}.process-layout{display:grid;grid-template-columns:.9fr 1.1fr;align-items:center;gap:clamp(3rem,8vw,7rem)}.process-list{margin:0;padding:0;list-style:none}.process-list li{display:grid;grid-template-columns:4rem 1fr;gap:1rem;padding:1.5rem 0;border-bottom:1px solid color-mix(in srgb,var(--sv-color-primary) 15%,var(--sv-color-line))}.process-list li>span{display:grid;width:3rem;aspect-ratio:1;place-items:center;border-radius:50%;background:var(--sv-color-primary);color:white;font-weight:900}.process-list strong{font-size:1.25rem}.process-list p{margin:.3rem 0 0;color:var(--sv-color-muted)}.portal-head{display:flex;align-items:end;justify-content:space-between;gap:2rem}.portal-grid{display:grid;grid-template-columns:1.25fr .75fr;gap:1.25rem}.portal-card{display:flex;min-height:18rem;flex-direction:column;padding:2rem;border:1px solid var(--sv-color-line);border-radius:1.3rem;background:white;color:var(--sv-color-ink);text-decoration:none;box-shadow:var(--sv-shadow-sm);transition:transform var(--sv-transition),box-shadow var(--sv-transition)}.portal-card:hover{transform:translateY(-5px);box-shadow:var(--sv-shadow-md)}.portal-card span{color:var(--sv-color-primary-bright);font-size:.75rem;font-weight:900;letter-spacing:.13em;text-transform:uppercase}.portal-card h3{margin-top:auto;font-size:1.65rem}.portal-card p{color:var(--sv-color-muted)}.portal-card b{margin-top:auto;color:var(--sv-color-primary)}.portal-main{grid-row:span 2;min-height:37.25rem;background:radial-gradient(circle at 80% 20%,rgba(245,161,10,.25),transparent 30%),linear-gradient(145deg,#06192b,#0b416d);color:white}.portal-main span,.portal-main b{color:#ffc95f}.portal-main p{color:#c6d9e7}.portal-main h3{max-width:30rem;font-size:clamp(2.1rem,4vw,3.6rem)}.expert-section{background:linear-gradient(135deg,#061a2d,#0b426e);color:white}.expert-grid{display:grid;grid-template-columns:1.2fr .8fr;align-items:center;gap:4rem}.expert-copy h2{color:white}.expert-copy .sv-eyebrow{color:#ffc95f}.expert-copy .sv-lead{color:#d0e0eb}.expert-card{display:flex;align-items:center;gap:1.25rem;padding:2rem;border:1px solid rgba(255,255,255,.18);border-radius:1.3rem;background:rgba(255,255,255,.08);backdrop-filter:blur(12px)}.expert-card>span{display:grid;width:5rem;aspect-ratio:1;place-items:center;border-radius:50%;background:var(--sv-color-accent);color:#101820;font-size:1.4rem;font-weight:950}.expert-card strong{font-size:1.25rem}.expert-card p{margin:.25rem 0;color:#d0e0eb}.expert-card small{color:#9fb8ca}
@media(max-width:58rem){.quick-grid{grid-template-columns:repeat(2,1fr)}.quick-grid a:nth-child(2){border-right:0}.quick-grid a:nth-child(-n+2){border-bottom:1px solid var(--sv-color-line)}.process-layout,.expert-grid{grid-template-columns:1fr}.portal-grid{grid-template-columns:1fr}.portal-main{grid-row:auto;min-height:28rem}.portal-head{align-items:flex-start;flex-direction:column}}
@media(max-width:38rem){.quick-nav{margin-top:-1rem}.quick-grid{grid-template-columns:1fr}.quick-grid a{border-right:0;border-bottom:1px solid var(--sv-color-line)}.quick-grid a:last-child{border-bottom:0}.portal-card{min-height:16rem;padding:1.4rem}.portal-main{min-height:24rem}.expert-card{align-items:flex-start;flex-direction:column}}
</style>
