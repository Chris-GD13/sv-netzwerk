---
import BaseLayout from '../layouts/BaseLayout.astro'; import Hero from '../components/Hero.astro'; import FeatureCard from '../components/FeatureCard.astro'; import ArticleCard from '../components/ArticleCard.astro'; import CallToAction from '../components/CallToAction.astro';
const services=[
 {title:'Komplex- und Großschäden',text:'Technische Einordnung, Schadenabgrenzung, Reservebewertung und dokumentierte Steuerung mehrstufiger Schadenverläufe.',href:'/komplexschaeden/'},
 {title:'Sachverständigenleistungen',text:'Nachvollziehbare Feststellungen, fachliche Bewertungen und belastbare Empfehlungen für Versicherer, Unternehmen und Beteiligte.',href:'/leistungen/'},
 {title:'Gutachter-Plattform',text:'Digitale Zusammenarbeit, strukturierte Aktenführung und vernetzte Fachkompetenz für moderne Schadenprozesse.',href:'/gutachter-plattform/'}
];
const articles=[
 {category:'Schadenregulierung',title:'Nicht jeder Mangel ist ein Versicherungsschaden',text:'Wie Mangel, Vorschaden und schadenbedingte Wiederherstellung fachlich sauber voneinander getrennt werden.',href:'/fachwissen/schadenabgrenzung-mangel-vorschaden-versicherungsschaden/',date:'03.07.2026'},
 {category:'Praxis',title:'Klare Rollen im Schadenfall',text:'Warum eindeutige Zuständigkeiten die Bearbeitungsqualität, Nachvollziehbarkeit und Regulierungssicherheit verbessern.',href:'/fachwissen/klare-rollen-schadenfall-regulierung/',date:'06.07.2026'},
 {category:'Brandschaden',title:'Lichtbogen an einer Leuchte',text:'Ein Praxisfall zeigt, wie aus einem kleinen elektrischen Defekt ein akuter Brandschaden entstehen kann.',href:'/fachwissen/brandschaden-lichtbogen-leuchte/',date:'09.07.2026'}
];
---
<BaseLayout title="Sachverständige und Großschadenregulierung" description="SV-Netzwerk verbindet Sachverständige, Großschadenregulierung und digitale Prozesse für komplexe Bau- und Versicherungsschäden.">
<Hero eyebrow="SV-Netzwerk Bau & Schaden" title="Komplexe Schäden brauchen mehr als einen Gutachter." text="Sie brauchen klare Zuständigkeiten, belastbare technische Bewertungen und einen Prozess, der vom Ortstermin bis zur Entscheidung nachvollziehbar bleibt." primaryLabel="Schaden melden" primaryHref="/schaden-melden/" secondaryLabel="Leistungen ansehen" secondaryHref="/leistungen/" />
<section class="sv-section"><div class="sv-container"><div class="sv-section-head"><div><p class="sv-eyebrow">Leistungssystem</p><h2>Fachkompetenz, die ineinandergreift.</h2><p class="sv-lead">Das SV-Netzwerk führt technische Bewertung, Regulierung und digitale Prozessstruktur in einem konsistenten System zusammen.</p></div><a class="sv-button sv-button-secondary" href="/leistungen/">Alle Leistungen</a></div><div class="sv-grid sv-grid-3">{services.map((item,i)=><FeatureCard index={`0${i+1}`} {...item}/>)}</div></div></section>
<section class="sv-section sv-section-alt"><div class="sv-container system-grid"><div><p class="sv-eyebrow">SV Operating System</p><h2>Vom Einzelvorgang zum steuerbaren Schadenprozess.</h2><p class="sv-lead">SVOS schafft eine gemeinsame technische, organisatorische und dokumentarische Grundlage. Feststellungen, Prüfungen, Entscheidungen und offene Punkte bleiben konsistent verknüpft.</p><div class="sv-stack"><a class="sv-button sv-button-primary" href="/svos/">SVOS kennenlernen</a><a class="sv-button sv-button-secondary" href="/gutachter-plattform/">Digitale Plattform</a></div></div><ol class="process sv-card"><li><span>01</span><div><strong>Erfassen</strong><p>Schadenbild, Beteiligte und Unterlagen strukturiert zusammenführen.</p></div></li><li><span>02</span><div><strong>Prüfen</strong><p>Kausalität, Umfang, Plausibilität und Kosten nachvollziehbar bewerten.</p></div></li><li><span>03</span><div><strong>Entscheiden</strong><p>Empfehlungen, Freigaben, Reserven und nächste Schritte dokumentieren.</p></div></li></ol></div></section>
<section class="sv-section"><div class="sv-container"><div class="sv-section-head"><div><p class="sv-eyebrow">Fachwissensbibliothek</p><h2>Praxiswissen für belastbare Entscheidungen.</h2><p class="sv-lead">Fachbeiträge zu Schadenregulierung, Bau- und Versicherungsschäden, Technik, Normen und dokumentationssicheren Arbeitsweisen.</p></div><a class="sv-button sv-button-secondary" href="/fachwissen/">Bibliothek öffnen</a></div><div class="sv-grid sv-grid-3">{articles.map(item=><ArticleCard {...item}/>)}</div></div></section>
<section class="sv-section sv-section-alt"><div class="sv-container about-grid"><div class="portrait" aria-hidden="true"><span>CW</span></div><div><p class="sv-eyebrow">Niederlassung Süd</p><h2>Christian Wächter</h2><p class="sv-lead">Sachverständiger und Großschadenregulierer, DIN EN ISO/IEC 17024 zertifiziert.</p><p>Schwerpunkte sind Komplex- und Großschäden, technische Schadenabgrenzung, strukturierte Regulierung sowie die Entwicklung dokumentationsstarker digitaler Arbeitsprozesse.</p><a class="sv-button sv-button-primary" href="/experten/christian-waechter/">Profil ansehen</a></div></div></section>
<CallToAction title="Ein Schadenfall braucht eine klare fachliche Linie." text="Übermitteln Sie die wichtigsten Eckdaten. Wir ordnen den Vorgang ein und benennen die nächsten sinnvollen Schritte." href="/schaden-melden/" label="Schadenfall einreichen" />
</BaseLayout>
<style>.system-grid,.about-grid{display:grid;grid-template-columns:1fr 1fr;align-items:center;gap:clamp(3rem,7vw,7rem)}.process{margin:0;padding:1.25rem 2rem;list-style:none}.process li{display:flex;gap:1.25rem;padding:1.5rem 0;border-bottom:1px solid var(--sv-color-line)}.process li:last-child{border-bottom:0}.process span{color:var(--sv-color-accent);font-weight:900}.process strong{font-size:1.1rem}.process p{margin:.25rem 0 0;color:var(--sv-color-muted)}.portrait{display:grid;min-height:28rem;place-items:center;border-radius:2rem;background:linear-gradient(145deg,var(--sv-color-primary),var(--sv-color-ink));box-shadow:var(--sv-shadow-md)}.portrait span{color:white;font-family:var(--sv-font-display);font-size:7rem;font-weight:700;letter-spacing:-.08em}@media(max-width:52rem){.system-grid,.about-grid{grid-template-columns:1fr}.portrait{min-height:18rem}}</style>
