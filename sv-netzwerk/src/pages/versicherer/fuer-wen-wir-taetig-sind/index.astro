---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import { insurerClients } from '../../../data/insurer-clients';
---

<BaseLayout
  title="Für wen wir tätig sind | Versicherer und Instanzbegleitung"
  description="Übersicht der Versicherer, für die das SV-Netzwerk tätig ist, inklusive Begleitung in 1. und 2. Instanz."
  breadcrumbs={[{ label: 'Start', href: '/' }, { label: 'Für Versicherer', href: '/versicherer/' }, { label: 'Für wen wir tätig sind' }]}
>
  <section class="sv-section">
    <div class="sv-container intro">
      <p class="sv-eyebrow">Versichererübersicht</p>
      <h1>Für wen wir tätig sind</h1>
      <p class="sv-lead">Wir unterstützen Versicherer in der operativen Schadenregulierung sowie in der Begleitung von Vorgängen in 1. und 2. Instanz.</p>
    </div>
  </section>

  <section class="sv-section">
    <div class="sv-container">
      <SectionHeader eyebrow="Versicherer" title="Aktuelle Zusammenarbeit" text="Die folgenden Namen werden als Referenzliste geführt. Auf Wunsch können offizielle Logos eingebunden werden, sobald die Freigabe bzw. die Dateivorlagen vorliegen." />
      <div class="logo-grid">
        {insurerClients.map((insurer) => (
          <article class="logo-card">
            <span>{insurer.name}</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="sv-section sv-section-alt">
    <div class="sv-container instance-grid">
      <article class="sv-card">
        <h2>1. Instanz</h2>
        <ul>
          <li>Erstaufnahme und technische Schadenabgrenzung</li>
          <li>Prüffähige Dokumentation und Entscheidungsvorlagen</li>
          <li>Reserveeinschätzung und priorisierte Fallsteuerung</li>
        </ul>
      </article>
      <article class="sv-card">
        <h2>2. Instanz</h2>
        <ul>
          <li>Nachprüfung bestehender Vorgänge und Bewertungen</li>
          <li>Plausibilisierung von KVA, Rechnungen und Nachträgen</li>
          <li>Fachliche Stellungnahmen bei strittigen Schadenpositionen</li>
        </ul>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .intro h1{margin:0}
  .intro .sv-lead{max-width:72ch}
  .logo-grid{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:var(--sv-space-4)}
  .logo-card{display:grid;place-items:center;min-height:5.1rem;padding:1rem;border:1px solid var(--sv-color-line);border-radius:var(--sv-radius-lg);background:rgba(255,255,255,.78);text-align:center}
  .logo-card span{font-weight:850;font-size:.9rem}
  .instance-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:var(--sv-space-5)}
  .instance-grid .sv-card{padding:clamp(1.3rem,2.8vw,2rem)}
  .instance-grid ul{display:grid;gap:.6rem;margin:0;padding-left:1.2rem}
  @media(max-width:72rem){.logo-grid{grid-template-columns:repeat(3,minmax(0,1fr))}}
  @media(max-width:50rem){.logo-grid,.instance-grid{grid-template-columns:1fr}}
</style>
