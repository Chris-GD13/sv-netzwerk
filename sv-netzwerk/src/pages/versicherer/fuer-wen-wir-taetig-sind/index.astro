---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { insurerClients } from '../../../data/insurer-clients';
---

<BaseLayout
  title="Versichererübersicht | SV-Netzwerk"
  description="Übersicht der Versicherer, die bei der operativen Schadenregulierung auf das SV-Netzwerk setzen."
  breadcrumbs={[{ label: 'Start', href: '/' }, { label: 'Für Versicherer', href: '/versicherer/' }, { label: 'Versichererübersicht' }]}
>
  <section class="sv-section">
    <div class="sv-container intro">
      <h1>Versichererübersicht</h1>
      <p class="sv-lead">Wir unterstützen Versicherer in der operativen Schadenregulierung.</p>
      <p class="intro-partner-label">Direkt und über:</p>
      <img class="intro-partner-logo" src="/assets/images/partners/die-regulierer.png" alt="Logo Die Regulierer" width="240" height="80" loading="lazy" />
    </div>
  </section>

  <section class="sv-section">
    <div class="sv-container">
      <div class="logo-grid">
        {insurerClients.map((insurer) => (
          <article class="logo-card">
            {insurer.logo ? (
              <img src={insurer.logo} alt={insurer.logoAlt ?? `Logo ${insurer.name}`} width="160" height="48" loading="lazy" />
            ) : (
              <span>{insurer.name}</span>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="sv-section sv-section-alt">
    <div class="sv-container instance-grid">
      <article class="sv-card">
        <h2>1. Instanz</h2>
        <ul>
          <li>Erstaufnahme und technische Schadenabgrenzung</li>
          <li>Prüffähige Dokumentation und Entscheidungsvorlagen</li>
          <li>Reserveeinschätzung und priorisierte Fallsteuerung</li>
        </ul>
      </article>
      <article class="sv-card">
        <h2>2. Instanz</h2>
        <ul>
          <li>Nachprüfung bestehender Vorgänge und Bewertungen</li>
          <li>Plausibilisierung von KVA, Rechnungen und Nachträgen</li>
          <li>Fachliche Stellungnahmen bei strittigen Schadenpositionen</li>
        </ul>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .intro h1{margin:0}
  .intro .sv-lead{max-width:72ch}
  .intro-partner-label{margin:.85rem 0 .45rem;font-weight:850;color:var(--sv-color-text)}
  .intro-partner-logo{display:block;max-width:min(100%,15rem);max-height:4rem;width:auto;height:auto;object-fit:contain}
  .logo-grid{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:var(--sv-space-4)}
  .logo-card{display:grid;place-items:center;min-height:6rem;padding:1rem;border:1px solid var(--sv-color-line);border-radius:var(--sv-radius-lg);background:rgba(255,255,255,.78);text-align:center}
  .logo-card span{font-weight:850;font-size:.9rem}
  .logo-card img{max-width:min(100%,15rem);max-height:3.1rem;width:auto;height:auto;object-fit:contain}
  .instance-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:var(--sv-space-5)}
  .instance-grid .sv-card{padding:clamp(1.3rem,2.8vw,2rem)}
  .instance-grid ul{display:grid;gap:.6rem;margin:0;padding-left:1.2rem}
  @media(max-width:72rem){.logo-grid{grid-template-columns:repeat(3,minmax(0,1fr))}}
  @media(max-width:50rem){.logo-grid,.instance-grid{grid-template-columns:1fr}}
</style>
