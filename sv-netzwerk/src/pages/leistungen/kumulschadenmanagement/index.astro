---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const sent = Astro.url.searchParams.get('gesendet') === '1';
const error = Astro.url.searchParams.get('fehler');
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Kumulschadenmanagement für Versicherer',
  serviceType: 'Kumulschadenmanagement und Unwetterlagen-Steuerung',
  areaServed: 'DE',
  provider: {
    '@type': 'Organization',
    name: 'SV-Netzwerk Bau & Schaden',
    url: 'https://www.sv-netzwerk.eu/',
  },
  url: 'https://www.sv-netzwerk.eu/leistungen/kumulschadenmanagement/',
};
---
<BaseLayout title="Kumulschadenmanagement für Versicherer | Auftrag direkt erteilen" description="Kumulschadenmanagement für Versicherer: Unwetterschäden direkt melden, priorisieren und strukturiert beauftragen." structuredData={serviceSchema} breadcrumbs={[{label:'Start',href:'/'},{label:'Leistungen',href:'/leistungen/'},{label:'Kumulschadenmanagement'}]}>
  <section class="sv-section" id="kumulschaden-formular">
    <div class="sv-container kumul-grid">
      <article class="sv-card form-card">
        <p class="sv-eyebrow">Kumulschaden</p>
        <h1>Kumulschadenmanagement direkt beauftragen</h1>
        <p class="sv-lead">Formular ohne Zwischenschritt ausfüllen und die Steuerung regionaler Schadenlagen priorisiert starten.</p>
        <h2>Kumulschaden-Formular</h2>
        {sent && <p class="status success">Der Auftrag wurde übermittelt. Sie erhalten eine Eingangsbestätigung per E-Mail.</p>}
        {error && <p class="status error">Die Übermittlung konnte nicht verarbeitet werden. Bitte Eingaben prüfen.</p>}
        <form action="/anfrage.php" method="post" accept-charset="UTF-8">
          <input type="text" name="website" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <input type="hidden" name="Formular" value="Kumulschadenmanagement" />

          <label>Versicherung / Auftraggeber
            <input name="Name" required />
          </label>
          <label>E-Mail
            <input name="E-Mail" type="email" required />
          </label>
          <label>Telefon
            <input name="Telefon" type="tel" />
          </label>
          <label>Region
            <input name="Region" required />
          </label>
          <label>Voraussichtliche Fallzahl
            <input name="Fallzahl" required />
          </label>
          <label>Startdatum
            <input name="Startdatum" type="date" required />
          </label>
          <label>Schadenlage
            <select name="Schadenlage" required>
              <option value="">Bitte auswählen</option>
              <option>Sturm / Hagel</option>
              <option>Starkregen / Überschwemmung</option>
              <option>Leitungswasser</option>
              <option>Gemischte Schadenlage</option>
            </select>
          </label>
          <label>Kurzbeschreibung
            <textarea name="Nachricht" rows="8" required></textarea>
          </label>

          <button class="sv-button sv-button-primary" type="submit">Kumulschaden melden</button>
        </form>
      </article>

      <article class="sv-card">
        <h2>Benötigte Angaben</h2>
        <ul>
          <li>Region und Schadenlage</li>
          <li>Geschätzte Fallzahl</li>
          <li>Zeitraum und Prioritäten</li>
          <li>Ansprechpartner für die Einsatzsteuerung</li>
        </ul>
        <a class="sv-button sv-button-secondary" href="/grossschadenregulierung/#grossschaden-formular">Großschaden melden</a>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .form-card h1{margin:0}
  .form-card .sv-lead{margin:0 0 .2rem}
  .kumul-grid{display:grid;grid-template-columns:minmax(0,1.25fr) minmax(16rem,.75fr);gap:1.2rem}
  .sv-card{padding:clamp(1.3rem,2.8vw,2rem)}
  ul{margin:0;padding-left:1.2rem;display:grid;gap:.5rem}
  form{display:grid;gap:.8rem}
  label{display:grid;gap:.4rem;font-weight:800}
  input,select,textarea{width:100%;padding:.78rem;border:1px solid var(--sv-color-line);border-radius:.6rem;background:#fff}
  .status{padding:.85rem 1rem;border-radius:.6rem;font-weight:700}
  .status.success{background:#e7f7ef;border:1px solid #6db58d;color:#174f31}
  .status.error{background:#fbe9e9;border:1px solid #cc7e7e;color:#6d1f1f}
  .hp-field{position:absolute;left:-100vw;width:1px;height:1px;opacity:0}
  @media(max-width:58rem){.kumul-grid{grid-template-columns:1fr;display:grid}}
</style>
