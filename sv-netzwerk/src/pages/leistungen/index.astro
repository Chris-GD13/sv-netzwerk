---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FeatureCard from '../../components/FeatureCard.astro';

const services = [
  { id: 'sachverstaendigenleistungen', title: 'Sachverständigenleistungen', text: 'Schadenaufnahme, technische Feststellungen, Ursacheneinordnung, Bewertung und verständliche Empfehlung für den konkreten Prüfauftrag.', href: '/schaden-melden/', linkLabel: 'Anfrage stellen' },
  { id: 'versicherer', title: 'Schadenregulierung für Versicherer', text: 'Prüffähige Entscheidungsvorlagen, KVA- und Rechnungsprüfung, Kumulschadenmanagement sowie Großschaden- und Komplexschadenregulierung aus einer abgestimmten Prozessführung.', href: '/leistungen/schadenregulierung-fuer-versicherer/', linkLabel: 'Leistungsseite öffnen' },
  { id: 'rechnungspruefung', title: 'Rechnungs- und KVA-Prüfung', text: 'Technische und kaufmännische Prüfung von Kostenvoranschlägen, Rechnungen, Nachträgen und Regiekosten für belastbare Regulierungsentscheidungen.', href: '/leistungen/rechnungs-und-kva-pruefung/', linkLabel: 'Leistungsseite öffnen' },
  { id: 'technische-schadenbewertung', title: 'Technische Schadenbewertung', text: 'Abgrenzung von Schaden, Vorschaden, Mangel und Instandhaltung mit nachvollziehbarer Herleitung.' },
  { id: 'beweissicherung', title: 'Beweissicherung', text: 'Dokumentation von Zuständen, Spuren, Messwerten und Öffnungen als belastbare Grundlage für die Bearbeitung.' },
  { id: 'gutachter-plattform', title: 'Gutachter-Plattform', text: 'Digitale Zusammenarbeit mit klarer Vorgangsstruktur, Aufgabensteuerung und nachvollziehbaren Bearbeitungsständen.', href: '/gutachter-plattform/anfrage/', linkLabel: 'Zur Plattform-Anfrage' },
];
---

<BaseLayout title="Leistungen für Schadenregulierung und Versicherer | SV-Netzwerk" description="Leistungen für Schadenregulierung, Großschaden, Kumulschaden, Rechnungs- und KVA-Prüfung mit direktem Einstieg in Anfrage und Beauftragung." breadcrumbs={[{label:'Start',href:'/'},{label:'Leistungen'}]}>
  <section class="sv-section">
    <div class="sv-container entry-header">
      <p class="sv-eyebrow">Leistungen</p>
      <h1>Leistungen für Schadenregulierung, Groß- und Kumulschäden</h1>
      <p class="sv-lead">Fachlich belastbare Bearbeitung für Versicherer, Regulierer und Auftraggeber – von der Erstaufnahme bis zur prüffähigen Entscheidung.</p>
    </div>
  </section>

  <section class="sv-section">
    <div class="sv-container">
      <div class="service-grid">
        {services.map((service, index) => (
          <div id={service.id} class="service-anchor"><FeatureCard index={String(index + 1).padStart(2, '0')} title={service.title} text={service.text} href={service.href} linkLabel={service.linkLabel} /></div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .entry-header{display:grid;gap:1rem}
  .entry-header h1{margin:0}
  .entry-header .sv-lead{margin:0}
  .entry-actions{display:flex;flex-wrap:wrap;gap:.75rem}
  .service-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:var(--sv-space-5)}
  .service-anchor{scroll-margin-top:7rem}
  .service-anchor :global(.feature-card){height:100%}
  @media(max-width:72rem){.service-grid{grid-template-columns:repeat(3,minmax(0,1fr))}}
  @media(max-width:58rem){.service-grid{grid-template-columns:repeat(2,minmax(0,1fr))}}
  @media(max-width:42rem){.entry-actions,.service-grid{grid-template-columns:1fr;display:grid}}
</style>
