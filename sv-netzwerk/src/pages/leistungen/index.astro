---
import BaseLayout from '../../layouts/BaseLayout.astro'; import Hero from '../../components/Hero.astro'; import FeatureCard from '../../components/FeatureCard.astro'; import CallToAction from '../../components/CallToAction.astro';
const items=[['Schadenaufnahme & Erstbewertung','Strukturierte Erfassung von Schadenbild, Ursache, Umfang, Beteiligten und Sofortmaßnahmen.'],['Komplex- und Großschadenregulierung','Steuerung umfangreicher Schadenfälle mit belastbaren Berichten, Reserven und dokumentierten Entscheidungen.'],['KVA- und Rechnungsprüfung','Positionsweise Prüfung von Mengen, Leistungen, Preisen, Nachträgen und schadenbedingter Erforderlichkeit.'],['Schadenabgrenzung','Trennung von versichertem Schaden, Vorschaden, Mangel, Instandhaltung und nicht schadenbedingten Kosten.'],['Bautechnische Bewertung','Fachliche Einordnung von Konstruktionen, Feuchte-, Brand-, Oberflächen- und Materialschäden.'],['Digitale Prozessunterstützung','Strukturierte Akten, Aufgaben, Dokumente und Bearbeitungsstände auf Basis des SVOS.']];
---
<BaseLayout title="Leistungen" description="Leistungen des SV-Netzwerks für Sachverständigenarbeit, Schadenregulierung, Prüfungen und digitale Schadenprozesse."><Hero compact eyebrow="Leistungen" title="Technische Bewertung mit klarer Regulierungslinie." text="Vom ersten Schadenbild bis zur abschließenden Empfehlung: strukturiert, nachvollziehbar und auf den konkreten Prüfauftrag ausgerichtet." primaryLabel="Schaden melden" primaryHref="/schaden-melden/"/><section class="sv-section"><div class="sv-container"><div class="sv-grid sv-grid-3">{items.map(([title,text],i)=><FeatureCard index={`0${i+1}`} title={title} text={text}/>)}</div></div></section><CallToAction title="Leistungsbedarf fachlich einordnen" text="Senden Sie uns Schadenart, Objekt, Auftraggeber und vorhandene Unterlagen. Wir prüfen, welche Bearbeitung sinnvoll ist." href="/kontakt/"/></BaseLayout>
