---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CallToAction from '../../../components/CallToAction.astro';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Schadenregulierung für Versicherer',
  serviceType: 'Schadenregulierung, Großschaden- und Kumulschadensteuerung',
  areaServed: 'DE',
  provider: { '@id': 'https://www.sv-netzwerk.eu/#organization' },
  url: 'https://www.sv-netzwerk.eu/leistungen/schadenregulierung-fuer-versicherer/',
};
---

<BaseLayout
  title="Schadenregulierung für Versicherer | Prozess, SLA, Entscheidungsvorlagen"
  description="Schadenregulierung für Versicherer mit SLA-gesteuerter Erstreaktion, technischer Abgrenzung und prüffähigen Entscheidungsvorlagen."
  breadcrumbs={[{label:'Start',href:'/'},{label:'Leistungen',href:'/leistungen/'},{label:'Schadenregulierung für Versicherer'}]}
  structuredData={serviceSchema}
>
  <section class="sv-section">
    <div class="sv-container intro">
      <p class="sv-eyebrow">Versicherer-Leistung</p>
      <h1>Schadenregulierung für Versicherer mit klarer Prozessverantwortung</h1>
      <p class="sv-lead">Wir verbinden Erstreaktion, technische Abgrenzung und Kostenprüfung in einem einheitlichen Ablauf für belastbare Regulierungsentscheidungen.</p>
    </div>
  </section>

  <section class="sv-section">
    <div class="sv-container grid">
      <article class="sv-card">
        <h2>Leistungsmodule</h2>
        <ul>
          <li>Technische Schadenabgrenzung und Ursacheneinordnung</li>
          <li>KVA- und Rechnungsprüfung inklusive Nachträgen und Regiekosten</li>
          <li>Steuerung von Großschaden- und Kumulschadenlagen</li>
          <li>Laufende Reservefortschreibung mit dokumentierten Annahmen</li>
        </ul>
      </article>
      <article class="sv-card">
        <h2>Prozess & SLA</h2>
        <ul>
          <li>Erstreaktion und Priorisierung nach vereinbartem SLA-Rahmen</li>
          <li>Transparente Übergaben zwischen Regulierer, Sachverständigen und Dienstleistern</li>
          <li>Einheitliche Aktenstruktur für nachvollziehbare Entscheidungen</li>
          <li>Regelmäßige Status- und Risikoberichte je Schadenlage</li>
        </ul>
      </article>
      <article class="sv-card">
        <h2>Typische Einsatzfälle</h2>
        <ul>
          <li><a href="/grossschadenregulierung/">Großschadenregulierung bei komplexen Einzelfällen</a></li>
          <li><a href="/leistungen/kumulschadenmanagement/">Kumulschadenmanagement bei regionalen Schadenlagen</a></li>
          <li><a href="/leistungen/rechnungs-und-kva-pruefung/">Rechnungs- und KVA-Prüfung mit Nachtragskontrolle</a></li>
          <li>Wohngebäude, Gewerbe und Industrie mit bundesweiter Koordination</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="sv-section sv-section-alt">
    <div class="sv-container grid">
      <article class="sv-card">
        <h2>Ablauf in 4 Schritten</h2>
        <ol>
          <li>Vorgang und Schadenziel aufnehmen.</li>
          <li>Technische Feststellung und Abgrenzung durchführen.</li>
          <li>Kosten, Nachträge und Reserven prüfen.</li>
          <li>Entscheidungsvorlage mit offenen Punkten übergeben.</li>
        </ol>
      </article>
      <article class="sv-card">
        <h2>Verantwortung und Nachweis</h2>
        <ul>
          <li><a href="/experten/christian-waechter/">Christian Wächter</a> verantwortet Groß- und Komplexschäden.</li>
          <li><a href="/experten/carmen-gohl/">Carmen Gohl</a> verantwortet Schadenabgrenzung bei Gebäudeschäden.</li>
          <li><a href="/experten/holger-roth/">Holger Roth</a> verantwortet operative Regulierungsabstimmung.</li>
          <li><a href="/praxisfaelle/">Praxisfälle</a> und <a href="/fachwissen/">Fachwissen</a> sind pro Vorgang verknüpft.</li>
        </ul>
      </article>
      <article class="sv-card">
        <h2>Direkter Einstieg</h2>
        <ul>
          <li><a href="/versicherer/#anfrage">Anfrage oder Beauftragung</a> mit vollständigen Vorgangsdaten</li>
          <li><a href="/versicherer/fuer-wen-wir-taetig-sind/">Versichererübersicht</a> für Zusammenarbeit und Routing</li>
          <li><a href="/leistungen/">Leistungsübersicht</a> für ergänzende Module</li>
          <li><a href="/kontakt/">Direkter Kontakt</a> für Abstimmung im Bestand</li>
        </ul>
      </article>
    </div>
  </section>

  <CallToAction
    title="Schadenregulierung für Ihr Portfolio abstimmen"
    text="Übermitteln Sie Schadenart, Region, Volumen und gewünschte Bearbeitungstiefe direkt über das Versicherer-Formular."
    href="/versicherer/#anfrage"
    label="Anfrage / Beauftragung starten"
  />
</BaseLayout>

<style>
  .intro h1{margin:0}
  .intro .sv-lead{max-width:68ch}
  .grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:var(--sv-space-5)}
  .sv-card{padding:clamp(1.3rem,2.8vw,2rem)}
  ul{display:grid;gap:.55rem;margin:0;padding-left:1.2rem}
  ol{display:grid;gap:.55rem;margin:0;padding-left:1.2rem}
  @media(max-width:62rem){.grid{grid-template-columns:1fr}}
</style>
